

<!DOCTYPE html>
<!--
This is a starter template page. Use this page to start your new project from
scratch. This page gets rid of all links and provides the needed markup only.
-->
<html>
<head>

    @RenderSection("styles", required: false)


    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>@ViewBag.Title</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/Assets/bower_components/font-awesome/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="~/Assets/bower_components/Ionicons/css/ionicons.min.css">
    <!-- Pace style -->
    <link rel="stylesheet" href="~/Assets/plugins/pace/pace.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/Assets/dist/css/AdminLTE.min.css">
    <!-- Select2 -->
    <link rel="stylesheet" href="~/Assets/bower_components/select2/dist/css/select2.min.css">
    <link rel="stylesheet" href="~/Assets/dist/css/alt/AdminLTE-select2.min.css">
    <!-- AdminLTE Skins. We have chosen the skin-blue for this starter
          page. However, you can choose any other skin. Make sure you
          apply the skin class to the body tag so the changes take effect. -->
    @*<link rel="stylesheet" href="~/Assets/dist/css/skins/skin-blue.min.css">*@
    <link rel="stylesheet" href="~/Assets/dist/css/skins/_all-skins.min.css">
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
    <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <![endif]-->
    <!-- Google Font -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,600,700,300italic,400italic,600italic">

    <link href="~/Assets/css/custom.css?v=1.0.3" rel="stylesheet" />
    <link rel="shortcut icon" type="image/png" href="http://themyriad.com/Assets/images/favicon.png">
    <link href="~/Assets/css/toast.css" rel="stylesheet" />
    <link href="~/Content/Css/Common.css" rel="stylesheet" />

</head>
<!--
BODY TAG OPTIONS:
=================
Apply one or more of the following classes to get the
desired effect
|---------------------------------------------------------|
| SKINS         | skin-blue                               |
|               | skin-black                              |
|               | skin-purple                             |
|               | skin-yellow                             |
|               | skin-red                                |
|               | skin-green                              |
|---------------------------------------------------------|
|LAYOUT OPTIONS | fixed                                   |
|               | layout-boxed                            |
|               | layout-top-nav                          |
|               | sidebar-collapse                        |
|               | sidebar-mini                            |
|---------------------------------------------------------|
-->
<body class="hold-transition skin-black sidebar-mini">

    <div class="wrapper">

        <!-- Loader -->
        <div class="myriad-loader" id="loader" style="display: none;">
            <div id="loading-bar-spinner" class="spinner"><div class="spinner-icon"></div></div>
        </div>

        <!-- Main Header -->
        @Html.Partial("/Areas/Student/Views/Shared/_Header.cshtml")

        <!-- Left side column. contains the logo and sidebar -->
        @Html.Partial("/Areas/Student/Views/Shared/_SidebarMenu.cshtml")

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <section class="content-header">
                @Html.Partial("/Areas/Student/Views/Shared/_Breadcrumb.cshtml")
            </section>
            <!-- Main content -->
            <section class="content container-fluid">
                <!--------------------------
            | Your Page Content Here |
            -------------------------->

                @RenderBody()

                <div id="snackbar"></div>
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <!-- Main Footer -->
        <footer class="main-footer no-print">
            <!-- To the right -->
            <div class="pull-right hidden-xs">
                @* Design &amp; Developed by <a href="https://www.bits-global.com/" target="_blank"><strong>BITS</strong></a>*@
            </div>
            <!-- Default to the left -->
            <strong>Copyright &copy; 2026 <a href="#">The Myriad</a>.</strong> All rights reserved.
        </footer>

        <!-- Control Sidebar -->


        <div class="modal fade" id="fileSizeMessage" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                        <h4 class="modal-title" id="myModalLabel">Alert</h4>
                    </div>

                    <div class="modal-body">
                        <p>Maximum allowed file size is 1MB.</p>
                        <p class="debug-url"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad" data-dismiss="modal">OK</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="message_modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                        <h4 class="modal-title" id="myModalLabel">Information</h4>
                    </div>

                    <div class="modal-body">
                        <p class="message_modal_text"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad" data-dismiss="modal">OK</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

            @using (Html.BeginForm("", "", FormMethod.Post, new { id = "delete_form" }))
            {
                @Html.AntiForgeryToken()

                <div class="modal-dialog">
                    <div class="modal-content">

                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                            <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
                        </div>

                        <div class="modal-body">
                            <p>You are about to delete this record. This process is irreversible.</p>
                            <p> Are you sure?</p>
                            <p class="debug-url"></p>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-themyriad btn-ok">Delete</button>
                        </div>
                    </div>
                </div>


            }
        </div>


        <div class="modal" id="CancelBtnConfirm">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">×</span>
                        </button>
                        <h4 class="modal-title">Are you sure you want to go Back?</h4>
                    </div>
                    <div class="modal-body">
                        <p>Changes you have made may not be saved.</p>
                        <p>Do you want to leave?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                        <button class="btn btn-themyriad btn-ok  confirmGoBack">Yes</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>

    <!-- ./wrapper -->
    <!-- REQUIRED JS SCRIPTS -->
    <!-- jQuery 3 -->
    <script src="~/Assets/bower_components/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="~/Assets/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- AdminLTE App -->
    <script src="~/Assets/dist/js/adminlte.min.js"></script>
    <!-- Optionally, you can add Slimscroll and FastClick plugins.
         Both of these plugins are recommended to enhance the
         user experience. -->
    <!-- PACE -->
    <script src="~/Assets/bower_components/PACE/pace.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <!-- Select2 -->
    <script src="~/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script src="~/Scripts/Common.js?v=@DateTime.Now.ToString("hhmmsstt")"></script>


    <script src="~/Assets/js/toast.js"></script>
    @RenderSection("scripts", required: false)
    <script>
        function showMessage(msg) {
            $('.message_modal_text').text(msg);
            $('#message_modal').modal('show');
        }
        $(document).ready(function () {
            //$.fn.datepicker.defaults.format = "dd/mm/yyyy";
            $('#confirm-delete').on('show.bs.modal', function (e) {
                $('#delete_form').attr('action', $(e.relatedTarget).data('href'));
            });

            $('#message_modal').on('show.bs.hide', function (e) {
                $('.message_modal_text').text('');
            });
        });
        $(document).ready(function () {
            $.ajax({
                url: "/User/GetProfileImage",
                method: "Get",
                success: function (data) {
                    var res = data.Data;
                    if (res != null) {
                        $('.profileImage').attr('src', res.ImageUrl);
                    }
                }

            });

            GetNotifications();
        });
        function GetNotifications() {
            var url = GetFormatedUrl("/Student/Notification/GetNotifications")
            $.ajax({
                type: "Get",
                url: url,
                success: function (data) {
                    var data = data.notifications;
                    var noti_count = "";
                    var total_noti = 0;
                    var html = "";
                    if (data != null) {
                        $.each(data, function (index, value) {
                            total_noti = data.length;
                            if (value.Counts == 0)
                                noti_count = '';
                            else
                                noti_count = value.Counts;

                            html += ` <li>
                                        <a href="${value.RedirectURL}">
                                            <h4 style="font-weight: bold"> ${value.Subject}</h4>
                                         <div>  <p>${value.Description}</p></div>
                                        </a>
                                    </li>`;
                        });
                        $('#noti_descriptions').html(html);
                        $('.total_noti').html(`You have ${total_noti} notifications`);
                        $('.noti_count').html(noti_count);
                    }
                }
            });
        }
        function UpdateNotification() {
            var url = GetFormatedUrl("/Student/Notification/UpdateNotification")
            $.ajax({
                type: "Get",
                url: url,
                success: function (data) {
                    GetNotifications();
                }

            })
        }
    </script>
</body>
</html>