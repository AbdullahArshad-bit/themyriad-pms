@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.TransportationBookingReportVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Transport Booking Detail Report";
    ViewBag.HeaderDescription = "Transport Booking Detail Report";
    ViewBag.Title = "Transport Booking Detail Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    div.container {
        max-width: 1200px;
    }

    .right {
        text-align: right;
    }

    table.dataTable tfoot th {
        text-align: right;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="StudentTransportaton-table" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Person Name</th>
                            <th>Myriad ID</th>
                            <th>Departure Time</th>
                            <th>Bus</th>
                            <th>Seat Number</th>
                            <th>Reservation Date</th>
                            <th>Route Name</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.MyriadID</td>
                                <td>@item.DepartureTime</td>
                                <td>@item.Bus</td>
                                <td>@item.SeatNumber</td>
                                <td>@item.ReservationDate</td>
                                <td>@item.RouteName</td>

                                @{
                                    if (item.Status == Enumeration.TransportationBooking.Booked.ToString())
                                    {
                                        <td><span class='label label-success'>@item.Status</span></td>
                                    }
                                    else
                                    {
                                        <td><span class="label label-danger">@item.Status</span></td>
                                    }
                                }
                                <td>
                                    @if (item.Status == "Booked" && DateTime.Now.TimeOfDay.CompareTo(item.Time) < 0 && DateTime.ParseExact(item.ScheduleDate, "dd/MM/yyyy", null) == DateTime.Today)
                                    {
                                        using (Html.BeginForm("CancelSeat", "Transport", new { id = "_Id" }, FormMethod.Post, new { id = "cancelForm" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a title="Cancel Seat" @("onclick=OpenConfirmCancelSeatModal(" + item.Id + ")") href="#"><i class="fa fa-remove"></i></a>
                                        }
                                        @*<a title="Cancel Booking" href="@Url.Action("CancelSeat", "Transport", new { id = item.Id })"><i class="fa fa-remove"></i></a>*@

                                    }
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    <div class="modal" id="CancelBtnConfirm">
        <form method="post" action="@Url.Action("CancelSeat", "Transport")">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                        <h4 class="modal-title" id="myModalLabel">Confirm Cancel Booking</h4>
                    </div>

                    <div class="modal-body">
                        <p>You are about to cancel a seat. This process is irreversible.</p>
                        <p> Are you sure?</p>
                        <p class="debug-url"></p>
                        <input type="hidden" name="id" id="ids" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                        <button class="btn btn-themyriad btn-ok" type="submit"> Yes</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </form>
    </div>
</div>

@section scripts{


    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    @*<script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>*@

    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        function OpenConfirmCancelSeatModal(id) {
            var action = document.getElementById('cancelForm').action;
            action = action.replace("_Id", id);
            $('#ids').val(id);
            $('form#cancelForm').attr('action', action);
            $('#CancelBtnConfirm').modal('show');
        }
        $(document).ready(function () {
            $('#StudentTransportaton-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                "pageLength": -1,
                buttons: [
                    

                ],
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                columnDefs: [
                    { type: 'date-euro', targets: 4 }
                ]
            });
            $('.dataTables_length').addClass('bs-select');
        });


    </script>


    <script type="text/javascript">


        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                //startDate.setDate(startDate.getDate(new Date(selected.date.valueOf())));
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetPaymentDetail() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var RouteId = $('#RouteId').val();
            window.location.href = GetFormatedUrl("/Reporting/TransportationBookingReport?FromDate=" + SD + "&ToDate=" + ED + "&StudentId=" + StudentId + "&RouteId=" + RouteId);

        };
        function Print() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var PaymentId = $('#PaymentId').val();
            var userid = $('#userid').val();
            var Type = $('#type').val();
            window.open("/Reporting/GetPaymentsDetailPDFReport?FromDate=" + SD + "&ToDate=" + ED + "&PaymentId=" + PaymentId + "&StudentId=" + StudentId, + "&userid=" + userid + "&type=" + Type, '_blank');
        }


    </script>

}