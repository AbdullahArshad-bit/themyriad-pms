@using PMS.Common.Classes
@{
    ViewBag.Header = "Payments";
    ViewBag.HeaderDescription = "All Payments";
    ViewBag.Title = "Payments | PMS";
    var payments = ViewBag.payments as List<PMS.DTO.ViewModels.PaymentViewModels.PaymentVM>;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
            @*<div class="input-group-btn">
                    <a href="@Url.Action("AddPerson", "PersonManage")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Person</a>
                </div>*@


        </div>
        <div class="row">

            <div class="col-md-12">

                <table id="Payments" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th>Transaction Code</th>
                            <th>Payment Date</th>
                            <th>Remarks</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            @* <th>Status</th>*@
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var payment in payments)
                        {
                            <tr>
                                <td>@payment.TransactionCode</td>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.Remarks</td>
                                <td>@payment.Amount</td>
                                <td>@payment.PaymentName</td>
                                @*<td>
                                        @if (payment.Status == true)
                                        {
                                            <span class="text-success label label-success">Approved</span>
                                        }
                                        else
                                        {
                                    <span class="text-danger label label-primary">Pending</span>
                                        }
                                    </td>*@
                                <td>
                                    <a title="Details" onclick="openReport(@payment.Id)"><i class="fa fa-download"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>


@section scripts{

    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>

        $(document).ready(function () {
            $('#Payments').DataTable({
                scrollY: true,
                scrollX: true
            });
        });
        function openReport(id) {

            window.open('/Reporting/GetPaymentTransactionDetailReport?Id=' + id, '_blank');
        }

    </script>
}