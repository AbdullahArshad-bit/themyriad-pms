@using PMS.Common.Classes
@{
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Bookings List";
    ViewBag.HeaderDescription = "All Bookings";
    ViewBag.Title = "All Bookings | PMS";

    var bookings = ViewBag.Bookings as List<PMS.DTO.ViewModels.BookingViewModels.BookingListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }

            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div style="overflow: auto; width:100%">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Booking Number</th>
                            <th>Check In date</th>
                            <th>Check Out date</th>
                            @*<th>Occupancy</th>*@
                            <th>Room Type</th>
                            <th>Monthly Rate</th>
                            @*<th>Status</th>*@
                            @*<th>Phone</th>*@
                            @*<th>Requests</th>*@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in bookings)
                        {
                            <tr>
                                <td>@booking.BookingNumber</td>
                                <td>@booking.CheckInDate.ToString("dd-MMM-yyyy")</td>
                                <td>@(booking.CheckOutDate == null ? "" : ((DateTime)booking.CheckOutDate).ToString("dd-MMM-yyyy"))</td>
                                @*<td>@booking.Commitment</td>*@
                                <td>@booking.RoomType</td>
                                <td>@((booking.PriceConfig?.Price ?? 0M) + (booking.PriceConfig?.CleaningCharge ?? 0M))</td>
                                @*@{
                                        if (Convert.ToBoolean(booking.IsCancel))
                                        {
                                            <td><span class='label label-danger'>Cancelled</span></td>
                                        }
                                        else
                                        {
                                            <td>@(booking.Status.ToLower().Contains("pending") ? Html.Raw("<span class='label label-danger'>" + booking.Status + "</span>") : Html.Raw("<span class='label label-success'>" + booking.Status + "</span>"))</td>
                                        }
                                    }*@
                                @*<td>@booking.Phone</td>*@
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>
    </div>
</div>

@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>

        $(document).ready(function () {
            $('.data-table').DataTable({
                scrollY: true,
                scrollX: true
            });
        });

    </script>

}