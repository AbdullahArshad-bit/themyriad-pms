﻿@model PMS.DTO.ViewModels.DashboardViewModel.Dashboard
@using PMS.DTO.ViewModels.DashboardViewModel
@{
    ViewBag.Title = "The Myriad | Resident Portal";
    //ViewBag.Header = "Dashboard";
    ViewBag.HeaderDescription = "";

    var PendingFee = ViewBag.PendingFee as List<PendingFeeAssesment>;


}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}


<style>
body {
    background-color: #f2f2f2;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    margin: 0;
    padding: 0;
}

    .section {
        margin: 50px auto;
        width: 80%;
        display: grid;
        /*grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));*/
        grid-template-columns: repeat(3, 1fr);
        /*grid-template-columns: repeat(3, minmax(200px, 250px));*/
        grid-gap: 35px;
        justify-content: center;
    }

/* Dashboard card */
    .newbox {
        background: linear-gradient(145deg, #222d32, #1e282c);
        border-radius: 12px;
        padding: 25px 20px;
        text-align: center;
        color: #f5f5f5;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease-in-out;
        border: 1px solid #2a3b44;
        position: relative;
        overflow: hidden;
        aspect-ratio: 1 / 0.6;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

/* Subtle hover animation */
.newbox::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(194,14,26,0.2) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.newbox:hover::after {
    opacity: 1;
}

.newbox:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.5);
    border-color: #c20e1a;
}

    .icon {
        font-size: 48px;
        margin-bottom: 15px;
        color: #c20e1a;
        align-self: center;
    }

    .title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 8px;
        align-self: center;
    }

.subtitle {
    font-size: 14px;
    color: #b8c7ce;
}

/* Responsive tweaks */
@@media (max-width: 1024px) {
    .section {
        width: 85%;
        grid-gap: 25px;
    }
}

@@media (max-width: 768px) {
    .section {
        width: 90%;
        grid-template-columns: repeat(2, 1fr);
        grid-gap: 20px;
        margin: 30px auto;
    }
    .newbox {
        padding: 20px 15px;
    }
    .icon {
        font-size: 40px;
        margin-bottom: 12px;
    }
    .title {
        font-size: 18px;
    }
}

@@media (max-width: 480px) {
    .section {
        width: 95%;
        grid-template-columns: 1fr;
        grid-gap: 15px;
        margin: 20px auto;
    }
    .newbox {
        padding: 25px 15px;
        aspect-ratio: 1 / 0.5;
    }
    .icon {
        font-size: 36px;
        margin-bottom: 10px;
    }
    .title {
        font-size: 16px;
    }
}
</style>

<body>
    <div class="section">
        <div class="newbox" onclick="window.location.href='@Url.Action("Profile","User")'">
            <div class="icon"><i class="fa fas fa-user-plus"></i></div>
            <div class="title">Profile</div>
        </div>
        <div class="newbox" onclick="window.location.href='@Url.Action("BookingList", "Booking")'">
            <div class="icon"><i class="fa fa fa-group"></i></div>
            <div class="title">My Bookings</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Action("InvoicingList","Invoicings")'">
            <div class="icon"><i class="fa fas fa-file-word-o"></i></div>
            <div class="title">My Invoices</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Action("StudentContracts","ContractsManage")'">
            <div class="icon"><i class="fa fa-file-pdf-o"></i></div>
            <div class="title">My Contracts</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Action("PaymentList","Payment")'">
            <div class="icon"><i class="fa fa-money"></i></div>
            <div class="title">My Payments</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Content("/Student/Invoicings/InvoicingList?ispaid=false")'">
            <div class="icon"><i class="fa fas fa-file-word-o"></i></div>
            <div class="title">Unpaid Invoices</div>
        </div>

        @*<div class="newbox" onclick="window.location.href='@Url.Action("Index","Ticket")'">
            <div class="icon"><i class="fa fa-ticket"></i></div>
            <div class="title">My Complaints</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Action("Routes","Transport")'">
            <div class="icon"><i class="fa fa-bus"></i></div>
            <div class="title">Routes</div>
        </div>

        <div class="newbox" onclick="window.location.href='@Url.Action("GetStudentBookingReport","Transport")'">
            <div class="icon"><i class="fa fa-circle-o-notch"></i></div>
            <div class="title">My Transport Bookings</div>
        </div>*@

    </div>
</body>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(document).ready(function () {
            $('#FeeAssessment').DataTable({
                "pageLength": 5,
                dom: 'Bfrtip',
                buttons: [
                    'excelHtml5',
                ]
            });
        });
    </script>
}