@model PMS.EF.Invoicing
@using PMS.Common.Classes;
@using PMS.EF;

@{
    ViewBag.Header = "Invoicing";
    ViewBag.HeaderDescription = "Invoicing Detail";
    ViewBag.Title = "Print Invoice | PMS";

    var statementUrl = Url.Action("PartnerLedger", "payments", new { personId = Model.StudentId });
}
@{
    var Details = (List<InvoicingDetail>)ViewBag.InvoicingDetail;
}
<div class="box-header with-border no-print">
    <div class="input-group-btn">
        <a href="@Url.Action("InvoicingList", "Invoicings")" class="btn btn-themyriad"><i class="fa fa-arrow-left" style="padding-right: 5px;"></i>Back to Invoices</a>
    </div>
</div>

<section class="invoice" id="Pdf2">
    <!-- title row -->
    <div class="row">
        <div class="col-xs-12">
            <h2 class="page-header">
                @*<span class="logo-lg"><img src="@Url.Content("~/Assets/Images/logo.png")" alt="logo"></span>*@
                <span class="logo-lg"><img src="https://themyriad.com/Assets/images/logo.png" alt="logo"></span>
            </h2>
        </div>
        <!-- /.col -->
    </div>
    <!-- info row -->
    <div class="row invoice-info">
        <div class="col-sm-4 invoice-col">
            <b>Invoice#: @Model.Code </b><br>
            <b>Location: </b> @Model.Location.LocationName<br>
            <b>Resident ID:</b> <a href="#" onclick="window.open('@statementUrl');">@Model.Person.Code:  @Model.Person.FullName </a><br>
            <b>Phone Number: </b> @Model.Person.Phone<br>
            <b>Invoice Date:</b>  @Model.InvoiceDate.ToString("dd/MM/yyyy")<br>

            <b>Status:</b> @{
                if (Model.IsApproved)
                {
                    <span class="label label-success">Approved</span>
                }
                else
                {
                    <span class="label label-primary">Pending</span>

                }

            } <br>
            @*<b>Account:</b> @Model.NetAmount
                <br />*@
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
    <!-- Table row -->
    <div class="row">
        <div class="col-xs-12 table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Sr#</th>
                        <th>Service</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th class="col-md-3">Taxes</th>
                        <th>Net Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int count = 1; }
                    @foreach (var item in Details)
                    {

                        <tr>
                            <td>@count</td>
                            <td>@item.ServiceName</td>
                            <td>@item.Description</td>
                            <td>@item.Price</td>
                            <td>
                                <select name=det[@count][TaxesIds] autocomplete="off" class="form-control select2 taxes" id="TaxIds" multiple="multiple" data-Taxids="@item.TaxesIds" disabled></select>
                            </td>
                            <td>@item.TotalAmount</td>
                        </tr>
                        count++;
                    }

                </tbody>
            </table>
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->

    <div class="row">
        <!-- accepted payments column -->
        <div class="col-xs-8">
            <p class="lead">Remarks:</p>
            <p class="text-muted well well-sm no-shadow" style="margin-top: 10px;">
                @Model.Remarks
            </p>
        </div>
        <!-- /.col -->
        <div class="col-xs-4">
            <div class="table-responsive">
                <table class="table">
                    <tbody>
                        <tr>
                            <th style="width:50%">Subtotal:</th>
                            <td>@Model.TotalPrice</td>
                        </tr>
                        <tr>
                            <th>Tax Amount:</th>
                            <td>@Model.TaxAmount</td>
                        </tr>


                        @if (Model.InvoiceTaxDetails != null)
                        {
                            foreach (var item in Model.InvoiceTaxDetails.ToList())
                            {
                                <tr>
                                    <th>@item.TaxName</th>
                                    <td>@item.TaxAmount</td>
                                </tr>
                            }
                        }
                        <tr>
                            <th>Net Total:</th>
                            <td>@Model.NetAmount</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
    <!-- this row will not appear when printing -->
    
</section>
@section scripts
{
    <script src="~/Scripts/jquery-3.3.1.min.js"></script>
    <script src="~/Scripts/jquery-3.3.1.js"></script>
    <script src="/PMS/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <!-- Select2 -->
    <script src="~/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script>
    $('#Approve').on('click', function () {
        $.ajax({
            type: "Get",
            url: GetFormatedUrl('/Invoicings/ApproveInvoice/') + '@Model.Id',
            async: true,
            success: function (data) {
                var data = data.status;
                if (data == true) {
                    window.location.reload();
                    $('#Approve').addClass('hide');
                }
            },
            error: function (data) {
                $('#Piechartdiv').text('Some error occured !', 'error')
            }
        });
    });

    GetTaxesEdit();
    $('.taxes').each(function (i, e) {
        $(this).select2().val($(this).attr('data-taxids').split(',')).trigger("change");
    })


    function GetTaxesEdit() {
        var url = GetFormatedUrl("/Invoicings/GetTaxes")
        $.ajax({
            type: "Get",
            url: url,
            async: false,
            success: function (data) {
                var data = data.data;
                $(".taxes").html('');
                var html = "";
                $.each(data, function (key, value) {
                    html = html + "<option Value='" + value.Value + "'>" + value.Text + "</option>"
                })
                $(".taxes").html(html);

            }
        });
        }


        function GetHtml(selector) {
            var ht = '';
            $.ajax({
                type: "Get",
                url: GetFormatedUrl('/Invoicings/InvoiceHtml/') + '@Model.Id',
                dataType: 'html',
                async: false,
                success: function (response)
                {
                    ht = jQuery(response).find(selector).html();
                }
            });

            $.ajax({
            type: "Post",
                url: GetFormatedUrl('/Invoicings/SendInvoiceByEmail'),
                async: true,
                data: {
                subject: 'The Myriad ' + '@Model.Location.LocationName ' + 'Invoice - ' + '@Model.Code',
                body: ht,
                isBodyHtml: true,
                to: '@Model.Person.Email'
            },
            success: function (data) {
                swal("Email Sent Successfully!", "", "success");
            },
            error: function (data) {
                $('#Piechartdiv').text('Some error occured !', 'error')
            }
        });

        }

        function getElementChildrenAndStyles(selector) {
            var test = $(selector).clone();
            var html = test[0].outerHTML

            selector = selector.split(",").map(function (subselector) {
                return subselector + "," + subselector + " *";
            }).join(",");
            elts = $(selector);

            var rulesUsed = [];
            // main part: walking through all declared style rules
            // and checking, whether it is applied to some element
            Stylesheets = document.styleSheets;
            var sheets = [];
            $(Stylesheets).each(function (i, e) {
                if (e.href != null && !e.href.includes('font')) {
                    sheets.push(e);
                }
            })
            for (var c = 0; c < sheets.length; c++) {
                var url = sheets[c].href;
                    var rules = sheets[c].rules || sheets[c].cssRules;
                    for (var r = 0; r < rules.length; r++) {
                        var selectorText = rules[r].selectorText;
                        var matchedElts = $(selectorText);
                        for (var i = 0; i < elts.length; i++) {
                            if (matchedElts.index(elts[i]) != -1) {
                                rulesUsed.push(rules[r]); break;
                            }
                        }
                    }

            }
            var style = rulesUsed.map(function (cssRule) {
                if (cssRule.style) {
                    var cssText = cssRule.style.cssText.toLowerCase();
                } else {
                    var cssText = cssRule.cssText;
                }
                // some beautifying of css
                return cssText.replace(/(\{|;)\s+/g, "\$1\n  ").replace(/\A\s+}/, "}");
                //                 set indent for css here ^
            }).join("\n");
            var htt = ''
            $(sheets).each(function (i, e) {
               htt = htt + '<link rel="stylesheet" href="' + e.href + '">'

            })
            var css = '<style> table, th, td {border: 1px solid black;} </style>'
            return htt + css + html;
            //return "<style>\n" + style + "\n</style>\n\n" + html;
        }


    </script>

    <style>
        .selection--multiple {
            border: none !important;
            background-color: transparent !important;
        }
    </style>
}
