            //    </div>`
            //                $("#PaymentModal .modal-content").append(html);
            //                $("#PaymentModal").modal();
            //            } else {
            //                Toast.show("Invoice not Found!", "error");
            //            }
            //        }
            //    });

            //});

            //invoiceTable.column(4).search('^Paid$', true, false).draw();

            invoiceTable.column(4).search('^' + defaultStatus + '$', true, false).draw();


            $('#statusFilter').on('change', function () {
                var value = $(this).val();

               {
                    // Search for exact match using regex
                    invoiceTable.column(4).search('^' + value + '$', true, false).draw();
                }
            });

            var referenceId = $("#reference").val();
            if (referenceId != "" && referenceId != undefined) {
                GetPayment(referenceId);
            }
        });

        function openReport(id) {

            window.open('/Reporting/GenerateInvoiceDetailReport?Id=' + id, '_blank');

        }
        function payment(id) {
            $('#close1,#pay')
                .prop("disabled", true)
                .html('<i class="fa fa-2x fa-sync-alt fa-spin  fa-refresh loading "></i>')
                .css('background', '#016891 !important');

            $.ajax({
                url: GetFormatedUrl('/Student/PaymentGateway/PayNow'),
                data: { id: id },
                type: "Get",
                success: function (response) {
                    if (response.success) {
                        window.open("" + response.data + "", "_self");
                    } else {
                        $('#pay')
                            .prop("disabled", false)
                            .html('')
                            .text('Confirm');

                        $('#close1')
                            .prop("disabled", false)
                            .html('')
                            .text('Close')
                        Toast.show(response.data, "error");
                    }
                }
            })

        }
        function GetPayment(id) {

            $.ajax({
                url: GetFormatedUrl('/Student/PaymentGateway/GetUserPayment'),
                data: { referenceId: id },
                type: "Get",
                success: function (response) {
                    if (response.success) {
                        $("#amount").html(response.data.Amount+" OMR");
                       $("#ref").html(response.data.ReferenceNo);
                        $("#code").html(response.data.InvoiceCode);
                        $("#card").html(response.data.Card);
                        $("#date").html(response.data.Date);
                        $("#PaymentConfirmModal").modal();
                    }
                }
            })

        }


        function ConfirmPayment(id, locationId) {
            debugger
            Id = id;
            $.ajax({
                url: GetFormatedUrl('/Student/Invoicings/GetPayableInvoice'),
                type: "Get",
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        var data = response.data;
                        $("#paymentConfirmBody").html('');
                        var resolvedLocationId = parseInt(locationId || data.LocationId || "0");

                        var html = `<p>Invoice Code  <b style="color:#c20e1a">${data.Code}</b></p>
                         <input id="PaymentLink_InvoiceId" value='${data.Id}' hidden/>
                         <input id="PaymentLink_LocationId" value='${resolvedLocationId}' hidden/>
                         <p>Net Amount is  <b style="color:#c20e1a">${data.NetAmount}</b>`;
                        $("#paymentConfirmBody").html(html);
                        $("#ConfirmPaymentLink").modal();
                    } else {
                        Toast.show("Invoice not Found!", "error");
                    }
                }
            });

        }

        function GenratePaymentLink() {
            debugger
            $("#ConfirmPaymentLink").modal('hide');
            var Id = $("#PaymentLink_InvoiceId").val();

            $.ajax({
                type: "Get",
                url: GetFormatedUrl('/Student/PaymentGateway/PayNow'),
                data: { id: Id },
                async: true,
                success: function (response) {
                    if (response.success) {
                        window.open("" + response.data + "", "_self");

                    } else {
                        Toast.show(response.data, "error");
                    }
                },
                error: function (data) {
                }
            });
        }

        function Copy() {
            var copyText = document.getElementById("paymentlink");
            copyText.select();
            copyText.setSelectionRange(0, 99999);

            navigator.clipboard.writeText(copyText.value);
        }

    </script>
}
