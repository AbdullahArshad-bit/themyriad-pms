            //        type: "Get",
            //        data: { Id: invoicingId },
            //        success: function (response) {
            //            if (response.success) {
            //                $("#PaymentModal .modal-content").html("");
            //                var html = `<div class="modal-header">
            //        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            //            <span aria-hidden="true">×</span>
            //        </button>
            //        <h4 class="modal-title">Confirm Payment</h4>
            //    </div>
            //    <div class="modal-body">
            //     <p>Invoice Code  <b style="color:#c20e1a">${response.data.Code}</b></p>
            //     <p>Your Net Amount is  <b style="color:#c20e1a">${response.data.NetAmount}</b>
