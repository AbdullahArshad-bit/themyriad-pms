@model List<PMS.DTO.ViewModels.TicketViewModel>
@using PMS.Common.Classes

@{
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Complaint";
    ViewBag.HeaderDescription = "All Complaints";
    ViewBag.Title = "All Complaint | PMS";
    //var Tickets = ViewBag.Tickets as List<PMS.DTO.ViewModels.TicketViewModel>;

}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    <a href="@Url.Action("Add", "Ticket",new {area="Student"})" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Complaint</a>
                </div>
            </div>

            <div style="overflow: auto; width:100%">

                <table id="ticket" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Subject</th>
                            <th>Description</th>
                            <th>Group</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var ticket in Model)
                            {
                                <tr>
                                    <td>@ticket.Code</td>
                                    <td>@ticket.Name</td>
                                    <td>@(ticket.Description != null ? ticket.Description : "------")</td>
                                    <td>@ticket.GroupName</td>
                                    <td>@ticket.Status</td>
                                    @*<td>
                                    <div class="form-group">
                                        @Html.DropDownList("StatusId", null, "--- Select Status ---", htmlAttributes: new { @class = "form-control select ", @required = "required" })
                                    </div>
                                </td>*@

                                    <td>@(ticket.DueDate != null ? Convert.ToDateTime(ticket.DueDate).ToString("dd-MMM-yyyy") : "-")</td>
                                    <td>
                                        @if (ticket.StatusId != (int)Enumeration.TicketStatus.Closed)
                                        {
                                        <a title="Comments" href="@Url.Action("Comments", "Ticket", new { Id = ticket.Id })"><i class="fa fa-comments"></i></a>

                                            
                                        if (ticket.StatusId == (int)Enumeration.TicketStatus.Open && ticket.CreatedBy == PMS.Common.Globals.User.ID)
                                        {
                                        <a title="Edit" href="@Url.Action("Add", "Ticket", new { id = ticket.Id })"><i class="fa fa-pencil-square-o"></i></a>
                                        }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

            </div>


        </div>
    </div>
</div>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="//cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>

    <script>
        $(function () {
            $('#ticket').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        })
    </script>
}