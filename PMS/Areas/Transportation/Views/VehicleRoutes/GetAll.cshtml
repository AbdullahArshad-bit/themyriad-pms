@using PMS.Common.Classes
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Routes";
    ViewBag.HeaderDescription = "All Routes";
    var routes = ViewBag.routes as List<PMS.DTO.ViewModels.TransportationViewModels.AddRouteVM>;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>

    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_routes))
                    {
                        <a href="@Url.Action("Add", "VehicleRoutes")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add Routes</a>
                    }
                </div>
            </div>

            <div style="overflow: auto; width:100%">
                <table id="Schedules" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Location</th>
                            <th>Route Name</th>
                            <th>Total Stops</th>
                            <th>Departure Stop</th>
                            <th>Arrival Stop</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in routes)
                        {
                            <tr>
                                <td>@item.LocationName</td>
                                <td>@item.Routename</td>
                                <td>@item.StopCount</td>
                                <td>@item.stopName</td>
                                <td>@item.ArrivalStop</td>

                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.edit_routes))
                                    {
                                        <a title="Edit" href="@Url.Action("Add", "VehicleRoutes", new { RouteID = item.RouteID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_routes))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("Delete", "VehicleRoutes", new { RouteID = item.RouteID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#Schedules').DataTable({});
        })
    </script>
}


