@using PMS.Common.Classes
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Stop";
    ViewBag.HeaderDescription = "All Stops";
    ViewBag.Title = "All Stops | PMS";
    var stops = ViewBag.stops as List<PMS.DTO.ViewModels.AddBusStopViewModel>;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_stops))
                    {
                        <a href="@Url.Action("Add", "VehicleStop")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Stop</a>
                    }
                </div>
            </div>



            <div style="overflow: auto; width:100%">

                <table id="Schedules" class="table table-bordered table-striped">

                    <thead>

                        <tr>

                            <th>Location</th>
                            <th>Stop Name</th>
                            <th>Longitude</th>
                            <th>Latitude</th>
                            <th>Stop Full Address</th>
                            <th>Action</th>

                        </tr>




                    </thead>
                    <tbody>

                        @foreach (var item in stops)
                        {
                            <tr>

                                <td>@item.LocationName</td>
                                <td>@item.Name</td>
                                <td>@item.Longitude</td>
                                <td>@item.Latitude</td>
                                <td>@item.FullName</td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @*<a title="Details" href="@Url.Action("RootDetails", "Transportation", new { ScheduleID = Schedule.ScheduleID })"><i class="fa fa-newspaper-o"></i></a>*@
                                    @if (User.IsInRole(AppUserRoles.edit_stops))
                                    {
                                        <a title="Edit" href="@Url.Action("Add", "VehicleStop", new { StopID = item.Id })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_stops))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("Delete", "VehicleStop", new { StopID = item.Id })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }
                                </td>

                            </tr>
                        }



                    </tbody>

                </table>

            </div>

        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#Schedules').DataTable({});
        })
    </script>
    <script type="text/javascript">
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
}


