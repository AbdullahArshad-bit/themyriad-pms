@model PMS.DTO.ViewModels.AddBusStopViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Vehicle Stop";
    ViewBag.HeaderDescription = "Add Stop";
    ViewBag.Title = "Add Vehicle Stop | PMS";
}



<div class="box box-danger">
    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("GetAll", "VehicleStop")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Stops</a>
        </div>
    </div>

    <!-- form start -->
    @using (Html.BeginForm("Add", "VehicleStop", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_BusStop_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Id)

        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            @*<div class="row">
                    <div class="col-md-12">
                        <div class="form-group">

                            <label>Active</label>

                            <div>
                                <label class="switch">
                                    <input type="checkbox" name="IsActive" id="IsActive"
                                           value="@Model.IsActive" @(Model.IsActive ? "checked" : "")>
                                    <span class="slider round"></span>
                                </label>
                            </div>

                            @Html.ValidationMessageFor(x => x.IsActive)
                        </div>
                    </div>
                </div>*@
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(x => x.LocationId, "Location")
                        @Html.DropDownList("LocationId", null, "--- Select Location ---", htmlAttributes: new { @class = "form-control", @required = "required" })
                        @Html.ValidationMessageFor(x => x.LocationId)

                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">

                    <div class="form-group">
                        <label for="Title">Stop Name</label>
                        @Html.TextBoxFor(x => x.Name, new { @class = "form-control", placeholder = "Enter Stop Name" })
                        @Html.ValidationMessageFor(x => x.Name)
                    </div>
                </div>
                <div class="col-md-6">

                    <div class="form-group">
                        <label for="Title">Latitude</label>

                        @Html.TextBoxFor(x => x.Latitude, new { @class = "form-control", placeholder = "Enter Latitude" })
                        @Html.ValidationMessageFor(x => x.Latitude)
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="Title">Longitude</label>

                        @Html.TextBoxFor(x => x.Longitude, new { @class = "form-control", placeholder = "Enter Longitude" })
                        @Html.ValidationMessageFor(x => x.Longitude)
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="Title">Stop Full Address</label>

                        @Html.TextBoxFor(x => x.FullName, new { @class = "form-control", placeholder = "Enter Stop FullName" })
                        @Html.ValidationMessageFor(x => x.FullName)
                    </div>
                </div>
            </div>



        </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <script>

    </script>
}


