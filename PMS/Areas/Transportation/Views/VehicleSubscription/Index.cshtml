@using PMS.Common.Classes
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Subscriptions";
    ViewBag.HeaderDescription = "All Subscriptions";
    ViewBag.Title = "All Vehicle Subscriptions | The Myriad Admin";

    var subscription = ViewBag.Subscription as List<PMS.DTO.ViewModels.TransportationViewModels.VehicleSubscriptionVM>;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>

    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_subscription))
                    {
                        <a href="@Url.Action("Add", "VehicleSubscription")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add Subscription</a>
                    }
                </div>
            </div>

            <div style="overflow: auto; width:100%">
                <table id="Subscription" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Location</th>
                            <th>Student Name</th>
                            <th>Frequency</th>
                            <th>Subscription Name</th>
                            <th>Subscription Price</th>
                            <th>Status</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in subscription)
                        {
                        <tr>
                            <td>@item.LocationName</td>
                            <td>@item.StudentName</td>
                            <td>@item.FrequencyName</td>
                            <td>@item.PriceName</td>
                            <td>@item.SubscriptionPrice</td>
                            @{
                                if (item.SubscriptionStatus == (int)Enumeration.SubscriptionsStatusLookup.Pending)
                                {
                                    <td><span class='label label-warning'>Pending</span></td>
                                }
                                else if (item.SubscriptionStatus == (int)Enumeration.SubscriptionsStatusLookup.Active)
                                {
                                    <td><span class='label label-success'>Active</span></td>
                                }
                                else if (item.SubscriptionStatus == (int)Enumeration.SubscriptionsStatusLookup.Suspended)
                                {
                                    <td><span class='label label-danger'>Suspended</span></td>
                                }
                                else if (item.SubscriptionStatus == (int)Enumeration.SubscriptionsStatusLookup.Ended)
                                {
                                    <td><span class='label label-danger'>Ended</span></td>
                                }

                            }
                        <td class="menu-icons" style="text-align:inherit">
                            @if (item.SubscriptionStatus != (int)Enumeration.SubscriptionsStatusLookup.Ended)
                            {
                                if (User.IsInRole(AppUserRoles.edit_subscription))
                                {
                                    <a title="Edit" href="@Url.Action("Add", "VehicleSubscription", new { SubscriptionID = item.SubscriptionId })"><i class="fa fa-edit"></i></a>
                                }
                                if (item.SubscriptionStatus != (int)Enumeration.SubscriptionsStatusLookup.Active)
                                {
                                    if (User.IsInRole(AppUserRoles.approve_subscription))
                                    {
                                        <a title="Approved" href="#" data-href="@Url.Action("Approve", "VehicleSubscription", new { subscriptionid = item.SubscriptionId })" data-toggle="modal" data-target="#confirm-approve"><i class="fa fa-check"></i></a>
                                    }
                                }
                                if (item.SubscriptionStatus != (int)Enumeration.SubscriptionsStatusLookup.Suspended)
                                {
                                    if (User.IsInRole(AppUserRoles.suspend_subscription))
                                    {
                                        <a title="Suspend" href="#" data-href="@Url.Action("Suspend", "VehicleSubscription", new { subscriptionid = item.SubscriptionId })" data-toggle="modal" data-target="#confirm-suspend"><i class="fa fa-ban"></i></a>
                                    }
                                }
                                    if (User.IsInRole(AppUserRoles.end_subscription))
                                    {
                                        <a title="End" href="#" data-href="@Url.Action("End", "VehicleSubscription", new { subscriptionid = item.SubscriptionId })" data-toggle="modal" data-target="#confirm-end"><i class="fa fa-minus"></i></a>
                                    }
                                    if (User.IsInRole(AppUserRoles.delete_subscription))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("Delete", "VehicleSubscription", new { SubscriptionID = item.SubscriptionId })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }
                                }
                        </td>

                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#Subscription').DataTable({});
        })
    </script>
}


