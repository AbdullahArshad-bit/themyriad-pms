@model PMS.DTO.ViewModels.VehicleViewModel.VehicleViewModel
@using PMS.Common.Classes
@using PMS.DTO.ViewModels.VehicleViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "Vehicle";
    ViewBag.HeaderDescription = "All Vehicles";
    ViewBag.Title = "All Vehicles | The Myriad Admin";
}
@{
    var Vehicles = (List<VehicleViewModel>)ViewBag.Vehicles;
    @Html.HiddenFor(x => x.BusId)


}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>

                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    <a href="@Url.Action("Add", "Vehicle")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Vehicle</a>
                </div>
            </div>
            @if (ViewBag.Vehicles != null)
            {
                <div style="overflow: auto; width:100%">

                    <table id="vehicle" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Location</th>
                                <th>Name</th>
                                <th>Registration Number</th>
                                <th>Total Seats</th>
                                <th>Active/InActive</th>
                                <th>Action</th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vehicle in Vehicles)
                            {
                            <tr>
                                <td>@(vehicle.LocationName)</td>

                                <td>@vehicle.BusName</td>
                                <td>@vehicle.RegistrationNumber</td>
                                <td>@vehicle.TotalSeats</td>
                                <td>
                                    @if (vehicle.IsActive == true)
                                    {
                                        <span class="label label-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="label label-danger">No</span>
                                    }

                                </td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.edit_vehicles))
                                    {
                                        <a title="Edit" href="@Url.Action("Add", "Vehicle", new { id = vehicle.BusId })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_vehicles))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("DeleteVehicle", "Vehicle", new { id = vehicle.BusId })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.view_seats))
                                    {
                                        <a title="View Seats" href="@Url.Action("Seats", "Vehicle", new { busId = vehicle.BusId })"><i class="fa fa-bus"></i></a>
                                    }
                                </td>
                            </tr>
                            }
                        </tbody>

                    </table>

                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#vehicle').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
                columnDefs: [
                    { type: 'date-euro', targets: 1 },
                    { type: 'date-euro', targets: 2 },
                ]
            });
        })
    </script>
}
