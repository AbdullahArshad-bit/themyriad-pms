@model List<PMS.DTO.ViewModels.VehicleViewModel.VehicleSeatsViewModel>
@using PMS.Common.Classes
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Header = "View Seats";
    ViewBag.HeaderDescription = "View Seats";
    ViewBag.Title = "View Seats | PMS";
    var busId = ViewBag.busId;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}



<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header with-border">
            <div class="input-group-btn">
                <a href="@Url.Action("Index", "Vehicle")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Vehicles</a>
            </div>
        </div>
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>

                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="margin-bottom: 5px;  text-align: right">
                <div class="input-group-btn">
                    <a onclick="OpenAddSeatModal()" href="#" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Seat</a>
                </div>
            </div>
            <div class="col-md-12">
                <hr />
            </div>
            <div style="overflow: auto; width:100%">

                <div class="col-md-12">
                    <table id="seatsTable" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Vehicle Name</th>
                                <th>Seats</th>
                                <th>Active/InActive</th>
                                <th>Actions</th>

                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null)
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @item.VechicleName
                                        </td>
                                        <td>
                                            @item.SeatNumber
                                        </td>
                                        <td>
                                            @if (item.IsActive == true)
                                            {
                                                <span class="label label-success">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="label label-danger">No</span>
                                            }
                                        </td>
                                        <td class="menu-icons" style="text-align:inherit">
                                            @if (User.IsInRole(AppUserRoles.edit_seats))
                                            {
                                                <a title="Update Seat" onclick="OpenEditSeatModal(@item.Id)" href="#"><i class="fa fa-edit"></i></a>
                                            }
                                            @if (User.IsInRole(AppUserRoles.delete_seats))
                                            {
                                            <a title="Delete" href="#" data-href="@Url.Action("DeleteSeat", "Vehicle", new { id = item.Id, busId = item.VehicleId })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    <!-- Add seat modal -->
    <div class="modal fade" id="SeatModal">
        <form method="post" id="SeatForm" action="@Url.Action("AddVehicleSeat", "Vehicle")">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                        <h4 class="modal-title" id="myModalLabel" style="font-weight: bold">Add Seat</h4>
                    </div>

                    <div class="modal-body">
                        <input name="VehicleId" id="vehicleId" value="@busId" hidden />
                        @*@Html.Hidden("VehicleId", new { id = "vehicleId" });*@
                        @Html.Hidden("Id", new { id = "Id" })
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label>Active</label>
                                    <div>
                                        <label class="switch">
                                            <input type="checkbox" checked name="IsActive" id="IsActive"
                                                   value="">
                                            <span class="slider round"></span>
                                        </label>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="Title">Seat Number</label>
                                        <input id="SeatNumber" class="form-control" required name="SeatNumber" placeholder="Enter Seat Number">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                        <button type="submit" onclick="Submit()" class="btn btn-themyriad">Save</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

</div>

@section scripts
{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <script>
        $(document).ready(function () {
            $('#seatsTable').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        });
        function OpenAddSeatModal() {
            $('#IsActive').val('');
            $('#SeatNumber').val('');
            $("#SeatModal").modal();
        }

        function OpenEditSeatModal(Id) {
            $.ajax({
                url: "/Vehicle/GetSeatDetail?busId=" + Id,
                method: "Get",
                success: function (data) {
                    if (data.success) {
                        var seat = data.data;
                        $('#IsActive').prop('checked', seat.IsActive);
                        $('#SeatNumber').val(seat.SeatNumber);
                        $("#Id").val(seat.Id);
                        $("#SeatModal").modal();
                    }
                }
            });
        }

        function Submit() {
            var seatNumber = $('#SeatNumber').val();
            if (seatNumber == null || seatNumber == '' || seatNumber == undefined) {
                showMessage('Please enter seat number');
                return false;
            }
            return true;
        }




    </script>
}