@using PMS.Common.Classes

@{
    ViewBag.Header = "Contracts List";
    ViewBag.HeaderDescription = "All Contracts";
    ViewBag.Title = "All Contracts | PMS";

    var contracts = ViewBag.Contracts as List<PMS.DTO.ViewModels.ContractViewModels.ContractsListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }

            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.Add_contracts))
                    {
                        <a href="@Url.Action("AddContracts", "ContractsManage")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Contract</a>
                    }
                </div>
            </div>

            <div style="overflow: auto; width:100%">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            @if (User.IsInRole(AppUserRoles.Add_contracts))
                            {
                                <th></th>
                            }
                            <th>Location</th>
                            <th>Number</th>
                            <th>Name</th>
                            <th>Version</th>
                            <th>Ref #</th>
                            <th>Type</th>
                            <th>Active</th>
                            <th>Published</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in contracts)
                        {
                            <tr>
                                <td>@contract.LocationName</td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.Add_contracts))
                                    {
                                        <a title="Add new version of this contract" href="@Url.Action("AddContracts", "ContractsManage", new { id = contract.ContractID, nv = true })"><i class="fa fa-plus-circle"></i> Add Version</a>
                                    }
                                </td>
                                <td>@contract.ContractNumber</td>
                                <td>@contract.ContractName</td>
                                <td>@contract.ContractVersion</td>
                                <td>@contract.ContractReferenceNumber</td>
                                <td>@contract.ContractType</td>
                                <td>@(contract.IsActive ? Html.Raw("<span class='label label-success'>Yes</span>") : Html.Raw("<span class='label label-danger'>No</span>"))</td>
                                <td>@(contract.IsPublish ? Html.Raw("<span class='label label-success'>Yes</span>") : Html.Raw("<span class='label label-danger'>No</span>"))</td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (!contract.IsPublish)
                                    {
                                        if (User.IsInRole(AppUserRoles.Add_contracts))
                                        {
                                            <a title="Edit Contract" href="@Url.Action("AddContracts", "ContractsManage", new { id = contract.ContractID })"><i class="fa fa-edit"></i></a>
                                        }
                                    }
                                    <a title="View documnets associated with this contract" href="@(!string.IsNullOrEmpty(contract.ContentValue) ? contract.ContentValue : "javascript:Toast.show('No document associated with this contract.', 'error', 3500);")" @(!string.IsNullOrEmpty(contract.ContentValue) ? "target=_blank" : "")><i class="fa fa-paperclip"></i></a>
                                    <a title="View a list of all versions associated with this contract" href="javascript:GetVersions('@contract.ContractNumber')"><i class="fa fa-copy"></i></a>
                                    @using (Html.BeginForm("ContractDownloadPdf", "ContractsManage", new { id = contract.ContractID, type = "contract" }, FormMethod.Post, new { id = "revertCancelBookingForm " + contract.ContractID, style = "display:inline-block" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <a title="Download Contract Editor Template" href="@(contract.ContentType == "file"? "#file" : "javascript:document.getElementById('revertCancelBookingForm "+ @contract.ContractID +"').submit()")"><i class="fa fa-download"></i></a>


                                    }

                                    @if (!contract.IsPublish)
                                    {
                                        if (User.IsInRole(AppUserRoles.Delete_contracts))
                                        {
                                            <a title="Delete" href="#" data-href="@Url.Action("DeleteContract", "ContractsManage", new { id = contract.ContractID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-trash"></i></a>
                                        }
                                    }
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>

            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modal_div" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            //$('.data-table').DataTable({ "targets": [0], "searchable": false, "orderable": false, "visible": true });
            $('.data-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
                order: [[1, 'asc']],
                columnDefs: [
                    {
                        "targets": [0, -1], //first column / numbering column
                        "orderable": false, //set not orderable
                    },
                ]
            });
        })


        function GetVersions(n) {
            $.ajax({
                url: GetFormatedUrl("/ContractsManage/GetContractVersions"),
                method: "Get",
                dataType: "html",
                contentType: 'application/json; charset=utf-8',
                data: { ContractNumber: n },
                beforeSend: function () {
                    $('#loader').show();
                },
                complete: function () {
                    $('#loader').fadeOut('slow');
                },
                success: function (data) {
                    $("#modal_div").html(data);
                    $('#modal_div').modal('show');

                    //$('#table').DataTable({});
                },
                error: function (xhr) {
                    showMessage(xhr.status + " - " + xhr.statusText);

                }
            });
        }

    </script>
}
