@model PMS.DTO.ViewModels.ContractViewModels.ContractTypesVM

@using PMS.Common.Classes

@{
    ViewBag.Header = "Contract Types";
    ViewBag.HeaderDescription = "Add/Edit Contract Type";
    ViewBag.Title = "Add/Edit Contract Type | PMS";
}


@section styles{
    <!-- bootstrap datepicker -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <!-- Bootstrap time Picker -->
    <link rel="stylesheet" href="~/Assets/plugins/timepicker/bootstrap-timepicker.css">
}


<div class="box box-danger">

    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("ContractTypes", "ContractsManage")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Contract Types</a>
        </div>
    </div>


    <!-- form start -->
    @using (Html.BeginForm("AddContractType", "ContractsManage", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_contract_type_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ContractTypeID)

        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-md-6">

                <div class="form-group">
                    <label>@Html.LabelFor(x => x.ContractTypeName)</label>

                    @Html.TextBoxFor(x => x.ContractTypeName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.ContractTypeName)

                </div>

                <div class="form-group">
                    <label>@Html.LabelFor(x => x.ContractTypeDescription)</label>
                    @Html.TextAreaFor(x => x.ContractTypeDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })
                    @Html.ValidationMessageFor(x => x.ContractTypeDescription)
                </div>


            </div>
        </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- bootstrap time picker -->
    <script src="~/Assets/plugins/timepicker/bootstrap-timepicker.min.js"></script>

    <script>
        $(document).ready(function () {

        });

         $(function () {
            //Date picker
            $('.term_date').datepicker({
                autoclose: true,
                format: "dd/M/yyyy"
            });

            //$('#show_time').timepicker({
            //    showInputs: false
            //})
        })

    </script>
}

