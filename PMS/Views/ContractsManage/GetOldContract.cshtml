@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.PaymentDetailReportVM>

@{
    ViewBag.Header = "Old Contracts";
    ViewBag.HeaderDescription = "Old Contracts";
    ViewBag.Title = "Old Contracts | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">


}


<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="">

                    <div class="col-md-3">
                        <label>Student</label>
                        @Html.DropDownList("StudentId", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>




                    <div class="col-md-1">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetOldContract();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                    </div>

                </div>
                <br />

            </div>
            <div class="col-md-12">
                <hr />
            </div>
            <div style="overflow: auto; width:100%">
                <div class="col-md-12">

                    <table id="contract-table" class="table table-bordered table-striped display now" style="width:100%">

                        <thead>

                            <tr>
                                <th>Contract Name</th>
                                <th>Contract</th>

                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.contract != null)
                            {
                                foreach (var item in ViewBag.contract)
                                {
                                    <tr>
                                        <td>@item</td>
                                        <td>
                                            <a href="http://@ViewBag.auth//Upload/Files/StudentContracts/@item" target="_blank"><i class="fa fa-download"></i></a>
                                        </td>


                                    </tr>
                                }
                            }

                        </tbody>


                    </table>

                </div>

            </div>
        </div>
    </div>
</div>

@section scripts{


    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>


    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>

        $(document).ready(function () {
            $('#contract-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                buttons: [
                    'excelHtml5'

                ],
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
               
            });
            $('.dataTables_length').addClass('bs-select');

           
        });


    </script>


    <script type="text/javascript">
        function GetOldContract() {
           
            var personId = $('#StudentId').val();
           
            window.location.href = GetFormatedUrl("/ContractsManage/GetOldContract?personId=" + personId);

        };
       


    </script>

}