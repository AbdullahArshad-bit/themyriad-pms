@model PMS.DTO.ViewModels.PaymentViewModels.AddPaymentTypeVM

@using PMS.Common.Classes

@{
    ViewBag.Header = "Payment Method";
    ViewBag.HeaderDescription = "Add/Edit Payment Method";
    ViewBag.Title = "Add/Edit Payment | PMS";
}

@section styles{
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <!-- Select2 -->
    <link rel="stylesheet" href="~/Assets/bower_components/select2/dist/css/select2.min.css">
}



<div class="box box-danger">

    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("PaymentList", "Paymenttypes")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Payment</a>
        </div>
    </div>

    <!-- form start -->
    @using (Html.BeginForm("AddPayment", "Paymenttypes", FormMethod.Post, new { enctype = "multipart/form-data", id = "inspection_fields_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.PaymentId)



        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="row col-md-12">

                <div class="col-md-12">
                    <div class="form-group">
                        <label>Active</label>
                        <div>
                            <label class="switch">
                                <input type="checkbox" name="IsActive" id="IsActive" value="@Model.IsActive" @(Model.IsActive ? "checked" : "")>
                                <span class="slider round"></span>
                            </label>
                        </div>
                        @Html.ValidationMessageFor(x => x.IsActive)
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        @Html.LabelFor(x => x.LocationId, "Location")
                        @Html.DropDownList("LocationId", null, "Select...", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                        @Html.ValidationMessageFor(x => x.LocationId)

                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        @Html.LabelFor(x => x.Code, "Method Code")
                        @Html.TextBoxFor(x => x.Code, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter Method Code" })
                    </div>
                    @Html.ValidationMessageFor(x => x.Code)
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        @Html.LabelFor(x => x.PaymentName)
                        @Html.TextBoxFor(x => x.PaymentName, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter name" })
                    </div>
                    @Html.ValidationMessageFor(x => x.PaymentName)
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        @Html.LabelFor(x => x.AccountId, "Chart of Account")
                        @Html.DropDownList("AccountId", null, "Select Account...", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                        @Html.ValidationMessageFor(x => x.AccountId)
                    </div>
                </div>
            </div>
        </div>


        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad btnSave" value="Save">
        </div>
    }
</div>

@section scripts
{

    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- Select2 -->
    <script src="~/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>

    <script>
        $(function () {
            //Date picker
            $('.datepicker').datepicker({
                autoclose: true,
                format: "dd/M/yyyy",
                startDate: new Date()
            })

            $('.select2').select2()
        })

        $(document).ready(function () {

        });

        function setInitialLocation() {

            var initialLocation = localStorage.getItem("selectedLocation");

            if (initialLocation) {

                $('#LocationId').val(initialLocation);
                $("#LocationId").prop('disabled', true);


            }
        }
        $('form').submit(function () {


            var locationId = $('#LocationId').val();


            $('<input>').attr({
                type: 'hidden',
                name: 'LocationId',
                value: locationId
            }).appendTo('form');

            return true;
        });

        setInitialLocation();
    </script>


}
