@model PMS.DTO.ViewModels.UserManageViewModels.AddRoleVM

@{
    ViewBag.Header = "Roles";
    ViewBag.HeaderDescription = "Add New Role";
    ViewBag.Title = "Add Roles | PMS";
}



<div class="box box-danger">
    @if (User.IsInRole(PMS.Common.Classes.AppUserRoles.view_roles))
    {
        <div class="box-header with-border">
            <div class="input-group-btn">
                <a href="@Url.Action("Roles", "UserManage")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Roles</a>
            </div>
        </div>
    }

    <!-- form start -->
    @using (Html.BeginForm("AddRole", "UserManage", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_role_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.RoleID)

        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="row col-md-12">



                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(x => x.LocationId, "Location", new { @class = "control-label required" })

                        @Html.DropDownList("LocationId", null, "-- Location --", htmlAttributes: new { @class = "form-control LocationId", @required = "required" })
                        @Html.ValidationMessageFor(x => x.LocationId)
                    </div>

                </div>

            </div>
            <div class="row col-md-12">

                <div class="col-md-6">

                    <div class="form-group">
                        @Html.LabelFor(x => x.RoleName)

                        @Html.TextBoxFor(x => x.RoleName, new { @class = "form-control", placeholder = "Enter role name" })

                        @Html.ValidationMessageFor(x => x.RoleName)

                    </div>

                    <div class="form-group">
                        @Html.LabelFor(x => x.RoleDescription)
                        @Html.TextAreaFor(x => x.RoleDescription, new { @class = "form-control", placeholder = "Enter role description", style = "min-height:125px" })
                        @Html.ValidationMessageFor(x => x.RoleDescription)
                    </div>

                </div>
            </div>
        </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <script>

        function setInitialLocation() {
            var initialLocation = localStorage.getItem("selectedLocation");

            if (initialLocation) {
                $('#LocationId').val(initialLocation);
                $("#LocationId").prop('disabled', true);


                $('<input>').attr({
                    type: 'hidden',
                    name: 'LocationId',
                    value: initialLocation
                }).appendTo('#add_role_form');

            }
        }
        $(document).ready(function () {
            setInitialLocation();
        });


        $(document).ready(function () {
            setInitialLocation();


        });
    </script>
}
