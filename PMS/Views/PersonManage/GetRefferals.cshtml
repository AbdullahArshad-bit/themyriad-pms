@using PMS.Common.Classes
@{
    ViewBag.Header = "Referral Program";
    ViewBag.HeaderDescription = "Referred To";
    ViewBag.Title = "Referral Program | PMS";
    var referrals = ViewBag.referrals as List<PMS.DTO.ViewModels.PersonManageViewModels.AddPersonVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">
           
            



            <div style="overflow: auto; width:100%">

                <table id="Schedules" class="table table-bordered table-striped">

                    <thead>

                        <tr>

                            <th>Myriad Id</th>
                            <th>Title</th>
                            <th>FullName</th>
                            <th>Gender</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>

                        </tr>




                    </thead>
                    <tbody>
                        @if (referrals != null)
                        {
                            foreach (var item in referrals)
                            {
                            <tr>

                                <td>@item.Code</td>
                                <td>@item.Title</td>
                                <td>@item.FullName</td>
                                <td>@item.Gender</td>
                                <td>@item.Email</td>
                                <td>@item.Phone</td>
                                <td>
                                    @if (item.Checkin != null && item.Type==3 && item.BookingId!=null)
                                    {
                                        <span class="text-success label label-success">Rewarded</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger label label-primary">Pending</span>
                                    }
                                </td>
                               

                            </tr>
                            }

                        }

                    </tbody>

                </table>

            </div>

        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#Schedules').DataTable({});
        })
    </script>
    <script type="text/javascript">
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
}

