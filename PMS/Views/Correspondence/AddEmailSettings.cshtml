@model PMS.DTO.ViewModels.CorrespondenceViewModels.AddEmailSettingsVM

@using PMS.Common.Classes

@{
    ViewBag.Header = "Correspondence";
    ViewBag.HeaderDescription = "Add/Edit Email Settings";
    ViewBag.Title = "Add/Edit Email Settings | Correspondence | PMS";
}


@section styles{
    <!-- bootstrap datepicker -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <!-- Bootstrap time Picker -->
    <link rel="stylesheet" href="~/Assets/plugins/timepicker/bootstrap-timepicker.css">
}


<div class="box box-danger">

    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("EmailSettings", "Correspondence" )" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Email Settings</a>
        </div>
    </div>
    <!-- form start -->
    @using (Html.BeginForm("AddEmailSettings", "Correspondence", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_email_settings_form" }))
    {
        @Html.AntiForgeryToken()
        if (Model.EmailSettingsID != null)
        {
            @Html.HiddenFor(x => x.EmailSettingsID)
        }

        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-md-12">
                <div class=" form-group ">
                    <label style="font-weight:normal">
                        @Html.CheckBoxFor(x => x.EnableEmail) Email Enabled
                    </label>

                    @Html.ValidationMessageFor(x => x.EnableEmail)

                </div>
            </div>

            <div class="col-md-12">
                <div class=" form-group ">
                    <label style="font-weight:normal">
                        @Html.CheckBoxFor(x => x.UseSSL) Email Server Uses SSL
                    </label>

                    @Html.ValidationMessageFor(x => x.UseSSL)

                </div>
            </div>

            <div class="row col-md-12">



                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(x => x.LocationId, "Location", new { @class = "control-label required" })

                        @Html.DropDownList("LocationId", null, "-- Location --", htmlAttributes: new { @class = "form-control LocationId", @required = "required" })
                        @Html.ValidationMessageFor(x => x.LocationId)
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(x => x.EmailServer)

                        @Html.TextBoxFor(x => x.EmailServer, new { @class = "form-control", placeholder = "Enter server" })

                        @Html.ValidationMessageFor(x => x.EmailServer)

                    </div>
                </div>

            </div>

            <div class="row col-md-12">

                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(x => x.EmailServerPort)

                        @Html.TextBoxFor(x => x.EmailServerPort, new { @class = "form-control", placeholder = "Enter server port" })

                        @Html.ValidationMessageFor(x => x.EmailServerPort)

                    </div>
                </div>

            </div>

        </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- bootstrap time picker -->
    <script src="~/Assets/plugins/timepicker/bootstrap-timepicker.min.js"></script>

    <script src="https://cdn.ckeditor.com/4.15.0/full/ckeditor.js"></script>

    <script>CKEDITOR.replace('MessageBody', {
        uiColor: '#CCEAEE',
        removePlugins: 'elementspath'
    });

    $(function () {
        //Date picker
        $('.term_date').datepicker({
            autoclose: true,
            format: "dd/M/yyyy"
        });

        //$('#show_time').timepicker({
        //    showInputs: false
        //})
    })


        function setInitialLocation() {
            var initialLocation = localStorage.getItem("selectedLocation");

            if (initialLocation) {
                $('#LocationId').val(initialLocation);
                $("#LocationId").prop('disabled', true);


                $('<input>').attr({
                    type: 'hidden',
                    name: 'LocationId',
                    value: initialLocation
                }).appendTo('#add_email_settings_form');

            }
        }
        $(document).ready(function () {
            setInitialLocation();
        });


    $(document).ready(function () {
        setInitialLocation();


    });
    </script>
}