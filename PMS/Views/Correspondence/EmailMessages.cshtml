@using PMS.Common.Classes

@{
    ViewBag.Header = "Email Messages List";
    ViewBag.HeaderDescription = "All Email Messages";
    ViewBag.Title = "All Email Messages | PMS";

    var messages = ViewBag.Messages as List<PMS.DTO.ViewModels.CorrespondenceViewModels.EmailMessagesListVM>;
}

@section styles{  
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }

            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">

                <div class="btn-group">
                    @if (User.IsInRole(AppUserRoles.Add_EmailMessages))
                    {
                        <a href="@Url.Action("AddEmailMessages", "Correspondence")" class="btn btn-themyriad">
                            <i class="fa fa-plus" style="padding-right: 5px;"></i>
                            Add Email Message
                        </a>
                    }
                    @if (User.IsInRole(AppUserRoles.Export_EmailMessages))
                    {
                        <a href="@Url.Action("ExportEmailMessages", "Correspondence")" class="btn btn-themyriad">
                            <i class="fa  fa-file-excel-o" style="padding-right: 5px;"></i>
                            Export To Exel
                        </a>
                    }
                </div>

            </div>

            <div style="overflow: auto; width:100%">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Subject</th>
                            <th>Sender</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var message in messages)
                        {
                            <tr>
                                <td>@message.LocationName</td>
                                <td>@message.EmailMessageName</td>
                                <td>@message.EmailMessageDescription</td>
                                <td>@message.EmailMessageSubject</td>
                                <td>@message.EmailMessageSender</td>
                                <td>@(message.IsActive ? Html.Raw("<span class='label label-success'>Active</span>") : Html.Raw("<span class='label label-danger'>Not Active</span>"))</td>

                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.Add_EmailMessages))
                                    {
                                        <a title="Edit" href="@Url.Action("AddEmailMessages", "Correspondence", new { id = message.EmailMessageID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.Delete_EmailMessages))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("DeleteEmailMessage", "Correspondence", new { id = message.EmailMessageID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>

            </div>

        </div>
    </div>
</div>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        })


    </script>
}
