@using PMS.Common.Classes

@{
    ViewBag.Header = "Email Senders List";
    ViewBag.HeaderDescription = "All Email Senders";
    ViewBag.Title = "All Email Senders | PMS";

    var senders = ViewBag.Senders as List<PMS.DTO.ViewModels.CorrespondenceViewModels.EmailSendersListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }

            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">

                <div class="btn-group">
                    @if (User.IsInRole(AppUserRoles.Add_EmailSenders))
                    {
                        <a href="@Url.Action("AddEmailSenders", "Correspondence")" class="btn btn-themyriad">
                            <i class="fa fa-plus" style="padding-right: 5px;"></i>
                            Add Email Sender
                        </a>
                    }
                    @if (User.IsInRole(AppUserRoles.Export_EmailSenders))
                    {
                        <a href="@Url.Action("ExportEmailSenders", "Correspondence")" class="btn btn-success btn-bordered waves-effect w-md button-effect">
                            <i class="fa  fa-file-excel-o" style="padding-right: 5px;"></i>
                            Export To Exel
                        </a>
                    }
                </div>

            </div>

            <div style="overflow: auto; width:100%">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>From Family Name</th>
                            <th>From</th>
                            <th>Email Routing</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sender in senders)
                        {
                            <tr>
                                <td>@sender.EmailSenderName</td>
                                <td>@sender.Description</td>
                                <td>@sender.FromName</td>
                                <td>@sender.FromAddress</td>
                                <td>
                                    <p>cc : @sender.CC</p>
                                    <p>bcc : @sender.BCC</p>
                                </td>
                                <td>@(sender.IsActive ? Html.Raw("<span class='label label-success'>Active</span>") : Html.Raw("<span class='label label-danger'>Not Active</span>"))</td>

                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.Add_EmailSenders))
                                    {
                                        <a title="Edit" href="@Url.Action("AddEmailSenders", "Correspondence", new { id = sender.EmailSenderID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.TestEmailSendersSettings))
                                    {
                                        <a title="Test Email" onclick="OpenTestEmailPopup(@sender.EmailSenderID)"><i class="fa fa-envelope"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.Delete_EmailSenders))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("DeleteEmailSender", "Correspondence", new { id = sender.EmailSenderID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>

            </div>

        </div>
    </div>
</div>



<div class="modal" id="TestEmailSettings">
    <form id="TestEmailSettingsform">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                    <h4 class="modal-title">Test Your Email Settings</h4>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="ToEmail">To Email</label>
                                <input type="email" id="ToEmail" name="ToEmail" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="Subject">Subject</label>
                                <input type="text" id="Subject" name="Subject" class="Subject form-control" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="TestEmailBody">Test Email Body</label>
                                <textarea id="TestEmailBody" class="form-control"></textarea>
                            </div>
                        </div>

                        <div class="col-md-12" style="text-align: center;">
                            <span id="EmailDeliveryResponse"></span>
                        </div>
                    </div>


                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                    <a class="btn btn-themyriad btn-ok" onclick="SendTestEmail()">Send</a>

                </div>
            </div>
            <!-- /.modal-content -->
        </div>
    </form>

    <!-- /.modal-dialog -->
</div>



@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <script src="~/Content/Js/Correspondance/EmailSettings.js?v=@DateTime.Now.ToString("hhmmsstt")" type="text/javascript"></script>


    <script>
        $(function () {
            $('.data-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        })


    </script>
}
