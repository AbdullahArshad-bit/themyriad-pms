@model PMS.DTO.ViewModels.TransportationViewModels.AddScheduleVM


@{
    /**/

    ViewBag.Header = "Transport";
    ViewBag.HeaderDescription = "Route Detail";
    ViewBag.Title = "Route Details | PMS";

    var ScheduleRootDetails = ViewBag.scheduleRouteDetails;
}



<div class="box box-danger">
    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("AllSchedules", "Transportation")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Schedules</a>
        </div>
    </div>

    <!-- form start -->
    @using (Html.BeginForm("AddSchedule", "Transportation", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_Schedule_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ScheduleID)

        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-md-6">

                @*<div class="form-group">
                        <label for="Title">Name</label>

                        @Html.TextBoxFor(x => x.ScheduleName, new { @class = "form-control", placeholder = "Enter Schedule Name" })

                        @Html.ValidationMessageFor(x => x.ScheduleName)

                    </div>*@


            </div>
            <div style="overflow: auto; width:100%">

                <table id="Schedules" class="table table-bordered table-striped">

                    <thead>

                        <tr>

                            <th>Route Name</th>
                            <th>Departure at</th>
                            <th>Action</th>

                        </tr>




                    </thead>
                    <tbody>

                        @foreach (var Route in (ScheduleRootDetails as List<PMS.EF.Route>))
                        {
                            <tr>

                                <td>@Route.RouteName</td>


                                <td>@Convert.ToDateTime(@Route.DepartureTime).ToString("hh:mm tt")</td>


                                <td class="menu-icons" style="text-align:inherit">
                                    @*<a title="Details" href="@Url.Action("SingleRootDetails", "Transportation", new { RouteID = Route.RouteID })"><i class="fa fa-newspaper-o"></i></a>*@
                                    <a title="Edit" href="@Url.Action("SingleRootDetails", "Transportation", new { RouteID = Route.RouteID })"><i class="fa fa-edit"></i></a>
                                    @*<a title="Delete" href="#" data-href="@Url.Action("DeleteSchedule" ,"Transportation", new { RouteID = Route.RouteID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>*@
                                </td>

                            </tr>
                        }



                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Route Name</th>
                            <th>Departure at</th>
                            <th>Action</th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <script>

    </script>
}


