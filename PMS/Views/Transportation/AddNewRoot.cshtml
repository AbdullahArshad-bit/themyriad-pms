@model PMS.DTO.ViewModels.TransportationViewModels.AddRouteVM


@{
    /**/

    /**/

    ViewBag.Header = "Add New Route";
    ViewBag.HeaderDescription = "Add New Route";
    ViewBag.Title = "Add New Route | PMS";

    var AllSchedule = ViewBag.allschedule;
}

@section styles{
    <!-- bootstrap datepicker -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <!-- Bootstrap time Picker -->
    <link rel="stylesheet" href="~/Assets/plugins/timepicker/bootstrap-timepicker.css">
}



<div class="box box-danger">
    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("AllSchedules", "Transportation")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Movie Shows</a>
        </div>
    </div>

    <!-- form start -->
    @using (Html.BeginForm("AddNewRouteDetail", "Transportation", FormMethod.Post, new { enctype = "multipart/form-data", id = "add_movie_show_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.RouteID)

    <div class="box-body">
        @if (ViewBag.error != null)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                @ViewBag.error
            </div>
        }
        @if (ViewBag.success != null)
        {
            <div class="alert alert-success alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h4><i class="icon fa fa-check"></i> Alert!</h4>
                @ViewBag.success
            </div>
        }

        <div class="col-md-3">
            <div class="form-group">
                <label for="HallNo">Route Name</label>

                @Html.TextBoxFor(x => x.Routename, new { @class = "form-control", placeholder = "Enter Route Name" })

                @Html.ValidationMessageFor(x => x.Routename)

            </div>
        
        </div>
        <div class="col-md-3">
      
            <div class="form-group">
                <label>Select Schedule</label>
                @Html.DropDownList("ScheduleID", (IEnumerable<SelectListItem>)AllSchedule, null, new { @class = "form-control" })

                @Html.ValidationMessageFor(x => x.ScheduleID)

            </div>

        </div>
        <div class="col-md-3">
       

            <div class="form-group">
                <label>Departure Time</label>

                <div class="input-group">
                    <div class="input-group-addon">
                        <i class="fa fa-clock-o"></i>
                    </div>

                    @Html.TextBoxFor(x => x.DepartureTime, new { @id = "show_time", @readonly = "", type = "text", @class = "form-control timepicker" })

                    @*@Html.ValidationMessageFor(x => x.DepartureTime)*@
                </div>
                <!-- /.input group -->
            </div>
        </div>
    </div>
        <!-- /.box-body -->

        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad" value="Save">
        </div>
    }
</div>

@section scripts
{
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- bootstrap time picker -->
    <script src="~/Assets/plugins/timepicker/bootstrap-timepicker.min.js"></script>

    <script>
        $(document).ready(function () {


        });
        $(function () {
            //Date picker
            $('#show_date').datepicker({
                autoclose: true,
                format: "dd/M/yyyy"
            });
            $('#show_time').timepicker({
                showInputs: false
            })
        })
    </script>
}


