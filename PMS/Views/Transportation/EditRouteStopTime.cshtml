@model PMS.DTO.ViewModels.TransportationViewModels.UpdateRouteTimeVM

@{
    /**/

    ViewBag.Header = "Transport";
    ViewBag.HeaderDescription = "Add New";
    ViewBag.Title = "Edit Route Time | PMS";
}





<div class="box box-danger">
    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("AllSchedules", "Transportation")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Schedules</a>
        </div>
    </div>




    @using (Html.BeginForm("UPDATEroute", "Transportation"))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(Model => Model.RouteStopID)

    <div class="box-body">
        @if (ViewBag.error != null)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                @ViewBag.error
            </div>
        }
        @if (ViewBag.success != null)
        {
            <div class="alert alert-success alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h4><i class="icon fa fa-check"></i> Alert!</h4>
                @ViewBag.success
            </div>
        }
        <div class="col-md-3">

            <div class="form-group">
                <label>Stop Time</label>
                <div class="input-group">

                    <div class="input-group-addon">
                        <i class="fa fa-clock-o"></i>
                    </div>

                    @Html.EditorFor(model => model.StopTime, new { @id = "show_time", type = "text", @class = "form-control timepicker" })


                </div>
            </div>
        </div>

        



        <div class="box-footer col-sm-12">
            <input type="submit" value="Save" class="btn btn-default" />
        </div>
    </div>
    }
</div>





@section scripts
{
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- bootstrap time picker -->
    <script src="~/Assets/plugins/timepicker/bootstrap-timepicker.min.js"></script>

    <script>
        $(document).ready(function () {


        });
        $(function () {
            //Date picker
            $('#show_date').datepicker({
                autoclose: true,
                format: "dd/M/yyyy"
            });
            $('#show_time').timepicker({
                showInputs: false
            })
        })
    </script>
}


