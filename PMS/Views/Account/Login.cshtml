@model PMS.DTO.ViewModels.LoginVM
@{
    /**/

    ViewBag.Title = "Login | The Myriad Admin";
    Layout = null;
}


<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>@ViewBag.Title</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/Assets/bower_components/font-awesome/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="~/Assets/bower_components/Ionicons/css/ionicons.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/Assets/dist/css/AdminLTE.min.css">
    <!-- iCheck -->
    <link rel="stylesheet" href="~/Assets/plugins/iCheck/square/_all.css">

    <link href="~/Assets/css/custom.css" rel="stylesheet" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
    <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <![endif]-->
    <!-- Google Font -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,600,700,300italic,400italic,600italic">
    <link rel="shortcut icon" type="image/png" href="https://themyriad.com/Assets/images/favicon.png">

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jQuery-viewport-checker/1.8.8/jquery.viewportchecker.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/jquery.validate.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.1/additional-methods.min.js"></script>
</head>
<body class="hold-transition login-page themyriad-login">
    <div class="login-container">
        <div class="login-card shadow-lg">
            <div class="brand text-center" style="padding-bottom: 28px !important; background-color: white; border-radius: 10px; ">
                <img src="https://www.themyriad.com/Assets/images/logo.png" alt="The Myriad" />
            </div>

            <div class="login-content">
                <h4 class="text-center login-title">Sign in to start your session</h4>

                @if (ViewBag.error != null)
                {
                    <div class="alert alert-danger alert-dismissible">
                        <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                        <strong>Error:</strong> @ViewBag.error
                    </div>
                }

                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(x => x.ReturnURL)

                    <div class="form-group has-feedback">
                        <div class="input-with-icon">
                            <span class="icon fa fa-envelope"></span>
                            @Html.TextBoxFor(x => x.Email, new { @class = "form-control modern-input", type = "email", placeholder = "Email address" })
                        </div>
                        @Html.ValidationMessageFor(x => x.Email)
                    </div>
                    <div class="form-group has-feedback">
                        <div class="input-with-icon">
                            <span class="icon fa fa-lock"></span>
                            @Html.PasswordFor(x => x.Password, new { @class = "form-control modern-input", type = "password", placeholder = "Password" })
                        </div>
                        @Html.ValidationMessageFor(x => x.Password)
                    </div>

                    <div class="remember-row">
                        <label class="remember-me">
                            @Html.CheckBoxFor(x => x.RememberMe) <span>Remember me</span>
                        </label>
                        <button type="submit" class="btn btn-primary btn-modern">Sign In</button>
                    </div>
                }
            </div>
        </div>
    </div>
    <!-- jQuery 3 -->
    <script src="~/Assets/bower_components/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="~/Assets/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- iCheck -->
    <script src="~/Assets/plugins/iCheck/icheck.min.js"></script>

    @*<script src="~/Scripts/jquery-3.3.1.min.js"></script>*@
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

    <style>
        .themyriad-login {
            background: linear-gradient(135deg, #0c0d10 0%, #1a1d24 60%, #2b2f3a 100%);
            min-height: 100vh;
        }

        .login-container {
            min-height: 100vh;
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -webkit-box-pack: center;
            -ms-flex-pack: center;
            justify-content: center;
            padding: 24px;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
        }

            .login-card .brand {
                padding: 28px 28px 0 28px;
            }

        .login-content {
            padding: 24px 28px 32px 28px;
            color: #e6e8ef;
        }

        .login-title {
            font-weight: 600;
            margin: 4px 0 18px 0;
            color: #cfd3dc;
        }

        .input-with-icon {
            position: relative;
        }

            .input-with-icon .icon {
                position: absolute;
                left: 12px;
                top: 50%;
                -webkit-transform: translateY(-50%);
                transform: translateY(-50%);
                color: #98a2b3;
                font-size: 14px;
            }

        .modern-input {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.18);
            color: #e6e8ef;
            height: 44px;
            border-radius: 10px;
            padding-left: 36px;
            -webkit-transition: all .2s ease;
            transition: all .2s ease;
        }

            .modern-input::-webkit-input-placeholder {
                color: #aeb6c2
            }

            .modern-input::-moz-placeholder {
                color: #aeb6c2
            }

            .modern-input:-ms-input-placeholder {
                color: #aeb6c2
            }

            .modern-input::placeholder {
                color: #aeb6c2
            }

            .modern-input:focus {
                outline: none;
                border-color: #7aa7ff;
                box-shadow: 0 0 0 3px rgba(122,167,255,0.25);
                background: rgba(255,255,255,0.15);
            }

        .remember-row {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -webkit-box-pack: justify;
            -ms-flex-pack: justify;
            justify-content: space-between;
            -ms-flex-wrap: nowrap;
            flex-wrap: nowrap;
            gap: 8px;
        }

        .remember-me {
            color: #c8ceda;
            font-weight: 500;
            white-space: nowrap;
            -ms-flex-negative: 0;
            flex-shrink: 0;
            margin-bottom: 0;
        }

            .remember-me input {
                margin-right: 6px;
            }

        .btn-modern {
            height: 42px;
            padding: 0 18px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg,#e21d2e 0%, #b1131f 100%);
            color: #fff;
            font-weight: 600;
            -webkit-transition: -webkit-transform .08s ease;
            transition: -webkit-transform .08s ease;
            transition: transform .08s ease;
            transition: transform .08s ease, -webkit-transform .08s ease;
        }

            .btn-modern:hover {
                opacity: .95
            }

            .btn-modern:active {
                -webkit-transform: translateY(1px);
                transform: translateY(1px)
            }

        .alert {
            border-radius: 10px
        }
    </style>

    <script>
        $(document).ready(function () {
            sessionStorage.clear("mySessionValue");
            localStorage.clear("SelItem");
        });
    </script>


</body>
</html>