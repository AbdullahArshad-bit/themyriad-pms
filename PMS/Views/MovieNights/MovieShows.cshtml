@using PMS.Common.Classes

@{
    ViewBag.Header = "Movie Shows";
    ViewBag.HeaderDescription = "All Shows";
    ViewBag.Title = "Movie Shows | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">

            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            @if (User.IsInRole(AppUserRoles.add_movie_shows))
            {
                <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                    <div class="input-group-btn">
                        <a href="@Url.Action("AddMovieShows", "MovieNights")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Movie Show</a>
                    </div>
                </div>
            }


            <div style="overflow: auto; width:100%">

                <table id="movie-shows" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th>Movie</th>
                            <th>Hall No</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Details</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var movie in (ViewBag.MovieShows as List<PMS.DTO.ViewModels.MovieNightsViewModels.MovieShowsVM>))
                        {
                            <tr>
                                <td>@movie.MovieTitle.ToUpper()</td>
                                <td>@movie.HallNo</td>
                                <td>@movie.ShowDate.ToString("dd-MMM-yyyy")</td>
                                <td>@movie.ShowTime</td>
                                <td>@movie.ShowDetails</td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.add_movie_shows))
                                    {
                                        <a title="Edit" href="@Url.Action("AddMovieShows", "MovieNights", new { showID = movie.MovieShowID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_movie_shows))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("DeleteMovieShows" ,"MovieNights", new { showID = movie.MovieShowID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }

                                </td>

                            </tr>
                        }





                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Movie</th>
                            <th>Hall No</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Details</th>
                            <th>Action</th>

                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#movie-shows').DataTable({});
            })
    </script>
}

