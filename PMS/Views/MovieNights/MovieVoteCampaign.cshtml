@model List<PMS.EF.MovieVoteCampaign>

@using PMS.Common.Classes

@{
    ViewBag.Header = "Movies Vote Campaign";
    ViewBag.HeaderDescription = "All Campaigns";
    ViewBag.Title = "All Campaigns | Movies Vote Campaign | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">

            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            @if (User.IsInRole(AppUserRoles.add_movie_vote_campaign))
            {
                <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                    <div class="input-group-btn">
                        <a href="@Url.Action("AddMovieVoteCampaign", "MovieNights")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Campaign</a>
                    </div>
                </div>
            }
            

            <div style="overflow: auto; width:100%">

                <table id="movies" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th>Description</th>
                            <th>Show Date</th>
                            <th>Show Time</th>
                            <th>Hall #</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var c in Model)
                        {
                            <tr>
                                <td>@c.Description.ToUpper()</td>
                                <td>@c.ShowDate.ToString("dd-MMM-yyyy")</td>
                                <td>@c.ShowTime.ToUpper()</td>
                                <td>@c.HallNo</td>
                                <td>@c.StartDate.ToString("dd-MMM-yyyy")</td>
                                <td>@c.EndDate.ToString("dd-MMM-yyyy")</td>
                                @{
                                    if (c.IsActive)
                                    {
                                        if (c.EndDate.Date < DateTime.Today.Date)
                                        {
                                            <td><span class="label label-danger">Expired</span></td>
                                        }
                                        else
                                        {
                                            <td><span class="label label-success">Active</span></td>
                                        }
                                    }
                                    else
                                    {
                                        <td><span class="label label-danger">Not Active</span></td>
                                    }
                                }

                                        <td class="menu-icons" style="text-align:inherit">
                                            @if (User.IsInRole(AppUserRoles.add_movie_vote_campaign))
                                            {
                                                <a title="Edit" href="@Url.Action("AddMovieVoteCampaign", "MovieNights", new { movieVoteCampaignID = c.MovieVoteCampaignID })"><i class="fa fa-edit"></i></a>
                                            }
                                            @if (User.IsInRole(AppUserRoles.view_movie_vote_campaign_detail))
                                            {
                                                <a title="Details" href="@Url.Action("MovieVoteCampaignDetail", "MovieNights", new { movieVoteCampaignID = c.MovieVoteCampaignID })"><i class="fa fa-newspaper-o"></i></a>
                                            }
                                            @if (User.IsInRole(AppUserRoles.delete_movie_vote_campaign))
                                            {
                                                <a title="Delete" href="#" data-href="@Url.Action("DeleteMovieVoteCampaign" ,"MovieNights", new { movieVoteCampaignID = c.MovieVoteCampaignID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                            }
                                        </td>

                            </tr>
                        }

                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Description</th>
                            <th>Show Date</th>
                            <th>Show Time</th>
                            <th>Hall #</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->



@section scripts{
    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#movies').DataTable({});
            })
    </script>
}

