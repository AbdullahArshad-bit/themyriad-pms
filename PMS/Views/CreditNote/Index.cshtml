@model IEnumerable<PMS.DTO.ViewModels.StudentCreditNoteVm>
@using PMS.Common.Classes
@{
    ViewBag.Header = "Credit Notes";
    ViewBag.HeaderDescription = "All Credit Notes";
    ViewBag.Title = "Credit Notes | PMS";
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    .right {
        text-align: right;
    }
</style>
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
            @*<div class="input-group-btn">
                    <a href="@Url.Action("AddPerson", "PersonManage")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Person</a>
                </div>*@

            <div class="btn-group">

                <a href="@Url.Action("Add", "CreditNote")" class="btn btn-themyriad">

                    <i class="fa fa-plus" style="padding-right: 5px;"></i>
                    Add New Credit Note
                </a>
            </div>

        </div>
        <div class="row">

            <div class="col-md-12">

                <table id="Invoices" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th>Code</th>
                            <th>Location</th>
                            <th>Student</th>
                            <th>Type</th>
                            <th>Remarks</th>
                            <th>Amount</th>
                            <th>RemainingAmount</th>
                            <th>Created Date</th>
                            <th>Created By</th>
                            <th>Approved By</th>
                            <th>Status</th>
                            <th>IsUtilized</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Code)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Location)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Student)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Type)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Reason)
                                </td>
                                <td class="right">
                                    @Html.DisplayFor(modelItem => item.Amount)
                                </td>
                                <td class="right">
                                    @if (item.RemainingAmount > 0)
                                    {
                                        <span class="text-success label label-danger">
                                            @Html.DisplayFor(modelItem => item.RemainingAmount)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success label label-success">
                                            @Html.DisplayFor(modelItem => item.RemainingAmount)
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(item.CreatedDate == null?"":((DateTime)item.CreatedDate).ToString("dd/MM/yyy"))
                                </td>
                                <td>
                                    @item.CreatedBy
                                </td>
                                <td>@item.ApprovedBy</td>
                                <td>
                                    @if (item.Status == (int)Enumeration.Status.Approved)
                                    {
                                        <span class="text-success label label-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger label label-primary ToBeApproved-@item.Id">Pending</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsUtilized)
                                    {

                                        <span class="label label-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="label label-danger">No</span>
                                    }
                                </td>
                                <td class="menu-icons" style="text-align:inherit">

                                    @if (item.Status != (int)Enumeration.Status.Approved)
                                    {

                                        if (User.IsInRole(AppUserRoles.approve_acc_CreditNote))
                                        {
                                            <a title="Approve" href="#Approve" onclick="ApproveConform(@item.Id)" class="ApproveHideAfterApproval"><i class="fa fa-thumbs-up"></i></a>
                                        }

                                        <a title="Edit" href="@Url.Action("Add", "CreditNote", new { id = item.Id })"><i class="fa fa-edit ApproveHideAfterApproval"></i></a>
                                    }

                                    @*@if (User.IsInRole(AppUserRoles.edit_after_approve_CreditNote) && item.IsUtilized == false)
                                        {
                                            <a title="Edit" href="@Url.Action("Add", "CreditNote", new { id = item.Id })"><i class="fa fa-edit ApproveHideAfterApproval"></i></a>
                                        }*@

                                    @*<a title="Details" href="@Url.Action("Details", "CreditNote", new { id = item.Id })"><i class="fa fa-file-text-o"></i></a>*@


                                    @if (item.VoucherId !=null)
                                    {
                                        <a class="voucher-action menu-icons" style="text-align:inherit" title="Voucher Details" href="@Url.Action("CreditNoteVoucher", "Voucher", new { id = item.VoucherId })">
                                            <i class="fa fa-ticket action-for-Voucher"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>
<div class="modal" id="ApproveConformation">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Are you sure you want to Approve?</h4>
            </div>
            <div class="modal-body">
                <p>If you Approve this Note will no longer be editable, Please review and confirm.</p>
            </div>
            <div class="modal-footer">
                <div class="col-md-3"></div>
                <div class="col-md-4"></div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
                <div class="col-md-2">
                    <button type="button" onclick="ApproveById();" class="btn btn-primary">Approve</button>
                </div>

            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

@section scripts{


    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="//cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>

    <script>

        $(document).ready(function () {
            $('#Invoices').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                "iDisplayLength": 100,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'copyHtml5',
                    'excelHtml5',
                ],
                columnDefs: [
                    { type: 'date-euro', targets: 3 },

                ]
            });
        });

        var Id = 0;
        function ApproveConform(Code) {
            Id = Code;
            $('#ApproveConformation').modal('show');
        }

        function ApproveById() {
            $('#ApproveConformation').modal('hide');
            $.ajax({
                type: "Get",
                url: GetFormatedUrl('/CreditNote/ApproveById/') + Id,
                async: true,
                success: function (data) {
                    if (data.status == true) {
                        $('.ToBeApproved-' + Id).closest('tr').find('.EditHideAfterApproval').addClass('hide');
                        $('.ToBeApproved-' + Id).closest('tr').find('.ApproveHideAfterApproval').addClass('hide');
                        $('.ToBeApproved-' + Id).closest('td').html('<span class="text-success label label-success">Approved</span>');
                        Toast.show(data.message, "success");
                    } else {
                        Toast.show(data.message, "error");
                    }
                },
                error: function (data) {
                }
            });
        };


    </script>
}
