@using PMS.Common.Classes

@{
    ViewBag.Header = "Room Types";
    ViewBag.HeaderDescription = "All Room Types";
    ViewBag.Title = "All Room Types | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            @if (User.IsInRole(AppUserRoles.add_room_types))
            {
                <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                    <div class="input-group-btn">
                        <a href="@Url.Action("AddRoomType", "Setup")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Room Type</a>
                    </div>
                </div>
            }

            @if (ViewBag.RoomTypes != null)
            {
                <div style="overflow: auto; width:100%">

                    <table id="room-types" class="table table-bordered table-striped">

                        <thead>

                            <tr>
                                <th>Location</th>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Instruction</th>
                                <th>Area</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var room in ViewBag.RoomTypes as List<PMS.EF.RoomType>)
                            {
                                <tr>
                                    <td>@room.Location.LocationName</td>
                                    <td>@room.RoomCode</td>
                                    <td>@room.RoomName</td>
                                    <td>@room.RoomDescription</td>
                                    <td>@room.RoomInstruction</td>
                                    <td>@room.RoomArea</td>
                                    <td class="menu-icons" style="text-align:inherit">
                                        @if (User.IsInRole(AppUserRoles.add_room_types))
                                        {
                                            <a title="Edit" href="@Url.Action("AddRoomType", "Setup", new { id = room.RoomTypeID })"><i class="fa fa-edit"></i></a>
                                        }
                                        @if (User.IsInRole(AppUserRoles.upload_room_typeImages))
                                        {
                                            <a title="Upload Images" href="@Url.Action("UploadRoomTypeImages", "Setup", new { RoomTypeid = room.RoomTypeID })"><i class="fa fa-file-photo-o"></i></a>
                                        }
                                        @if (User.IsInRole(AppUserRoles.delete_room_types))
                                        {
                                            <a title="Delete" href="#" data-href="@Url.Action("DeleteRoomType" ,"Setup", new { id = room.RoomTypeID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                        }
                                    </td>

                                </tr>
                            }

                        </tbody>
                        @*<tfoot>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Area</th>
                                    <th>Action</th>
                                </tr>
                            </tfoot>*@
                    </table>

                </div>

            }

        </div>
    </div>
</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#room-types').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        })


    </script>
}
