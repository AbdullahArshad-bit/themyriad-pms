@model PMS.DTO.ViewModels.SetupViewModels.RoomTypeDetailsVM
@using PMS.EF
@{
    var filePath = System.Configuration.ConfigurationManager.AppSettings["UploadedImages"];
    var Images = ViewBag.ImagesDetail as ICollection<RoomTypeDetail>;

}

@using PMS.Common.Classes
@section styles{


    <!-- Jquery filer css -->

    <link href="~/Assets/plugins/jquery.filer/fancy-file-uploader/fancy_fileupload.css" media="all" rel="stylesheet">

}
@{
    ViewBag.Header = "Room Features";
    ViewBag.HeaderDescription = "Add New Room Feature";
    ViewBag.Title = "Add Room Features | PMS";
}

<div class="box box-danger">
    @if (User.IsInRole(AppUserRoles.view_room_feaure))
    {
        <div class="box-header with-border">
            <div class="input-group-btn">
                <a href="@Url.Action("RoomTypes", "Setup")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Room Types</a>
            </div>
        </div>
    }




    @using (Html.BeginForm("UploadRoomTypeImages", "Setup", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.HiddenFor(x => x.RoomTypeID)

        <div class="row col-md-12">
            <input id="ImageSource" type="file" name="ImageSource" class="hide" accept=".jpg, .png, image/jpeg, image/png" multiple>



        </div>

        <div class="row col-md-12">
            <table class="table table-sm table-responsive-sm">
                <thead>
                    <tr>
                        <th scope="col" style="width:30%"> Image</th>
                        <th scope="col"> File Name</th>
                        <th scope="col"> Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Images.ToList())
                    {

                        <tr>
                            <td>
                                <a href="@filePath@item.ImageUrl" target="_blank">
                                    <div class="pull-left image">
                                        <img src="@filePath@item.ImageUrl" class="img-circle" alt="User Image" style="width: 65px; height:65px">
                                    </div>
                                </a>
                            </td>
                            <td>
                                <a href="@filePath@item.ImageUrl" target="_blank">@item.Description</a>
                            </td>
                            <td><a href="#del" onclick="DeleteImage(@item.ID)"><i class="fa fa-remove" style="color:red"></i></a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad hide" value="Save">
        </div>
    }
</div>
<div class="modal" id="DeleteImageConformation">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Are you sure you want to Delete?</h4>
            </div>
            <div class="modal-body">
                <p>You are about to delete this record. This process is irreversible.</p>
                <p> Are you sure?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" onclick="ApproveInvoice();" class="btn btn-themyriad btn-ok">Delete</button>
            </div>

        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

@section scripts
{

    <script src="~/Assets/plugins/jquery.filer/fancy-file-uploader/jquery.ui.widget.js"></script>
    <script src="~/Assets/plugins/jquery.filer/fancy-file-uploader/jquery.fileupload.js"></script>
    <script src="~/Assets/plugins/jquery.filer/fancy-file-uploader/jquery.iframe-transport.js"></script>
    <script src="~/Assets/plugins/jquery.filer/fancy-file-uploader/jquery.fancy-fileupload.js"></script>
    <script>
        $('#ImageSource').FancyFileUpload({
            params: {
                action: 'fileuploader',
                RoomTypeID: $('#RoomTypeID').val()

            },
            'uploadcompleted': function (e, data) {
                var response = data.result;
                alert('Image Uploaded Successfully!');
            },
            'retries': 1,

            maxfilesize: 1000000
        });
        $(function () {
        })
        var Id = 0;
        function DeleteImage(Code) {
            Id = Code;
            $('#DeleteImageConformation').modal('show');
        }

        function ApproveInvoice() {
            $('#DeleteImageConformation').modal('hide');
            $.ajax({
                type: "Post",
                url: GetFormatedUrl('/setup/DeleteRoomTypeImagebyId/') + Id,
                async: true,
                success: function (data) {
                    var data = data.status;
                    if (data == true) {
                        window.location.reload();
                        $('#Approve').addClass('hide');
                    }
                },
                error: function (data) {
                }
            });
        };


    </script>

}
