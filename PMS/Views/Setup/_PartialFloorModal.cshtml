@model PMS.DTO.ViewModels.SetupViewModels.AddFloorVM

@using (Ajax.BeginForm("AddFloor", "Setup", new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "modalFormSuccess",
    OnFailure = "modalFormFailure",
    OnBegin = "$('#loader').show();",
    OnComplete = "$('#loader').fadeOut('slow');"
}))
{
    @Html.AntiForgeryToken();
    @Html.HiddenFor(x => x.FloorID)
    @Html.HiddenFor(x => x.BuildingID)

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Add/Update Floor</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>

                    @Html.TextBoxFor(x => x.FloorName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.FloorName)

                </div>
                <div class="form-group">
                    <label>Description</label>

                    @Html.TextAreaFor(x => x.FloorDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })

                    @Html.ValidationMessageFor(x => x.FloorDescription)

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-themyriad">Save</button>
            </div>
        </div>
    </div>
}