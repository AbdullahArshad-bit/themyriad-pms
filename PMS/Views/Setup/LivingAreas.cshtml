                background-color: black;
            }

        .multistepform #msform .action-button-previous {
            width: 100px;
            background: #c20e1a;
            font-weight: bold;
            color: white;
            border: 0 none;
            border-radius: 0px;
            cursor: pointer;
            padding: 10px 5px;
            margin: 10px 5px 10px 0px;
            float: right
        }

            .multistepform #msform .action-button-previous:hover,
            .multistepform #msform .action-button-previous:focus {
                background-color: black;
            }

        .multistepform .card {
            z-index: 0;
            border: none;
            position: relative
        }

        .multistepform .fs-title {
            font-size: 25px;
            color: #c20e1a;
            margin-bottom: 15px;
            font-weight: normal;
            text-align: left
        }

        .multistepform .purple-text {
            color: #c20e1a;
            font-weight: normal
        }

        .multistepform .steps {
            font-size: 25px;
            color: gray;
            margin-bottom: 10px;
            font-weight: normal;
            text-align: right
        }

        .multistepform .fieldlabels {
            color: gray;
            text-align: left
        }

        .multistepform #progressbar {
            margin-bottom: 30px;
            overflow: hidden;
            color: lightgrey
        }

            .multistepform #progressbar .active {
                color: #c20e1a
            }

            .multistepform #progressbar li {
                list-style-type: none;
                font-size: 15px;
                width: 16%;
                float: left;
                position: relative;
                font-weight: 400
            }

            .multistepform #progressbar #account:before {
                font-family: FontAwesome;
                content: "\f00c"
            }

        #progressbar #personal:before {
            font-family: FontAwesome;
            content: "\f00c"
        }

        .multistepform .multistepform #progressbar #personal:before {
            font-family: FontAwesome;
            content: "\f00c"
        }

        .multistepform #progressbar #payment:before {
            font-family: FontAwesome;
            content: "\f00c"
        }

        .multistepform #progressbar #confirm:before {
            font-family: FontAwesome;
            content: "\f00c"
        }


        .multistepform #progressbar #rooms:before {
            font-family: FontAwesome;
            content: "\f00c"
        }



        .multistepform #progressbar #beds:before {
            font-family: FontAwesome;
            content: "\f00c"
        }

        .multistepform #progressbar li:before {
            width: 50px;
            height: 50px;
            line-height: 45px;
            display: block;
            font-size: 20px;
            color: #ffffff;
            background: lightgray;
            border-radius: 50%;
            margin: 0 auto 10px auto;
            padding: 2px
        }

        .multistepform #progressbar li:after {
            content: '';
            width: 100%;
            height: 2px;
            background: lightgray;
            position: absolute;
            left: 0;
            top: 25px;
            z-index: -1
        }

        .multistepform #progressbar li.active:before,
        .multistepform #progressbar li.active:after {
            background: #c20e1a
        }

        .multistepform .progress {
            height: 20px
        }

        .multistepform .progress-bar {
            background-color: #c20e1a
        }

        .multistepform .fit-image {
            width: 100%;
            object-fit: cover
        }
    </style>

}

