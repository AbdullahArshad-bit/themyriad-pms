<div class="modal fade" id="form_modal_div" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

</div>


<div class="modal fade" id="confirm-delete-async" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

    @using (Ajax.BeginForm("", "", new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "deleteSuccess",
        OnFailure = "deleteFailure",
        OnBegin = "$('#loader').show();",
        OnComplete = "$('#loader').fadeOut('slow');"
    }, new { id = "delete_form_async" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
                </div>

                <div class="modal-body">
                    <p>You are about to delete this record. This process is irreversible.</p>
                    <p> Are you sure?</p>
                    <p class="debug-url"></p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-themyriad btn-ok">Delete</button>
                </div>
            </div>
        </div>

    }
</div>


@section scripts{

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script>
        function LoadTable(view, id) {
            $.ajax({
                url: GetFormatedUrl("/Setup/GetTable"),
                method: "Get",
                dataType: "html",
                contentType: 'application/json; charset=utf-8',
                data: { View: view, Id: id },
                beforeSend: function () {
                    $('#loader').show();
                },
                complete: function () {
                    $('#loader').fadeOut('slow');
                },
                success: function (data) {
                    $("#" + view + "_table").html(data);
                    if (view == "room") {
                        $("#" + view + "_table" + ' table').DataTable({
                            "scrollY": "70vh",
                            "scrollCollapse": true,
                            "scrollX": "auto",
                            dom: 'Blfrtip',
                            lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                            buttons: [
                                'excelHtml5',
                            ],
                            "order": [],
                            "columnDefs": [{
                                "targets": 0,
                                "orderable": false,
                            }]
                        });
                    }
                    else {
                        $("#" + view + "_table" + ' table').DataTable({
                            "scrollY": "70vh",
                            "scrollCollapse": true,
                            "scrollX": "auto",
                            dom: 'Blfrtip',
                            lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                            buttons: [
                                'excelHtml5',
                            ],
                        });

                    }
                },
                error: function (xhr) {
                    showMessage(xhr.status + " - " + xhr.statusText);

                }
            });
        }



        var deleteSuccess = function (data) {
            var view = $(this).data('view');
            $('#confirm-delete-async').modal('hide');

            if (data.status == false) {
                Toast.show(data.data, "error");
                return;
            }
            if (data.Success == true) {

                Toast.show(data.Message, "success");

                switch (view) {
                    case "location":
                        { LoadTable(view, 0); return; }
                    case "project":
                        { LoadTable(view, $("input[name='location']:checked").val()); return; }
                    case "building":
                        { LoadTable(view, $("input[name='project']:checked").val()); return; }
                    case "floor":
                        { LoadTable(view, $("input[name='building']:checked").val()); return; }
                    case "room":
                        { LoadTable(view, $("input[name='floor']:checked").val()); return; }
                    case "bed":
                        { LoadTable(view, $("input[name='room']:checked").val()); return; }
                    default:
                        return;
                }
            }
            else {
                //showMessage('Unable to process your request. Pleae try again later.');
                Toast.show("Unable to process your request. Pleae try again later.", "error");
            }
        }
        var deleteFailure = function (data) {
            showMessage(data.status + ' - ' + data.statusText);
        }

        var modalFormSuccess = function (data) {
            console.log(data);
            if (data.Success == false) {
                Toast.show(data.Message, "error");
                return;
            }

            $('#form_modal_div').modal('hide');
            Toast.show(data.Message, "success");

            var view = $(this).data('view');

            switch (view) {
                case "location":
                    { LoadTable(view, 0); return; }
                case "project":
                    { LoadTable(view, $("input[name='location']:checked").val()); return; }
                case "building":
                    { LoadTable(view, $("input[name='project']:checked").val()); return; }
                case "floor":
                    { LoadTable(view, $("input[name='building']:checked").val()); return; }
                case "room":
                    { LoadTable(view, $("input[name='floor']:checked").val()); return; }
                case "bed":
                    { LoadTable(view, $("input[name='room']:checked").val()); return; }
                default:
                    return;
            }

        }

        var modalFormFailure = function (data) {
            showMessage(data.status + ' - ' + data.statusText);
        }

        $(document).ready(function () {

            $('#confirm-delete-async').on('show.bs.modal', function (e) {
                $('#delete_form_async').attr('action', $(e.relatedTarget).data('href'));
                $('#confirm-delete-async form').attr('data-view', $(e.relatedTarget).data('view'));
            });

            $('#form_modal_div').on('hide.bs.modal', function (e) {
                $('#form_modal_div').html('');
            });


            LoadTable("location", 0);


            $(document).on("click", ".form_modal", function () {
                var view = $(this).data('view');
                var id = $(this).data('id');
                var linkId = 0;

                if (view == "location") {

                }
                else if (view == "project") {
                    linkId = $("input[name='location']:checked").val();
                }
                else if (view == "building") {
                    linkId = $("input[name='project']:checked").val();
                }
                else if (view == "floor") {
                    linkId = $("input[name='building']:checked").val();
                }
                else if (view == "room") {
                    linkId = $("input[name='floor']:checked").val();
                }
                else if (view == "bed") {
                    linkId = $("input[name='room']:checked").val();
                }

                $.ajax({
                    
                    url: GetFormatedUrl("/Setup/GetModal"),
                    method: "Get",
                    dataType: "html",
                    contentType: 'application/json; charset=utf-8',
                    data: { View: view, Id: id, LinkId: linkId },
                    beforeSend: function () {
                        $('#loader').show();
                    },
                    complete: function () {
                        $('#loader').fadeOut('slow');
                    },
                    success: function (data) {
                        $("#form_modal_div").html(data);
                        $('#form_modal_div form').attr('data-view', view);
                        $.validator.unobtrusive.parse("#form_modal_div form");
                        $('#form_modal_div').modal('show');
                    },
                    error: function (xhr) {
                        $('.message_modal_text').text(xhr.status + ' - ' + xhr.statusText);
                        $('#message_modal').modal('show');

                    }
                });
            });



            var current_fs, next_fs, previous_fs; //fieldsets
            var opacity;
            var current = 1;
            var steps = $("fieldset").length;

            setProgressBar(current);

            $(".next").click(function () {

                if (false) { }
                else {
                    current_fs = $(this).parent();
                    next_fs = $(this).parent().next();

                    var index = $("fieldset").index(next_fs);

                    if (index == 1) {
                        if (typeof $("input[name='location']:checked").val() == "undefined") {
                            showMessage("Please select location to proceed.");
                            return;
                        }

                        LoadTable('project', $("input[name='location']:checked").val());
                    }
                    else if (index == 2) {
                        if (typeof $("input[name='project']:checked").val() == "undefined") {
                            showMessage("Please select project to proceed.");
                            return;
                        }

                        LoadTable('building', $("input[name='project']:checked").val());
                    }
                    else if (index == 3) {
                        if (typeof $("input[name='building']:checked").val() == "undefined") {
                            showMessage("Please select building to proceed.");
                            return;
                        }

                        LoadTable('floor', $("input[name='building']:checked").val());
                    }
                    else if (index == 4) {
                        if (typeof $("input[name='floor']:checked").val() == "undefined") {
                            showMessage("Please select floor to proceed.");
                            return;
                        }

                        LoadTable('room', $("input[name='floor']:checked").val());
                    }
                    else if (index == 5) {
                        if (typeof $("input[name='room']:checked").val() == "undefined") {
                            showMessage("Please select room to proceed.");
                            return;
                        }

                        LoadTable('bed', $("input[name='room']:checked").val());
                    }

                    //Add Class Active
                    $("#progressbar li").eq($("fieldset").index(next_fs)).addClass("active");

                    //show the next fieldset
                    next_fs.show();
                    //hide the current fieldset with style
                    current_fs.animate({ opacity: 0 }, {
                        step: function (now) {
                            // for making fielset appear animation
                            opacity = 1 - now;

                            current_fs.css({
                                'display': 'none',
                                'position': 'relative'
                            });
                            next_fs.css({ 'opacity': opacity });
                        },
                        duration: 500
                    });
                    setProgressBar(++current);
                }


            });

            $(".previous").click(function () {

                current_fs = $(this).parent();
                previous_fs = $(this).parent().prev();


                var index = $("fieldset").index(current_fs);
                if (index == 1) {
                    $('#project_table').html('');
                }
                else if (index == 2) {
                    $('#building_table').html('');
                }
                else if (index == 3) {
                    $('#floor_table').html('');
                }
                else if (index == 4) {
                    $('#room_table').html('');
                }
                else if (index == 5) {
                    $('#bed_table').html('');
                }


                //Remove class active
                $("#progressbar li").eq($("fieldset").index(current_fs)).removeClass("active");

                //show the previous fieldset
                previous_fs.show();

                //hide the current fieldset with style
                current_fs.animate({ opacity: 0 }, {
                    step: function (now) {
                        // for making fielset appear animation
                        opacity = 1 - now;

                        current_fs.css({
                            'display': 'none',
                            'position': 'relative'
                        });
                        previous_fs.css({ 'opacity': opacity });
                    },
                    duration: 500
                });
                setProgressBar(--current);
            });

            function setProgressBar(curStep) {
                var percent = parseFloat(100 / steps) * curStep;
                percent = percent.toFixed();
                $(".progress-bar")
                    .css("width", percent + "%")
            }

            $(".submit").click(function () {
                return false;
            });

        });


        $('.Finish').on('click', function () {
            location.reload(true);
        })
      
    </script>
}
