            /*padding: 8px 15px 8px 15px;
            border: 1px solid #ccc;
            border-radius: 0px;
            margin-bottom: 25px;
            margin-top: 2px;
            width: 100%;
            box-sizing: border-box;
            font-family: montserrat;
            color: #c20e1a;
            background-color: #ECEFF1;
            font-size: 16px;
            letter-spacing: 1px*/
        }

            .multistepform #msform input:focus,
            .multistepform #msform textarea:focus {
                -moz-box-shadow: none !important;
