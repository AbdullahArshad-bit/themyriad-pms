@model PMS.DTO.ViewModels.SetupViewModels.AddLocationVM

@using (Ajax.BeginForm("AddLocation", "Setup", new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "modalFormSuccess",
    OnFailure = "modalFormFailure",
    OnBegin = "$('#loader').show();",
    OnComplete = "$('#loader').fadeOut('slow');"
}))
{
    @Html.AntiForgeryToken();
    @Html.HiddenFor(x => x.LocationID)

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Add/Update Location</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>

                    @Html.TextBoxFor(x => x.LocationName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.LocationName)

                </div>
                <div class="form-group">
                    <label>Arabic Loaction Name</label>

                    @Html.TextBoxFor(x => x.Ar_LocationName, new { @class = "form-control", placeholder = "Enter Arabic Name" ,@required="Required", @maxlength="250" })

                    @Html.ValidationMessageFor(x => x.Ar_LocationName)

                </div>
                <div class="form-group">
                    <label>Prefix</label>

                    @Html.TextBoxFor(x => x.Prefix, new { @class = "form-control", placeholder = "Enter Prefix it will be applicable on all entities" ,@required="Required", @maxlength="4" })

                    @Html.ValidationMessageFor(x => x.Prefix)

                </div>
                <div class="form-group">
                    <label>Description</label>

                    @Html.TextAreaFor(x => x.LocationDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })

                    @Html.ValidationMessageFor(x => x.LocationDescription)

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-themyriad">Save</button>
            </div>
        </div>
    </div>
}