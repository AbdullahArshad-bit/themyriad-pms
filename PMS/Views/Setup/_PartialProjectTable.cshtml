@{
    var projects = ViewBag.Projects as List<PMS.EF.Project>;
}

<table class="table">
    <thead>
        <tr>
            <th>Project</th>
            <th>Description</th>
            <th>Action</th>
        </tr>

    </thead>
    <tbody>
        @for (int i = 0; i < projects.Count; i++)
        {
            <tr>
                <td>
                    <div class="form-group">
                        <div class="radio">
                            <label>
                                <input type="radio" name="project" value="@projects[i].ProjectID" @(i == 0 ? "checked" : "")>
                                @projects[i].ProjectName
                            </label>
                        </div>
                    </div>
                </td>
                <td>@projects[i].ProjectDescription</td>
                <td class="menu-icons" style="text-align:inherit">
                    <a title="Edit" href="#" class="form_modal" data-id="@projects[i].ProjectID" data-view="project"><i class="fa fa-edit"></i></a>
                    <a title="Delete" href="#" data-view="project" data-href="@Url.Action("DeleteProject" ,"Setup", new { id = projects[i].ProjectID })" data-toggle="modal" data-target="#confirm-delete-async"><i class="fa fa-remove"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>