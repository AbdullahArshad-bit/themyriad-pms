@model PMS.DTO.ViewModels.SetupViewModels.AddProjectVM

@using (Ajax.BeginForm("AddProject", "Setup", new AjaxOptions
{
    
    HttpMethod = "POST",
    OnSuccess = "modalFormSuccess",
    OnFailure = "modalFormFailure",
    OnBegin = "$('#loader').show();",
    OnComplete = "$('#loader').fadeOut('slow');"
}))
{
    @Html.AntiForgeryToken();
    @Html.HiddenFor(x => x.LocationID)
    @Html.HiddenFor(x => x.ProjectID)

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Add/Update Project</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>

                    @Html.TextBoxFor(x => x.ProjectName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.ProjectName)

                </div>
                <div class="form-group">
                    <label>City</label>

                    @Html.TextBoxFor(x => x.ProjectCity, new { @class = "form-control", placeholder = "Enter City" })

                    @Html.ValidationMessageFor(x => x.ProjectCity)

                </div>
                <div class="form-group">
                    <label>State</label>

                    @Html.TextBoxFor(x => x.ProjectState, new { @class = "form-control", placeholder = "Enter State" })

                    @Html.ValidationMessageFor(x => x.ProjectState)

                </div>
                <div class="form-group">
                    <label>Zip</label>

                    @Html.TextBoxFor(x => x.ProjectZip, new { @*@min = 1,*@ @class = "form-control", placeholder = "Enter Zip", @type="number" })

                    @Html.ValidationMessageFor(x => x.ProjectZip)

                </div>
                <div class="form-group">
                    <label>Address</label>

                    @Html.TextBoxFor(x => x.ProjectAddress, new { @class = "form-control", placeholder = "Enter Address" })

                    @Html.ValidationMessageFor(x => x.ProjectAddress)

                </div>
                <div class="form-group">
                    <label>Description</label>

                    @Html.TextAreaFor(x => x.ProjectDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })

                    @Html.ValidationMessageFor(x => x.ProjectDescription)

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-themyriad">Save</button>
            </div>
        </div>
    </div>
}