@using PMS.Common.Classes
@model PMS.DTO.ViewModels.SetupViewModels.ImportTermFromExcelVM

@{
    ViewBag.Header = "Term";
    ViewBag.HeaderDescription = "All Terms";
    ViewBag.Title = "All Terms | The Myriad Admin";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">

                <div class="btn-group">

                    @if (User.IsInRole(AppUserRoles.add_terms))
                    {
                        <a href="@Url.Action("AddTerm", "Setup")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Term</a>

                    }

                    @*<a href="http://localhost:54589//Upload/Files/ExcelImportFormats/ImportTerms.xlsx" class="btn btn-themyriad">
                        <i class="fa  fa-file-excel-o" style="padding-right: 5px;"></i>
                        Import Terms Format
                    </a>

                    <a href="javascript:void(0)" data-toggle="modal" data-target="#import-from-excel-modal" class="btn btn-themyriad">
                        <i class="fa  fa-file-excel-o" style="padding-right: 5px;"></i>
                        Import Terms From Excel
                    </a>*@

                </div>
            </div>


            @if (ViewBag.Terms != null)
            {
                <div style="overflow: auto; width:100%">

                    <table id="term" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Location</th>
                                <th>Name</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Frequency</th>
                                <th>Description</th>
                                <th>University</th>
                                <th>Publish</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var term in ViewBag.Terms as List<PMS.EF.Term>)
                            {
                                <tr>
                                    <td>@term.Location.LocationName</td>
                                    <td>@term.TermName</td>
                                    <td>@(term.TermStartDate == null ? "" : ((DateTime)term.TermStartDate).ToString("dd/MM/yyy"))</td>
                                    <td>@(term.TermEndDate == null ? "" : ((DateTime)term.TermEndDate).ToString("dd/MM/yyy"))</td>
                                    <td>@(term.FrequencyId == null ? "" : term.VehiclePriceLookUp.PriceRate)</td>
                                    <td>@term.TermDescription</td>
                                    <td>@(term.UniversityId==null ? "" :term.University.UniversityName)</td>
                                    <td>
                                        @if (term.IsPublished == true)
                                        {
                                            <span class="label label-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger">No</span>

                                        }

                                    </td>
                                    <td class="menu-icons" style="text-align:inherit">
                                        @if (User.IsInRole(AppUserRoles.add_terms))
                                        {
                                            <a title="Edit" href="@Url.Action("AddTerm", "Setup", new { id = term.TermID })"><i class="fa fa-edit"></i></a>
                                        }
                                        @if (User.IsInRole(AppUserRoles.delete_terms))
                                        {
                                            <a title="Delete" href="#" data-href="@Url.Action("DeleteTerm" ,"Setup", new { id = term.TermID })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            }


        </div>
    </div>
</div>

<div class="modal fade" id="import-from-excel-modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

    @using (Html.BeginForm("ImportTermsFromExcel", "Setup", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken();

        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4 class="modal-title" id="myModalLabel">Import terms from excel file</h4>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label>Excel File</label>

                        @Html.TextBoxFor(x => x.fileBase, new { @class = "form-control", type = "file" })

                        @Html.ValidationMessageFor(x => x.fileBase)

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-themyriad">Save</button>
                </div>
            </div>
        </div>
    }
</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#term').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                "iDisplayLength": 100,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
                columnDefs: [
                    { type: 'date-euro', targets: 1 },
                    { type: 'date-euro', targets: 2 },
                ]
            });
        })
    </script>
}
