@model PMS.DTO.ViewModels.SetupViewModels.UniversityVM
@using PMS.Common.Classes

@{
    ViewBag.Header = "Universites";
    ViewBag.HeaderDescription = "Universities";
    ViewBag.Title = "Universites | PMS";
}

@section styles{
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <!-- Select2 -->
    <link rel="stylesheet" href="~/Assets/bower_components/select2/dist/css/select2.min.css">
}
<style>
    .overlay-image:hover {
        opacity: 0.5;
    }

        .overlay-image:hover .profilepic__content {
            opacity: 1;
        }

    .overlay-image {
        overflow: hidden;
    }

    .profilepic__content {
        position: absolute;
        top: 10%;
        right: 0;
        bottom: 0;
        left: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        opacity: 0;
        transition: opacity .2s ease-in-out;
    }

    .profilepic__icon {
        color: white;
        padding-bottom: 8px;
    }

    .profilepic__content .fa {
        font-size: 20px;
        color: white;
    }

    .profilepic__text {
        text-transform: uppercase;
        font-size: 12px;
        width: 50%;
        text-align: center;
        color: white;
    }

    .option1 {
        display: inline-block; /* show on the same line */
        padding-right: 5px; /* small gap on the right of each header */
    }
</style>


<div class="box box-danger">

    <div class="box-header with-border">
        <div class="input-group-btn">
            <a href="@Url.Action("GetUniversitesList", "Setup")" class="btn btn-themyriad"><i class="fa fa-arrow-circle-left" style="padding-right: 5px;"></i> All Universities</a>
        </div>
    </div>

    @using (Html.BeginForm("AddUniversity", "Setup", FormMethod.Post, new { enctype = "multipart/form-data", id = "University_form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Id)



        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-md-12">
                <div class="form-group">
                    <label>Active</label>

                    <div>

                        <label class="switch">
                            <input type="checkbox" name="IsActive" id="IsActive" value="@Model.IsActive" @(Model.IsActive ? "checked" : "")>
                            <span class="slider round"></span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            @Html.LabelFor(x => x.LocationId, "Location")
                            @Html.DropDownList("LocationId", null, "Select...", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                            @Html.ValidationMessageFor(x => x.LocationId)

                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Routing Prefix</label>
                            @Html.TextBoxFor(x => x.Prefix, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Routing prefix" })
                            @Html.ValidationMessageFor(x => x.Prefix)
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email Suffix </label>
                            @Html.TextBoxFor(x => x.EmailPrefix, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter email suffix " })
                            @Html.ValidationMessageFor(x => x.EmailPrefix)

                        </div>
                    </div>
                </div>
                <br />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Title">Name</label>
                            @Html.TextBoxFor(x => x.UniversityName, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter name" })
                            @Html.ValidationMessageFor(x => x.UniversityName)

                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Title">Arabic Name</label>
                            @Html.TextBoxFor(x => x.UniversityArabicName, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter arabic name" })
                            @Html.ValidationMessageFor(x => x.UniversityArabicName)

                        </div>
                    </div>
                </div>
                <br />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Title">Description</label>
                            @Html.TextBoxFor(x => x.UniDescription, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter description" })
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Title">Arabic Description</label>

                            @Html.TextBoxFor(x => x.Ar_UniDescription, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter arabic description" })
                        </div>
                    </div>
                </div>
                <br />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Title">Email CC</label>
                            @Html.TextBoxFor(x => x.EmailCC, new { @class = "form-control pull-right", @autocomplete = "off", placeholder = "Enter Email" })
                        </div>
                    </div>
                </div>
                <br />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group ">
                            <label for="exampleInputFile">Banner</label>
                            @{
                                if (Model.Id > 0)
                                {
                                    Html.EnableClientValidation(false);
                                }
                            }
                            @Html.TextBoxFor(x => x.ThumbnailImage, new { @class = "form-control", type = "file" })
                            <p class="help-block ">image size should be 2250x508 pixels</p>

                            @Html.ValidationMessageFor(x => x.ThumbnailImage)

                            <img id="thumbUpload" src="@(!string.IsNullOrEmpty(Model.ThumbnailImageUrl) ? Model.ThumbnailImageUrl : "")" class="img-responsive" />

                            @{ Html.EnableClientValidation(true);}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- /.box-body -->
        <div class="box-footer">
            <input type="submit" class="btn btn-themyriad btnSave" value="Save">
        </div>
    }
</div>

@section scripts
{
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <!-- Select2 -->
    <script src="~/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>

    <script>
        $(function () {

            $('.select2').select2()
        })

    </script>
    <script>

        $(function () {
            function readURL(input) {
                $('#thumbUpload').attr('src', '');
                if (input.files && input.files[0]) {
                    var size = input.files[0].size / 1024 / 1024;
                    if (size > 1) {
                        $('#fileSizeMessage').modal('show');
                        $("#ThumbnailImage").val(null);
                        return;
                    }
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#thumbUpload').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            };
            $("#ThumbnailImage").change(function () {
                readURL(this);
            });

            $("#thumbUpload").click(function () {
                $("input[id='ThumbnailImage']").click();
            });
        });

    </script>

}

