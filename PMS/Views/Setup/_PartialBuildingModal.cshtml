
@model PMS.DTO.ViewModels.SetupViewModels.AddBuildingVM

@using (Ajax.BeginForm("AddBuilding", "Setup", new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "modalFormSuccess",
    OnFailure = "modalFormFailure",
    OnBegin = "$('#loader').show();",
    OnComplete = "$('#loader').fadeOut('slow');"
}))
{
    @Html.AntiForgeryToken();
    @Html.HiddenFor(x => x.BuildingID)
    @Html.HiddenFor(x => x.ProjectID)

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Add/Update Building</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>

                    @Html.TextBoxFor(x => x.BuildingName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.BuildingName)

                </div>
                @*<div class="form-group">
                    <label>Allocated Gender</label>

                    @Html.DropDownListFor(model => model.BuildingGender,
    new SelectList(PMS.Common.Globals.Genders, "", ""),
    "-- Building Gender --",
    new { @Class = "form-control" })

                    @Html.ValidationMessageFor(x => x.BuildingGender)

                </div>*@
                <div class="form-group">
                    <label>Description</label>

                    @Html.TextAreaFor(x => x.BuildingDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })

                    @Html.ValidationMessageFor(x => x.BuildingDescription)

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-themyriad">Save</button>
            </div>
        </div>
    </div>
}