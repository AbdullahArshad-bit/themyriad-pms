
@model PMS.DTO.ViewModels.SetupViewModels.AddRoomVM

@using (Ajax.BeginForm("AddRoom", "Setup", new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "modalFormSuccess",
    OnFailure = "modalFormFailure",
    OnBegin = "$('#loader').show();",
    OnComplete = "$('#loader').fadeOut('slow');"
}))
{
    @Html.AntiForgeryToken();
    @Html.HiddenFor(x => x.RoomID)
    @Html.HiddenFor(x => x.FloorID)

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Add/Update Room</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>

                    @Html.TextBoxFor(x => x.RoomName, new { @class = "form-control", placeholder = "Enter Name" })

                    @Html.ValidationMessageFor(x => x.RoomName)

                </div>
                <div class="form-group">
                    <label>Room Type</label>

                    @Html.DropDownListFor(model => model.RoomTypeID,
    new SelectList(Model.RoomTypeList, "RoomTypeID", "RoomName"),
    "-- Room Type --",
    new { @Class = "form-control" })

                    @Html.ValidationMessageFor(x => x.RoomTypeID)

                </div>
                <div class="form-group">
                        <label>Allocated Gender</label>

                        @Html.DropDownListFor(model => model.RoomGender,
        new SelectList(PMS.Common.Globals.Genders, "", ""),
        "-- Building Gender --",
        new { @Class = "form-control" })

                        @Html.ValidationMessageFor(x => x.RoomGender)

                    </div>
                <div class="form-group">
                    <label>Size</label>

                    @Html.TextBoxFor(x => x.RoomSize, new { @class = "form-control", placeholder = "Enter Size" })

                    @Html.ValidationMessageFor(x => x.RoomSize)

                </div>
                <div class="form-group">
                    <label>Room LockId</label>

                    @Html.TextBoxFor(x => x.RoomLockId, new { @class = "form-control", placeholder = "Enter Room LockId" })


                </div>
                <div class="form-group">
                    <label>Description</label>

                    @Html.TextAreaFor(x => x.RoomDescription, new { @class = "form-control", placeholder = "Enter Description", style = "min-height:125px" })

                    @Html.ValidationMessageFor(x => x.RoomDescription)

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-themyriad">Save</button>
            </div>
        </div>
    </div>
}