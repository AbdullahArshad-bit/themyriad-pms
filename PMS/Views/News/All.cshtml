@using PMS.Common.Classes

@{
    ViewBag.Header = "News";
    ViewBag.HeaderDescription = "All News";
    ViewBag.Title = "All News | PMS";
}


@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <!-- /.box-header -->
        <div class="box-body">

            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            @if (User.IsInRole(AppUserRoles.add_news))
            {
                <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                    <div class="input-group-btn">
                        <a href="@Url.Action("News", "News")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New</a>
                    </div>
                </div>
            }
            @*<div class="col-sm-12 " style="margin-bottom:50px ; padding:0px;">
                    <div class=" col-sm-3" style="padding:0px">
                        <a href="@Url.Action("News", "News")" class="btn btn-block btn-themyriad btn-lg">Add New</a>

                    </div>
                    <div class=" col-sm-11"> </div>
                </div>*@


            <div style="overflow: auto; width:100%">

                <table id="example1" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th style="display:none"></th>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Heading</th>
                            <th>Headline</th>
                            <th>Status</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var news in (ViewBag.News as List<PMS.DTO.ViewModels.NewsViewModels.AllNewsVM>).OrderByDescending(x => x.NewsDate))
                        {
                            <tr>
                                <td style="display:none">@news.NewsDate.ToString("yyyyMMdd")</td>
                                <td>@news.NewsDate.ToString("dd/MMMM/yyyy")</td>
                                <td>@news.NewsCategory</td>
                                <td>@news.Heading</td>
                                <td>@news.Headline</td>
                                <td>@((news.IsActive == true) ? Html.Raw("<span class='label label-success'>Active</span>") : Html.Raw("<span class='label label-danger'>Not Active</span>"))</td>
                                <td class="menu-icons">
                                    @if (User.IsInRole(AppUserRoles.add_news))
                                    {
                                        <a title="Edit" href="@Url.Action("News", "News", new { id = news.NewsID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.view_news_detail))
                                    {
                                        <a title="Details" href="@Url.Action("NewsDetail", "News", new { id = news.NewsID })"><i class="fa fa-newspaper-o"></i></a>
                                    }


                                </td>

                            </tr>
                        }





                    </tbody>
                    <tfoot>
                        <tr>
                            <th style="display:none"></th>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Heading</th>
                            <th>Headline</th>
                            <th>Status</th>
                            <th>Action</th>

                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
        <!-- /.box-body -->
    </div>
    <!-- /.box -->
</div>


<!-- /.card -->

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#example1').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
                "order": [[0, "desc"]], //or asc
                //"columnDefs": [{ "targets": 0, "type": "date-eu" }]
                columnDefs: [
                    { orderable: false, targets: -1 }
                ]
            });
            $('#example2').DataTable({
                'paging': true,
                'lengthChange': false,
                'searching': false,
                'ordering': true,
                'info': true,
                'autoWidth': false
            })
        })
    </script>
}
