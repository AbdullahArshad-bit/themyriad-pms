<div class="modal fade statsModal" id="housingStatsModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content">
            <div class="modal-body" style="max-height: 700px; overflow-y: auto;">

                <div class="row">
                    <br />
                    <h4 class="modal-title" style="color: white; background-color: #c20e1a; text-align: center;">ACCOMODATION</h4>
                    <br />

                    <div class="col-md-6">
                        <h5 style="text-align: center; font-weight: bold;">In House Today</h5>
                        <table class="table table-striped table-bordered table-hover order-lines" id="InHouseTodayTbl">
                            <thead>
                                <tr>
                                    <th>Building</th>
                                    <th>RoomType</th>
                                    <th>Total Rooms</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <div class="col-md-6">
                        <h5 style="text-align: center; font-weight: bold;">Vacancy by Building</h5>
                        <table class="table table-striped table-bordered table-hover order-lines" id="VacancyTbl">
                            <thead>
                                <tr>
                                    <th>Building</th>
                                    <th>RoomType</th>
                                    <th>Total Rooms</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div class="row">

                    <br />

                    <div class="col-md-6">
                        <h5 style="text-align: center; font-weight: bold;">Closures by Building</h5>
                        <table class="table table-striped table-bordered table-hover order-lines" id="Closurestbl">
                            <thead>
                                <tr>
                                    <th>Building</th>
                                    <th>RoomType</th>
                                    <th>Total Rooms</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <div class="col-md-6">
                        <h5 style="text-align: center; font-weight: bold;">Vacancy by Room Type</h5>
                        <table class="table table-striped table-bordered table-hover order-lines" id="VacancyRoomtbl">
                            <thead>
                                <tr>
                                    <th>Room Name</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div class="row">

                    <br />
                    <h4 class="modal-title" style="color: white; background-color: #c20e1a; text-align: center;">HAPPENING TODAY</h4>
