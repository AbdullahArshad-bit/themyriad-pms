@model PMS.DTO.ViewModels.DashboardViewModel.Dashboard
@using PMS.DTO.ViewModels.DashboardViewModel
@using PMS.Common.Classes

@{
    ViewBag.Title = "Dashboard | PMS";
    ViewBag.HeaderDescription = "";
    var PendingFee = ViewBag.PendingFee as List<PendingFeeAssesment>;
    var unpaidinvoice = ViewBag.unpaidinvoice as List<unpaidInvoice>;

    var contractsColClass = Model.LocationId == (int)Enumeration.LocationEnum.Muscat ? "col-lg-6 col-6" : "col-lg-3 col-6";


}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}

<style>
    .box-hover:hover {
        background-color: lightgrey;
    }

    .well {
        background-color: transparent !important;
    }

    .info-box-number {
        font-size: 25px;
    }

    @@media screen and (max-width: 992px) {
        .well {
            width: 100%;
            height: 100%;
        }
    }

    @@media (min-width: 768px) {
        .modal-dialog {
            width: 65% !important;
        }
    }

    .statsModal .modal-content {
        width: auto;
    }

    .info-box-icon {
        background-color: transparent;
    }

    .info-box-content {
        padding: 16px 0px !important;
        margin-left: 80px !important;
    }

    .info-box-icon {
        width: 70px !important;
    }

    .info-box-text {
        font-size: 11px !important;
    }
</style>

@if (!string.IsNullOrEmpty(ViewBag.ShowMessage) && !string.IsNullOrEmpty(ViewBag.MessageType))
{
    if (ViewBag.MessageType.Equals("success", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
            <h4><i class="icon fa fa-check"></i> Alert!</h4>
            @ViewBag.ShowMessage
        </div>
    }

    else
    {
        <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
            <h4><i class="icon fa fa-ban"></i> Alert!</h4>
            @ViewBag.ShowMessage
        </div>
    }
}

<section class="content">

    <div class="col-lg-12 col-12 panel">
        <div class="progress-group">
            <div class="text">
                <h3>
                    Occupied Bed Spaces
                    <span class="float-right"><b style="color: #c20e1a">@Model.TotalBedSpaceOccupied</b>/<b style="color: #4f4f4f">@Model.TotalBedSpaces</b></span>
                </h3>
            </div>
            <div class="progress progress-lg">
                <div class="progress-bar bg-success" style="width: @Model.TotalBedSpaceOccupancyPercent%; background-color:#c20e1a"></div>
            </div>
        </div>
    </div>
    <br />

    <input id="rate" value="@Model.TotalBedSpaceOccupancyPercent" hidden />

    <div class="col-lg-12 col-12 panel">
        <div id="chartContainer" style="text-decoration: none;height: 370px; width: 100%;"></div>
    </div>

    <br />
    <br />
