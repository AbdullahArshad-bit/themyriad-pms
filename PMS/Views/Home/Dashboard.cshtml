    <div class="col-lg-3 col-6">
        <div class="small-box bg-info" style="text-decoration: none; background-color: #4f4f4f !important ">
            <div class="inner" style="color:white!important">
                <h3 style="font-size:45px !important"> @Model.ToBeCheckedinToday</h3>
                <p>Today's Check In(s) <b> Pending</b></p>
            </div>
            <a style="cursor: pointer; color: white " onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="TodayCheckinpending"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger" style="text-decoration: none; background-color: #c20e1a !important ">
            <div class="inner" style="color:white!important">
                <h3 style="font-size:45px !important"> @Model.TodaysCheckedIn</h3>
                <p>Today's Check In(s)  <b>Completed</b></p>
            </div>
            <a style="cursor: pointer; color: white" onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="TodayCheck"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-info" style="text-decoration: none; background-color: #4f4f4f !important ">
            <div class="inner" style="color:white!important">
                <h3 style="font-size:45px !important"> @Model.ToBeCheckedOutToday</h3>
                <p>Today's Check Out(s) <b>Pending</b></p>
            </div>
            <a style="cursor:pointer; color:white" onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="TodayCheckoutpending" })'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger" style="text-decoration: none; background-color: #c20e1a !important ">
            <div class="inner" style="color:white!important">
                <h3 style="font-size:45px !important"> @Model.TodaysCheckedOut</h3>
                <p>Today's Check Out(s) <b>Completed</b></p>
            </div>
            <a style="cursor: pointer;color: white" onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="TodayCheckOut"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>



    <div class="@contractsColClass">
        <div class="small-box bg-danger" style="text-decoration: none; background-color: white !important ">
            <div class="inner" style="color: #c20e1a !important ">
                <h3 style="font-size:45px !important"> @Model.BookingsNotAssignedPlacement</h3>
                <p>Pending  <b>Bookings</b></p>
            </div>
            <a style="cursor: pointer; color: #c20e1a " onclick="window.location.href='@Url.Action("BookingList", "Booking", new { queryby ="PlacementNotAssigned"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>
    @if (Model.LocationId != (int)Enumeration.LocationEnum.Muscat)
    {
        <div class="@contractsColClass">
            <div class="small-box bg-danger" style="text-decoration: none; background-color: white !important ">
                <div class="inner" style="color: #c20e1a !important ">
                    <h3 style="font-size:45px !important"> @Model.ContractsToBeSigned</h3>
                    <p>Contracts <b>to be signed</b></p>
                </div>
                <a style="cursor: pointer; color: #c20e1a" onclick="window.location.href='@Url.Action("Contractsigned", "ContractsManage", new { Issigned=false})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
            </div>
        </div>


        <div class="@contractsColClass">
            <div class="small-box bg-danger" style="text-decoration: none; background-color: white !important ">
                <div class="inner" style="color: #c20e1a !important ">
                    <h3 style="font-size:45px !important"> @Model.ContractsToBeGenerated</h3>
                    <p>Contracts <b>to be generated</b></p>
                </div>
                <a style="cursor: pointer; color: #c20e1a " onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="NoContract"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>

            </div>
        </div>
    }

    <div class="@contractsColClass">
        <div class="small-box bg-danger" style="text-decoration: none; background-color: white !important ">
            <div class="inner" style="color: #c20e1a !important ">
                <h3 style="font-size:45px !important"> @Model.ReservedButNotCheckedin</h3>
                <p>Waiting <b>for checkin</b></p>
            </div>
            <a style="cursor: pointer; color: #c20e1a " onclick="window.location.href='@Url.Action("PlacementsList", "BedSpacePlacement", new { queryby="NotCheckedIn"})'" class="small-box-footer">More info <i class="fa fa-arrow-circle-right" style="font-size:15px"></i></a>
        </div>
    </div>

</section>

