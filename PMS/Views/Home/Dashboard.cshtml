@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://canvasjs.com/assets/script/canvasjs.min.js"></script>

    <script>

        $(document).ready(function () {
            $('#FeeAssessment').DataTable({
                "pageLength": 5,
                dom: 'Bfrtip',
                buttons: [
                    'excelHtml5',
                ]
            });

        });

        $(document).ready(function () {
            $('#UnpaidInvoice').DataTable({
                "pageLength": 5,
                dom: 'Bfrtip',
                buttons: [
                    'excelHtml5',
                ]
            });

        });

        function OpenConfirmPostModal() {
            $('#QuickBooksConfirm').modal('show');
        }

        function OpenConfirmPostZohoModal() {
            $('#ZohoBooksConfirm').modal('show');
        }
        function OpenConfirmPostScienerModal() {
            $('#ScienerAppConfirm').modal('show');
        }

    </script>

    <script type="text/javascript">

        window.onload = function () {
            var rate = $("#rate").val();
            var Remaining = 100 - rate;
            var chart = new CanvasJS.Chart("chartContainer", {

                animationEnabled: true,
                legend: {
                    verticalAlign: "center",
                    horizontalAlign: "left",
                    fontSize: 20,
                    fontFamily: "Helvetica"
                },
                theme: "light2",
                data: [
                    {
                        type: "pie",
                        indexLabelFontFamily: "Garamond",
                        indexLabelFontSize: 20,
                        indexLabel: "{label} {y}%",
                        startAngle: -20,
                        showInLegend: true,
                        toolTipContent: "{legendText} {y}%",
                        dataPoints: [
                            { y: Remaining, color: "#4f4f4f", legendText: "Available", label: "Available" },
                            { y: rate, color: "#c20e1a", legendText: "Occupied", label: "Occupied" },

                        ]
                    }
                ]
            });
            chart.render();
        };

    </script>

    <script>

        var dataTable1;
        var dataTable2;
        var dataTable3;
        var dataTable4;
        var dataTable5;
        var dataTable6;

        // Handle the button click event
        function openModal() {

            // Make an AJAX request to your server to get the data
            $.ajax({
                type: "Get",
                url: "/Home/GetBuildingData",
                async: true,
                success: function (response) {
                    updateAccommodationTables(response);
                    updateHappeningTodayTables(response);
                },
                failure: function (response) {
                    $(".loader").hide();
                    alert(response.d);
                },
                error: function (response) {
                    $(".loader").hide();
                    alert(response.d);
                }
            });
        }

        function updateAccommodationTables(responseData) {

            if (dataTable1) {
                dataTable1.destroy();
            }
            if (dataTable2) {
                dataTable2.destroy();
            }
            if (dataTable3) {
                dataTable3.destroy();
            }
            if (dataTable4) {
                dataTable4.destroy();
            }

            dataTable1 = $('#InHouseTodayTbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            dataTable2 = $('#VacancyTbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            dataTable3 = $('#Closurestbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            dataTable4 = $('#VacancyRoomtbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            populateTable(dataTable1, responseData.InHouseTodayData);
            populateTable(dataTable2, responseData.VacancyData);
            populateTable(dataTable3, responseData.ClosuresData);
            populateTable(dataTable4, responseData.VacancyRoomData);

            $('#housingStatsModal').modal('show');
        }

        function updateHappeningTodayTables(responseData) {

            if (dataTable5) {
                dataTable5.destroy();
            }
            if (dataTable6) {
                dataTable6.destroy();
            }

            dataTable5 = $('#CheckInsTbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            dataTable6 = $('#CheckOutsTbl').DataTable({
                "paging": false,
                "searching": false,
                "lengthChange": false,
                "info": false,
                "autoWidth": false,
                "responsive": true
            });

            populateTable(dataTable5, responseData.CheckInsData);
            populateTable(dataTable6, responseData.CheckOutsData);
        }

        function populateTable(table, data) {

            table.clear().draw();
            data.forEach(function (row) {
                var newRow = $('<tr>');

                $.each(row, function (index, value) {
                    newRow.append('<td>' + value + '</td>');
                });
                table.row.add(newRow);
            });
            table.draw();
        }

    </script>

}
