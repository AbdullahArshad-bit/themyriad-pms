<!-- /Quick Books Modal-->

<div class="modal" id="QuickBooksConfirm">
    <form method="post" action="@Url.Action("ApiCallService", "Home")">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4 class="modal-title" id="myModalLabel">Confirm post entries</h4>
                </div>

                <div class="modal-body">
                    <p>You are about to post journal entries in QuickBooks. This process is irreversible.</p>
                    <p> Are you sure?</p>
                    <p class="debug-url"></p>
                    <input type="hidden" name="id" id="ids" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-themyriad btn-ok" type="submit"> Yes</button>
                </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
    </form>
</div>

<!-- /Zoho Books Modal-->

