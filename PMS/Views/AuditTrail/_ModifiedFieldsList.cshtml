@{
    var model = ViewBag.AuditDetails as List<PMS.EF.AuditLogDetail>;

    var routecontrol = ViewBag.RouteControl as PMS.EF.CorrespondenceAction;
}
<div class="modal-dialog modal-lg">
    <div class="modal-content">

        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h4 class="modal-title" id="myModalLabel">Modified Fields</h4>
        </div>

        <div class="modal-body" style="max-height:70vh; overflow-y:auto;">
            @if (routecontrol.Controller != null)
            {
                <a href="@Url.Action(routecontrol.Action , routecontrol.Controller , new { id = ViewBag.PrimaryKey })" class="btn btn-primary" title="View Entity" target="_blank">View Entity</a>

            }
            <div style="overflow: auto; width:100%">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Field Name</th>
                            <th>Old Value</th>
                            <th>New Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in model)
                        {
                            <tr>
                                <td>@detail.PropertyName</td>
                                <td>@detail.OldValue</td>
                                <td>@detail.NewValue</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-themyriad" data-dismiss="modal" style="min-width:80px">OK</button>
        </div>
    </div>
</div>




