
@using PMS.Common.Classes

@{
    ViewBag.Header = "Placements";
    ViewBag.HeaderDescription = "Import from excel";
    ViewBag.Title = "Import from excel | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    <a href="@Url.Action("PlacementsList", "BedSpacePlacement")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> All Placements List</a>
                </div>
            </div>

            <div style="overflow: auto; width:100%">

                <table id="placement-table" class="table table-bordered table-striped">

                    <thead>

                        <tr>
                            <th>Status</th>
                            <th>BedSpaceID</th>
                            <th>Booking Number</th>
                            <th>Bed Name</th>
                            <th>Move in</th>
                            <th>Move Out</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var placement in ViewBag.SavedPlacements as List<PMS.DTO.ViewModels.BedSpacePlacementViewModels.AddBedSpacePlacementVM>)
                        {
                            <tr>
                                <td><span class='label label-success'>Success</span></td>
                                <td>@placement.BedSpaceID</td>
                                <td>@placement.BookingNumber</td>
                                <td>@placement.BedName</td>
                                <td>@(placement.MoveIn == null ? "" : ((DateTime)placement.MoveIn).ToString("dd/MM/yyy"))</td>

                                <td>@(placement.MoveOut == null ? "" : ((DateTime)placement.MoveOut).ToString("dd/MM/yyy"))</td>

                            </tr>
                        }

                        @foreach (var placement in ViewBag.NotSavedPlacements as List<PMS.DTO.ViewModels.BedSpacePlacementViewModels.AddBedSpacePlacementVM>)
                        {
                            <tr>
                                <td><span class='label label-danger'>Failed</span></td>
                                <td>@placement.BedSpaceID</td>
                                <td>@placement.BookingNumber</td>
                                <td>@placement.BedName</td>
                                <td>@(placement.MoveIn == null ? "" : ((DateTime)placement.MoveIn).ToString("dd/MM/yyy"))</td>

                                <td>@(placement.MoveOut == null ? "" : ((DateTime)placement.MoveOut).ToString("dd/MM/yyy"))</td>

                            </tr>
                        }



                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Status</th>
                            <th>BedSpaceID</th>
                            <th>Booking Number</th>
                            <th>Bed Name</th>
                            <th>Move in</th>
                            <th>Move Out</th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
    </div>
</div>


@section scripts{

    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('#placement-table').DataTable({});
        })


    </script>
}
