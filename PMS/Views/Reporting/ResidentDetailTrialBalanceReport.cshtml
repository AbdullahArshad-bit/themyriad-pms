﻿@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ResidentDetailTrialBalanceVM>
@using PMS.Common.Classes


@{ ViewBag.Header = "Resident Detail Trial Balance Report";
    ViewBag.HeaderDescription = "Resident Detail Trial Balance Report";
    ViewBag.Title = "Resident Detail Trial Balance Report | PMS"; }
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/css/bootstrap-multiselect.css">
}
<style>
    .right {
        text-align: right;
    }
</style>
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="row">
            <div class="col-md-2">
                <label>From Date</label>
                <input name="daterange" type="text" autocomplete="off" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
            </div>
            <div class="col-md-2">
                <label>To Date</label>
                <input name="daterange" type="text" autocomplete="off" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
            </div>
            <div class="col-md-3">
                <label>Student</label>
                @Html.DropDownList("StudentId", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
            </div>
            <div class="col-md-1">
                <label> &nbsp; </label>
                <br />
                <button type="button" onclick="GetResidentDetailTrialReport();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
            </div>
            <div class="col-md-2">
                <label> &nbsp; </label>
                <br />
                <button type="button" onclick="GetExcel()" class="btn btn-themyriad btn-bordered waves-effect w-md"> <i class="fa fa-download"> </i> <span> Export Report </span> </button>
            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div class="box-body">
            <div class="row">
                <div class="row" style="margin-bottom:30px">
                    <div class="col-md-3">
                        <label>Search By Column:</label>
                        <select class="form-control" id="column-filter">
                            <option value="">All Columns</option>
                            <option value="MyriadID">MyriadID</option>
                            <option value="Name">Name</option>
                            <option value="RoomNo">Room No</option>
                            <option value="BedSpace">Bed Space</option>
                            <option value="InvoiceCode">Invoice Id</option>
                            <option value="TypeOfReceipt">Type Of Receipt</option>
                            <option value="ReceiptNumber">Receipt Number</option>

                        </select>
                    </div>
                    <div class="col-md-3" style="width: 200px;">
                        <label>Column Visibilty:</label>
                        <select multiple class="form-control" id="columnvisibilty-filter">
                            <option value="MyriadID">MyriadID</option>
                            <option value="Name">Name</option>
                            <option value="RoomNo">Room No</option>
                            <option value="BedSpace">Bed Space</option>
                            <option value="TypeOfInvoice">Type of Invoice</option>
                            <option value="InvoiceCode">Invoice Id</option>
                            <option value="InvoiceDate">Invoice Date</option>
                            <option value="InvoiceAmount">Invoice Amount</option>
                            <option value="FromDate">From Date</option>
                            <option value="ToDate">To Date</option>
                            <option value="TypeofReceipt">Type of Receipt</option>
                            <option value="ReceiptNumber">Receipt Number</option>
                            <option value="DateOfReceipt">Date of Receipt</option>
                            <option value="AmountReceived">Amount Received</option>
                            <option value="BalanceReceivable">Balance receivable</option>
                            <option value="AgingInDays">Aging of Balance in Days</option>
                        </select>
                    </div>
                </div>

                <table class="table table-bordered table-striped data-table" id="ResidentDetailTrialBalanceTable">
                    <thead>
                        <tr>
                            <th>MyriadID</th>
                            <th>Name</th>
                            <th>Room No.</th>
                            <th>Bed Space</th>
                            <th>Type of Invoice</th>
                            <th>Invoice Id</th>
                            <th>Invoice Date</th>
                            <th>Invoice Amount</th>
                            <th>From Date</th>
                            <th>To Date</th>
                            <th>Type of Receipt</th>
                            <th>Receipt Number</th>
                            <th>Date of Receipt</th>
                            <th>Amount Received</th>
                            <th>Balance receivable</th>
                            <th>Aging of Balance in Days</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>


@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/js/bootstrap-multiselect.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>

        var dataTable;

        $(document).ready(function () {
            $('#columnvisibilty-filter').multiselect({

                nonSelectedText: 'Select columns to hide',
                maxHeight: 100,
                onChange: function (element, checked) {

                    GetResidentDetailTrialReport();
                },
            });
            GetResidentDetailTrialReport();
        });

        function GetResidentDetailTrialReport() {

            loadResideentDetailTable();
        };

        function loadResideentDetailTable() {
            ShowLoader();
            if (dataTable) {
                dataTable.destroy();
            }
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var urlParams = new URLSearchParams(window.location.search);
            var query = urlParams.get('queryby');
            var StudentId = $('#StudentId').val();
            var isSummaryReport = true;
            var selectedColumns = $('#columnvisibilty-filter').val();
            var columns = [];
            if (selectedColumns) {
                selectedColumns.forEach(function (columnName) {
                    var columnDef = {
                        "data": columnName
                    };
                    columns.push(columnDef);
                });
            }
            dataTable = $('#ResidentDetailTrialBalanceTable').DataTable({
                processing: false,
                serverSide: true,
                filter: true,
                paging: true,
                searching: true,
                lengthChange: true,
                scrollCollapse: true,
                scrollY: '70vh',
                scrollX: true,
                scroller: true,
                ordering: true,
                info: true,
                iDisplayLength: 100,
                autoWidth: true,
                responsive: true,
                columns: columns,
                language: {
                    emptyTable: "No record found."
                },
                "ajax": {
                    "url": "/Reporting/loadResidentDetailTrialBalancebyAjax",
                    "type": "POST",
                    "data": function (d) {
                        d.FromDate = SD;
                        d.ToDate = ED;
                        d.StudentId = StudentId;
                        d.query = query;
                        d.isSummaryReport = isSummaryReport;
                        d.SelectedColumns = selectedColumns;
                        var selectedColumn = $('#column-filter').val();
                        if (selectedColumn) {
                            d.search = {
                                value: $('#ResidentDetailTrialBalanceTable_filter input').val(), // Include the search query
                                column: selectedColumn // Include the selected column
                            };
                        }
                        else {
                            d.search
                        }
                        var columnIndex = d.order[0].column;

                        if (columnIndex === 0) {
                            d.orderBy = d.order[0].column;
                            d.orderDir = d.order[0].dir;
                        }
                        else {
                            var columnName = d.columns[columnIndex].data;
                            d.orderBy = columnName;
                            d.orderDir = d.order[0].dir;
                        }
                    },
                    "datatype": "json",
                    beforeSend: function () {
                        ShowLoader(); // Show loader before AJAX request
                    },
                    complete: function () {
                        HideLoader(); // Hide loader after AJAX request
                    },
                    error: function (xhr, error, thrown) {
                        console.error('AJAX error:', error, thrown);
                        HideLoader();
                    }
                },
                columns: [

                    { "data": "MyriadID", visible: !selectedColumns.includes("MyriadID") },
                    { "data": "Name", visible: !selectedColumns.includes("Name") },
                    { "data": "RoomNo", visible: !selectedColumns.includes("RoomNo") },
                    { "data": "BedSpace", visible: !selectedColumns.includes("BedSpace") },
                    { "data": "TypeOfInvoice", visible: !selectedColumns.includes("TypeOfInvoice") },
                    { "data": "InvoiceCode", visible: !selectedColumns.includes("InvoiceCode") },
                    {
                        "data": "InvoiceDate",
                        visible: !selectedColumns.includes("InvoiceDate"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.InvoiceDate) + '</span>'
                        },
                    },
                    {
                        "data": "InvoiceAmount",
                        visible: !selectedColumns.includes("InvoiceAmount"),
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            if (full.InvoiceAmount == null) {
                                return ``
                            }
                            else {
                                return '<span>' + parseFloat(full.InvoiceAmount).toFixed(2) + '</span>'
                            }
                        },
                    },
                    {
                        "data": "FromDate",
                        visible: !selectedColumns.includes("FromDate"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.FromDate) + '</span>'
                        },
                    },
                    {
                        "data": "ToDate",
                        visible: !selectedColumns.includes("ToDate"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.ToDate) + '</span>'
                        },
                    },
                    { "data": "TypeOfReceipt", visible: !selectedColumns.includes("TypeOfReceipt") },
                    { "data": "ReceiptNumber", visible: !selectedColumns.includes("ReceiptNumber") },
                    {
                        "data": "DateOfReceipt",
                        visible: !selectedColumns.includes("DateOfReceipt"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.DateOfReceipt) + '</span>'
                        },
                    },
                    {
                        "data": "AmountReceived",
                        visible: !selectedColumns.includes("AmountReceived"),
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            if (full.AmountReceived == null) {
                                return ``
                            }
                            else {
                                return '<span>' + parseFloat(full.AmountReceived).toFixed(2) + '</span>'
                            }
                        },
                    },
                    {
                        "data": "BalanceReceivable",
                        visible: !selectedColumns.includes("BalanceReceivable"),
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            if (full.BalanceReceivable == null) {
                                return ``
                            }
                            else {
                                return '<span>' + parseFloat(full.BalanceReceivable).toFixed(2) + '</span>'
                            }
                        },
                    },
                    { "data": "AgingInDays", visible: !selectedColumns.includes("AgingInDays") },
                ],

                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };

                    // Total over for column "InvoiceAmount" all pages
                    total = api
                        .column(7)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over for column "InvoiceAmount" this page
                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update for column "InvoiceAmount" footer
                    $(api.column(7).footer()).html(
                        pageTotal.toFixed(2)
                    );

                    // Total over for column "AmountReceived" all pages
                    total = api
                        .column(13)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over for column "AmountReceived" this page
                    pageTotal = api
                        .column(13, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update for column "AmountReceived" footer
                    $(api.column(13).footer()).html(
                        pageTotal.toFixed(2)
                    );

                    // Total over for column "BalanceReceivable" all pages
                    total = api
                        .column(14)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over for column "BalanceReceivable" this page
                    pageTotal = api
                        .column(14, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update for column "BalanceReceivable" footer
                    $(api.column(14).footer()).html(
                        pageTotal.toFixed(2)
                    );
                },
            });

        };

        function dateformate(date) {
            if (date == '' || date == null) {
                return '';
            } else {
                let d = new Date(parseInt(date.substr(6))); //parse json datetime to datetime
                let _month = (d.getMonth() + 1).toString().padStart(2, "0");
                let _date = d.getDate() + "/" + _month + "/" + d.getFullYear();

                return _date;
            }
        }

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });


        function Print() {
            var ED = $('.to_date').val();

            window.open("/Reporting/GetResidentTrialBalanceDetailPDFReport?ToDate=" + ED, '_blank');
        }
        function GetExcel() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();

            var url = "/Reporting/ExportResidentDetailTrialBalanceReport?FromDate=" + SD + "&ToDate=" + ED + "&StudentId=" + StudentId;

            window.location.href = url;
        }


    </script>

}