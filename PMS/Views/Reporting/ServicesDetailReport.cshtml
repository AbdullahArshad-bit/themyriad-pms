@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ServicesDetailVM>

@{
    ViewBag.Header = "Services Detail Report";
    ViewBag.HeaderDescription = "Services Detail Report";
    ViewBag.Title = "Services Detail Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    div.container {
        max-width: 1200px;
    }
    .right{
        text-align:right;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }



        </div>
        <div class="">
            <div class="">
                <div class="col-md-2">
                    <label>From Date</label>
                    <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
                </div>
                <div class="col-md-3">
                    <label>Student</label>
                    @Html.DropDownList("StudentId", null, "-- All Students --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                </div>

                <div class="col-md-2">
                    <label>Service</label>
                    @Html.DropDownList("serviceid", null, "-- All Services --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Terms</label>
                        @Html.DropDownList("TermID", null, "-- All Terms --", new { @Class = "form-control select2", id = "TermID" })
                    </div>
                </div>

                <div class="col-md-3">
                    <label>Type</label>
                    <select class="select2" name="Type" id="type">
                        <option value="0" @(ViewBag.Type == 0 ? "selected" : "")>All</option>
                        <option value="1" @(ViewBag.Type == 1 ? "selected" : "")>Created By</option>
                        <option value="2" @(ViewBag.Type == 2 ? "selected" : "")>Approved By</option>
                    </select>
                </div>
                <div class="col-md-3" style="display:none;" id="UserDiv" >
                    <label>User</label>
                    @Html.DropDownList("userid", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                </div>
                <div class="col-md-1">
                    <label> &nbsp; </label>
                    <br />
                    <button type="button" onclick="GetServicesLedger();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                </div>
            </div>
            <br />

        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="persons-table" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>Transaction Code</th>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Service Type</th>
                            <th>Transaction Date</th>
                            <th>Remarks</th>
                            <th>Vat</th>
                            <th>Service Price</th>
                            <th>From Date</th>
                            <th>To Date</th>
                            <th>Created By</th>
                            <th>Approved By</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                        <tr>
                            <td>
                                @item.LocationName
                            </td>
                            <td>@item.code</td>
                            <td>@item.MyriadID</td>
                            <td>@item.FullName</td>
                            <td>
                                @item.ServiceName
                            </td>


                            <td>@item.InvoiceDate</td>

                            <td>@item.Remarks</td>
                            <td class="right">
                                @item.TaxAmount

                            </td>
                            <td class="right">
                                @item.ServicePrice
                            </td>
                            <td>@(item.FromDate!=null?item.FromDate.GetValueOrDefault().ToString("dd/MM/yyyy"):"----")</td>
                            <td>@(item.ToDate!=null?item.ToDate.GetValueOrDefault().ToString("dd/MM/yyyy"):"----")</td>
                            <td>
                                @item.PostedBy

                            </td>
                            <td>
                                @item.ApprovedBy

                            </td>

                        </tr>
                        }

                    </tbody>

                    <tfoot style="width: 100%">
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            @*<th>@ViewBag.TotalAmount</th>*@
                            <th></th>
                            <th></th>
                            <th class="right"></th>
                            <th class="right"></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>

    </div>
</div>

@section scripts{


    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>

    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>

        $(document).ready(function () {
            $('#persons-table').DataTable({
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };

                    // Total over all pages
                    total = api
                        .column(6)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(6, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                        pageTotal.toFixed(2)
                    );

                    total = api
                        .column(7)
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Total over this page
                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                        pageTotal.toFixed(2)
                    );
                },
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                //"iDisplayLength": 100,
                //"pageLength": -1,
               
                "filter": true,
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "order": [[1, 'asc']],
                "info": true,
                "scrollCollapse": true,
                "scrollX": true,
                "scrollY": '70vh',
                "iDisplayLength": 100,
                "autoWidth": true,
                "responsive": true,
                buttons: [
                    'excelHtml5',
                    '<button type="button" onclick="Print()" class="dt-button buttons-excel buttons-html5"><i class="fa fa-download"></i></button>'
                ],
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                columnDefs: [
                    { type: 'date-euro', targets: 4 }
                ]
            });
            $('.dataTables_length').addClass('bs-select');

            var Typevalue = $("#type").val();
            ShowUserDiv(Typevalue);
            $("#type").on('change', function () {
                var value = $(this).val();
                ShowUserDiv(value);

            });
            function ShowUserDiv(value) {

                if (value != 0) {
                    $("#UserDiv").show();
                }
                else {
                    $("#UserDiv").hide();
                    $('#userid').val('').change();
                }
            }
        });

    </script>

    <script type="text/javascript">

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                //startDate.setDate(startDate.getDate(new Date(selected.date.valueOf())));
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetServicesLedger() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var userid = $('#userid').val();
            var ServiceId = $('#serviceid').val();
            var TermID = $('#TermID').val();
            var Type = $('#type').val();
            window.location.href = GetFormatedUrl("/Reporting/ServicesDetailReport?FromDate=" + SD + "&ToDate=" + ED + "&serviceId=" + ServiceId + "&StudentId=" + StudentId + "&TermID=" + TermID + "&userid=" + userid + "&type=" + Type );

        };

        function Print() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var ServiceId = $('#serviceid').val();
            var TermID = $('#TermID').val();
            var Type = $('#type').val();
            window.open("/Reporting/GetServicesDetailPDFReport?FromDate=" + SD + "&ToDate=" + ED + "&serviceId=" + ServiceId + "&StudentId=" + StudentId + "&TermID=" + TermID + "&userid=" + userid + "&type=" + Type , '_blank');
        };


    </script>

}