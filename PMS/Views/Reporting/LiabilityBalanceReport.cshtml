@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.LiabIlityBalanceVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Liability Balance Report";
    ViewBag.HeaderDescription = "Liability Balance Report";
    ViewBag.Title = "Liability Balance Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    /* Match dashboard housingStatsModal sizing and scrolling */
    @@media (min-width: 768px) {
        #detailModal .modal-dialog {
            width: 65% !important;
        }
    }
    #detailModal .modal-content {
        width: auto;
    }
    #detailModal .modal-body {
        max-height: 700px;
        overflow-y: auto;
    }
    /* Keep cells on one line to enable horizontal scroll */
    #DetailLiabilityTable th,
    #DetailLiabilityTable td {
        white-space: nowrap;
    }
    /* Center and enlarge Close button in modal */
    #detailModal .modal-footer {
        text-align: center;
    }
    #detailModal .modal-footer .btn {
        min-width: 250px;
    }
</style>
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="">
                    <div class="col-md-2">
                        <label>From Date</label>
                        <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
                    </div>
                    <div class="col-md-2">
                        <label>To Date</label>
                        <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
                    </div>
                    <div class="col-md-3">
                        <label>Persons</label>
                        @Html.DropDownList("StudentId", null, "-- All Persons --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>
                    <div class="col-md-1">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetBalanceDetail();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                    </div>
                </div>
                <br />

            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="LiabilityTable" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>MyriadID</th>
                            <th>Full Name</th>
                            <th>CheckOut Date</th>
                            <th>Room Type</th>
                            <th>Room Deposit Amount</th>
                            <th>Deposit Amount Collected</th>
                            <th>Deposit Amount Refunded</th>
                            <th>Liability Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                        <tr>
                            <td>@item.LocationName</td>
                            <td><a href="#" class="open-detail" data-student="@item.StudentId">@item.MyriadID</a></td>
                            <td>@item.FullName</td>
                            <td>@item.CheckOutDate</td>
                            <td>@item.RoomType</td>
                            <td>@item.RoomDepositAmount</td>
                            <td>@item.DepositAmountCollected</td>

                            <td>(@Math.Abs(item.DepositAmountRefunded))</td>
                            @{
                                if (item.LiabilityBalance < 0)
                                {

                                    <td class="right">(@Math.Abs(item.LiabilityBalance))</td>
                                }
                                else
                                {

                                    <td class="right">@item.LiabilityBalance</td>
                                }
                            }
                        </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>

    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#LiabilityTable').DataTable({
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "scrollCollapse": true,
                "scrollY": '70vh',
                "scrollX": "auto",
                "iDisplayLength": 100,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5'
                ],
            });
        });

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetBalanceDetail() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            window.location.href = GetFormatedUrl("/Reporting/LiabilityBalanceReport?FromDate=" + SD + "&ToDate=" + ED + "&StudentId=" + StudentId);


        };
        $(document).on('click', '.open-detail', function (e) {
            e.preventDefault();
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var studentId = $(this).data('student');
            $('#detailModal .modal-body').html('<div class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading...</div>');
            $('#detailModal').modal('show');
            $('#detailModal .modal-body').load(GetFormatedUrl('/Reporting/LoadDetailLiabilityBalances?FromDate=' + SD + '&ToDate=' + ED + '&StudentId=' + studentId), function () {
                if ($.fn.dataTable.isDataTable('#DetailLiabilityTable')) {
                    $('#DetailLiabilityTable').DataTable().destroy();
                }
                $('#DetailLiabilityTable').DataTable({
                    paging: true,
                    searching: true,
                    lengthChange: true,
                    ordering: true,
                    scrollX: true,
                    iDisplayLength: 50,
                    info: true,
                    autoWidth: false,
                    responsive: false,
                    width: '100%',
                    dom: 'Blfrtip',
                    buttons: [ 'excelHtml5' ]
                });
                $('#detailModal').on('shown.bs.modal', function () {
                    $('#DetailLiabilityTable').DataTable().columns.adjust().draw();
                });
            });
        });
     
    </script>
}

<div class="modal fade" id="detailModal" tabindex="-1" role="dialog" aria-labelledby="detailModalLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="detailModalLabel">Liability Balance Details</h4>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black waves-effect w-md button-effect" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>