        function loadInvoicesTable() {
            ShowLoader();
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            
            // Destroy existing table if it exists
            if ($.fn.DataTable.isDataTable('#LiabilityTable')) {
                $('#LiabilityTable').DataTable().destroy();
            }
            
            var table = $('#LiabilityTable').DataTable({
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api(), data;

                    // Remove the formatting to get integer data for summation
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };

                    pageTotal = api
                        .column(2, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(2).footer()).html(
                        pageTotal
                    );
                    pageTotal = api
                        .column(4, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(4).footer()).html(
                        pageTotal.toFixed(2)
                    );

                    pageTotal = api
                        .column(6, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(6).footer()).html(
                        pageTotal
                    );

                    pageTotal = api
                        .column(7, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer
                    $(api.column(7).footer()).html(
                        pageTotal
                    );

                },

                serverSide: false,
                destroy: true,
                responsive: true,
                processing: true,
                paging: true,
                async: false,
                "scrollY": "70vh",
                "scrollX": "70vh",
                "scrollCollapse": true,
                "iDisplayLength": 100,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'copyHtml5',
                    'excelHtml5',
                ],
                ajax: {
                    "url": GetFormatedUrl("/Reporting/HistoryForcastReportAjax?FromDate=" + SD + "&ToDate=" + ED),
                    "type": "GET",
                    "datatype": "json",
                    beforeSend: function () {
                        ShowLoader(); // Show loader before AJAX request
                    },
                    complete: function () {
                        HideLoader(); // Hide loader after AJAX request
                    },
                    error: function (xhr, error, thrown) {
                        console.error('AJAX error:', error, thrown);
                        HideLoader();
                    }
                },
                columns: [
                    { "data": "Date" },
                    { "data": "TotalOccupiedBedSpace" },
                    { "data": "ArrivalRoom" },
                    { "data": "OccupancyPercentage" },
                    { "data": "TotalRevenue" },
                    { "data": "AvgBedSpaceRate" },
                    { "data": "DeptBedSpace" },
                    { "data": "NoShowBedSpace" },
                    { "data": "OccupiedAndHeadAdltChildrn" },
                  
                ],

                columnDefs: [
                    {
                        targets: 0,
                        render: function (data, type, full, meta) {
                            if (type === 'sort' || type === 'type' || type === 'filter') {
                                if (!full.Date) {
                                    return '';
                                }
                                return new Date(parseInt(full.Date.substr(6))).getTime();
                            }
                            return '<span>' + dateformate(full.Date) + '</span>';
                        },
                    },

                ],

            });
        };
        function dateformate(date) {
            if (date == '' || date == null) {
                return '';
            } else {
                let d = new Date(parseInt(date.substr(6))); //parse json datetime to datetime
                let _day = d.getDate().toString().padStart(2, "0");
                let _month = (d.getMonth() + 1).toString().padStart(2, "0");
                let _date = _day + "/" + _month + "/" + d.getFullYear();

                return _date;
            }
        }

