@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ResidentTrialBalanceVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Resident Trial Balance Report";
    ViewBag.HeaderDescription = "Resident Trial Balance Report";
    ViewBag.Title = "Resident Trial Balance Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/css/bootstrap-multiselect.css">
}

<style>
    th, td {
        white-space: nowrap;
    }

    .dataTables_scrollFootInner {
        overflow: visible !important;
        padding-right: 0px !important;
    }

    .right {
        text-align: right;
    }

    table.dataTable tfoot th {
        text-align: right;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">

        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>

        <div class="row">
            <div class="col-md-2">
                <label>From Date</label>
                <input name="daterange" type="text" autocomplete="off" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
            </div>
            <div class="col-md-2">
                <label>Date</label>
                <input name="daterange" id="ToDate" autocomplete="off" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
            </div>
            <div class="col-md-2">
                <label>Status of Residents</label>
                <select class="select2" name="CheckOut" id="checkout">
                    <option value="0" @(ViewBag.CheckOut == 0 ? "selected" : "")>All</option>
                    <option value="1" @(ViewBag.CheckOut == 1 ? "selected" : "")>Non Residents</option>
                    <option value="2" @(ViewBag.CheckOut == 2 ? "selected" : "")>Residents</option>
                </select>
            </div>
            <div class="col-md-3">
                <label>Student</label>
                @Html.DropDownList("StudentId", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
            </div>
            <div class="col-md-3">
                <label> &nbsp; </label>
                <br />
                <button type="button" onclick="GetResidentReport();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                <button type="button" onclick="GetExcel()" class="btn btn-success btn-bordered waves-effect w-md button-effect" style="margin-left: 5px;"> <i class="fa fa-download"> </i> <span> Export Report </span> </button>
            </div>
        </div>

        <div class="col-md-12">
            <hr />
        </div>

        <div class="box-body">
            <div class="row">
                <div class="row" style="margin-bottom:30px">
                    <div class="col-md-3">
                        <label>Search By Column:</label>
                        <select class="form-control" id="column-filter">
                            <option value="">All Columns</option>
                            <option value="RoomNo">Room No</option>
                            <option value="BedSpace">Bed Space</option>
                            <option value="MyriadID">MyriadID</option>
                            <option value="Name">Name</option>
                        </select>
                    </div>
                    <div class="col-md-3" style="width: 200px;">
                        <label>Column Visibilty:</label>
                        <select multiple class="form-control" id="columnvisibilty-filter">
                            <option value="RoomNo">Room No</option>
                            <option value="BedSpace">Bed Space</option>
                            <option value="MyriadID">MyriadID</option>
                            <option value="Name">Name</option>
                            <option value="MoveIn">Arr. Date</option>
                            <option value="MoveOut">Dep. Date</option>
                            <option value="CheckIn">CheckIn</option>
                            <option value="CheckOut">CheckOut</option>
                            <option value="OpeningBalance">Opening Balance</option>
                            <option value="DebitAmount">Debit Amount</option>
                            <option value="CreditAmount">Credit Amount</option>
                            <option value="ExclusiveOpeningBalance">Exclusive Opening Balance</option>
                            <option value="LastEntryDate">Last entry date</option>

                        </select>
                    </div>
                </div>
                <table id="ResidentTrialBalanceTable" class="table table-bordered table-striped data-table">
                    <thead>
                        <tr>
                            <th>Room No.</th>
                            <th>Bed Space</th>
                            <th>MyriadID</th>
                            <th>Name</th>
                            <th>Arr. Date</th>
                            <th>Dep. Date</th>
                            <th>CheckIn</th>
                            <th>CheckOut</th>
                            <th>Opening Balance</th>
                            <th>Debit Amount</th>
                            <th>Credit Amount</th>
                            <th>Balance</th>
                            <th>Exclusive Opening Balance</th>
                            <th>Last entry date</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>


@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
