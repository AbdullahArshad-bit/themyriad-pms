            //var grandTotalRow = footer.find('.grand-total-row');

            //if (grandTotalRow.length === 0) {
            //    footer.append('<tr class="grand-total-row"></tr>');
            //    grandTotalRow = footer.find('.grand-total-row');
            //}

            //for (var i = 0; i <= 13; i++) {
            //    var cell = grandTotalRow.find('th[data-column="' + i + '"]');
            //    if (cell.length === 0) {
            //        grandTotalRow.append('<th data-column="' + i + '"></th>');
            //        cell = grandTotalRow.find('th[data-column="' + i + '"]');
            //    }

            //    if (i === 7) {
            //        cell.text("Grand Total");
            //    } else {
