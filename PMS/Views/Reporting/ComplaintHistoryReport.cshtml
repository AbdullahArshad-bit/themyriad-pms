@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ComplaintHistoryVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Complaint Escalation Report";
    ViewBag.HeaderDescription = "Complaint Escalation Report";
    ViewBag.Title = "Complaint Escalation Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>

</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="">
                    <div class="col-md-3">
                        <label>Status</label>
                        @Html.DropDownList("statusId", null, "-- All Statuses --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Created By</label>
                            @Html.DropDownList("createdBy", null, "-- All Created By --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label>Updated By</label>
                        @Html.DropDownList("updatedBy", null, "-- All Upadted By --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>

                    <div class="col-md-1">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetComplaintHistory();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                    </div>
                </div>
                <br />

            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="complaintTable" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>Ticket Code</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Created Date</th>
                            <th>Updated By</th>
                            <th>Updated Date</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                        <tr>
                            <td>@item.LocationName</td>

                            <td>
                                <a target="_blank" href="@Url.Action("Index", "Ticket")">@item.Code</a>
                            </td>
                            <td>@item.Name</td>
                            @{
                                if (item.Status == Enumeration.TicketStatus.Open.ToString())
                                {
                                    <td><span class='label label-primary'>@item.Status</span></td>
                                }
                                else if (item.Status == Enumeration.TicketStatus.Pending.ToString())
                                {
                                    <td><span class='label label-warning'>@item.Status</span></td>
                                }
                                else if (item.Status == Enumeration.TicketStatus.Resolved.ToString())
                                {
                                    <td><span class='label label-success'>@item.Status</span></td>
                                }
                                else if (item.Status == Enumeration.TicketStatus.Closed.ToString())
                                {
                                    <td><span class='label label-danger'>@item.Status</span></td>
                                }
                                else
                                {
                                    <td><span class="label label-danger">@item.Status</span></td>
                                }


                            }
                            <td>@item.CreatedBy</td>
                            <td>@item.CreatedDate</td>
                            <td>@item.UpdatedBy</td>
                            <td>@item.UpdatedDate</td>

                        </tr>
                        }

                    </tbody>
                </table>

            </div>

        </div>

    </div>
</div>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#complaintTable').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        });
        function GetComplaintHistory() {
            var statusId = $('#statusId').val();
            var createdBy = $('#createdBy').val();
            var updatedBy = $('#updatedBy').val();
            window.location.href = GetFormatedUrl("/Reporting/ComplaintHistoryReport?statusId=" + statusId + "&createdBy=" + createdBy + "&updatedBy=" + updatedBy);

        };
    </script>
}