@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.SwappedBedSpacesVM>

@{
    ViewBag.Header = "Swapped Bedspace Report";
    ViewBag.HeaderDescription = "Swapped Bedspace Report";
    ViewBag.Title = "Swapped Bedspace Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    div.container {
        max-width: 1200px;
    }

    .right {
        text-align: right;
    }

    table.dataTable tfoot th {
        text-align: right;
    }
</style>
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="col-md-2">
                    <label>From Date</label>
                    <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
                </div>
                <div class="col-md-3">
                    <label>BedSpace</label>
                    @Html.DropDownList("BedSpaceID", null, "-- All Bed Spaces --", htmlAttributes: new { @class = "form-control select2" })
                    @*@Html.DropDownListFor(model => model.BedSpaceID, new SelectList(Model.BedSpacesList, "Value", "Text"), "-- Bed Space --", new { @Class = "form-control select2", @id = "ddlBedSpaces" })*@

                </div>

                <div class="col-md-1">
                    <label> &nbsp; </label>
                    <br />
                    <button type="button" onclick="GetRoomSwappedDetails();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="SwappedBedSpaceTable" class="table table-bordered table-striped display now" style="width:100%">
                    <thead>
                        <tr>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Old Bed Space</th>
                            <th>New Bed Space</th>
                            <th>Remarks</th>
                            <th>Swapped Date</th>
                            <th>Swapped By</th>
                            <th>MoveIn</th>
                            <th>MoveOut</th>
                            <th>CheckIn</th>
                            <th>CheckOut</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                        <tr>
                            <td>@item.MyriadID</td>
                            <td>@item.FullName</td>
                            <td>@item.OldBedSpace</td>
                            <td>@item.NewBedSpace</td>
                            <td>@item.Remarks</td>
                            <td>@item.SwapDate.ToString("d/M/yyyy h:mm tt")</td>

                            <td>@item.SwappedBy</td>
                            <td>@item.MoveIn.ToString("d/M/yyyy")</td>
                            <td>@item.MoveOut.ToString("d/M/yyyy")</td>
                            <td>@(item.CheckIn.HasValue ? item.CheckIn.Value.ToString("d/M/yyyy h:mm tt") : "N/A")</td>
                            <td>@(item.CheckOut.HasValue ? item.CheckOut.Value.ToString("d/M/yyyy h:mm tt") : "N/A")</td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#SwappedBedSpaceTable').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5'
                ],
            });
        });
        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetRoomSwappedDetails() {
            
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var BedSpaceID = $('#BedSpaceID').val();

            window.location.href = GetFormatedUrl("/Reporting/SwappBedSpacesReport?FromDate=" + SD + "&ToDate=" + ED + "&BedSpaceID=" + BedSpaceID);

        };
        //function PDFPrint() {
        //    var SD = $('.from_date').val();
        //    var ED = $('.to_date').val();
        //    var AccountId = $('#AccountId').val();
        //    window.open("/Reporting/TaxDetailPDFReport?FromDate=" + SD + "&ToDate=" + ED + "&AccountId=" + AccountId, '_blank');
        //}
    </script>
}