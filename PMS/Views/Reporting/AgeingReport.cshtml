    <script type="text/javascript">

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                $('.to_date').datepicker('setStartDate', startDate);
            });

        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetExcel() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();

            var url = "/Reporting/ExportAgeingReport?FromDate=" + SD + "&ToDate=" + ED + "&StudentId=" + StudentId;

            window.location.href = url;

        }

    </script>

    <script>
        var table;
        var tot;
        var dataTable;
        $(document).ready(function () {
            $('#columnvisibilty-filter').multiselect({

                nonSelectedText: 'Select columns to hide',
                maxHeight: 100,
                onChange: function (element, checked) {

                    GetAgeingDetail();
                },
            });
            GetAgeingDetail();
        });

        function GetAgeingDetail() {

            initializeDataTable();
        };

        function initializeDataTable(SD, ED, CheckOut, StudentId, query) {

            ShowLoader();
            if (dataTable) {
                dataTable.destroy();
            }
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var urlParams = new URLSearchParams(window.location.search);
            var query = urlParams.get('queryby');
            var selectedColumns = $('#columnvisibilty-filter').val();
            var columns = [];
            if (selectedColumns) {
                selectedColumns.forEach(function (columnName) {
                    var columnDef = {
                        "data": columnName
                    };
                    columns.push(columnDef);
                });
            }
            dataTable = $('#AgeingTable').DataTable({
                processing: false,
                serverSide: true,
                filter: true,
                paging: true,
                searching: true,
                lengthChange: true,
                scrollCollapse: true,
                scrollY: '70vh',
                scrollX: true,
                scroller: true,
                ordering: true,
                info: true,
                iDisplayLength: 100,
                autoWidth: true,
                responsive: true,
                columns: columns,
                language: {
                    emptyTable: "No record found."
                },


                "ajax": {
                    "url": "/Reporting/loadAgeingReportbyAjax",
                    "type": "POST",
                    "data": function (d) {
                        d.FromDate = SD;
                        d.ToDate = ED;
                        d.StudentId = StudentId;
                        d.query = query;
                        d.SelectedColumns = selectedColumns;
                        var selectedColumn = $('#column-filter').val();
                        if (selectedColumn) {
                            d.search = {
                                value: $('#AgeingTable_filter input').val(),
                                column: selectedColumn
                            };
                        }
                        else {
                            d.search
                        }
                        var columnIndex = d.order[0].column;

                        if (columnIndex === 0) {
                            d.orderBy = d.order[0].column;
                            d.orderDir = d.order[0].dir;
                        }
                        else {
                            var columnName = d.columns[columnIndex].data;
                            d.orderBy = columnName;
                            d.orderDir = d.order[0].dir;
                        }
                    },

                    "datatype": "json",
                    beforeSend: function () {
                        ShowLoader(); // Show loader before AJAX request
                    },
                    complete: function () {
                        HideLoader(); // Hide loader after AJAX request
                    },
                    error: function (xhr, error, thrown) {
                        console.error('AJAX error:', error, thrown);
                        HideLoader();
                    }
                },
                columns: [

                    { "data": "Title", visible: !selectedColumns.includes("Title") },
                    {
                        "data": "MyriadID",
                        "render": function (data, type, full, meta) {
                            var link = '/payments/PartnerLedger?personId=' + full.PersonID;
                            return '<a target="_blank" href="' + link + '">' + full.MyriadID + '</a>';
                        },
                        "visible": !selectedColumns.includes("MyriadID")
                    },
                    { "data": "FullName", visible: !selectedColumns.includes("FullName") },
                    { "data": "Gender", visible: !selectedColumns.includes("Gender") },
                    { "data": "BedSpace", visible: !selectedColumns.includes("BedSpace") },
                    { "data": "Room", visible: !selectedColumns.includes("Room") },
                    { "data": "RoomType", visible: !selectedColumns.includes("RoomType") },
                    { "data": "Commitment", visible: !selectedColumns.includes("Commitment") },
                    {
                        "data": "MoveIn",
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.MoveIn) + '</span>'
                        },
                        visible: !selectedColumns.includes("MoveIn")
                    },
                    {
                        "data": "MoveOut",
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.MoveOut) + '</span>'
                        },
                        visible: !selectedColumns.includes("MoveOut")
                    },
                    {
                        "data": "CheckIn",
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.CheckIn) + '</span>'
                        },
                        visible: !selectedColumns.includes("CheckIn")
                    },
                    {
                        "data": "CheckOut",
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.CheckOut) + '</span>'
                        },
                        visible: !selectedColumns.includes("CheckOut")
                    },
                    { "data": "Email", visible: !selectedColumns.includes("Email") },
                    { "data": "Phone", visible: !selectedColumns.includes("Phone") },
                    //{
                    //    "data": "BSPCreatedDate",
                    //    render: function (data, type, full, meta) {
                    //        return '<span>' + dateformateWithTime(full.BSPCreatedDate) + '</span>'
                    //    },
                    //    visible: !selectedColumns.includes("BSPCreatedDate")
                    //},
                    { "data": "University", visible: !selectedColumns.includes("University") },

                    {
                        "data": "Status",
                        render: function (data, type, full, meta) {
                            if (full.Status == "CheckedIn") {
                                return `<span class="text-success label label-success">CheckedIn</span>`
                            }
                            else if (full.Status == "CheckedOut") {
                                return `<span class="label label-primary">CheckedOut</span>`;
                            }
                            else if (full.Status == "Not CheckedIn") {
                                return `<span class="label label-danger">Not CheckedIn</span>`;
                            }

                            else {
                                return `<span class="label label-danger"></span>`
                            }
                        },

                        visible: !selectedColumns.includes("Status")
                    },

                    {
                        "data": "OutstandingAmount",
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            if (full.OutstandingAmount == null) {
                                return ``;
                            } else {
                                let amount = parseFloat(full.OutstandingAmount).toFixed(2);
                                if (amount < 0) {
                                    return '<span>(' + Math.abs(amount) + ')</span>';
                                } else {
