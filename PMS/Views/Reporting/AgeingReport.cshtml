                                }
                            }
                        },
                        visible: !selectedColumns.includes("Last121To180DaysBalance")
                    },

                    {
                        "data": "Above180DaysBalance",
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            if (full.Above180DaysBalance == null) {
                                return ``;
                            } else {
                                let amount = parseFloat(full.Above180DaysBalance).toFixed(2);
