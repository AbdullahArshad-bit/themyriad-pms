@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ContractsExpiringIn30DaysVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Contracts Expiring In 30Days";
    ViewBag.HeaderDescription = "Contracts Expiring In 30Days";
    ViewBag.Title = "Contracts Expiring In 30Days | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="">
                   
                    <div class="col-md-3">
                        <label>Status</label>
                        <select class="select2" name="Status" id="status">
                            <option value="2" @(ViewBag.Status == 2 ? "selected" : "")>All</option>
                            <option value="1" @(ViewBag.Status == 1 ? "selected" : "")>Signed</option>
                            <option value="0" @(ViewBag.Status == 0 ? "selected" : "")>Pending</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetContractDetail();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                    </div>
                </div>
                <br />

            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="ContractTable" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Occupancy</th>
                            <th>Room</th>
                            <th>MoveIn</th>
                            <th>MoveOut</th>
                            <th>CheckIn</th>
                            <th>CheckOut</th>
                            <th>Contract Status</th>
                            <th>Contract Validity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.LocationName</td>
                                <td>@item.MyriadID</td>
                                <td>@item.FullName</td>
                                <td>@item.Occupancy</td>
                                <td>@item.Room</td>
                                <td>@item.MoveIn.ToString("dd/M/yyyy")</td>
                                <td>@item.MoveOut.ToString("dd/M/yyyy")</td>
                                <td>@(item.CheckIn.HasValue ? item.CheckIn.Value.ToString("dd/M/yyyy hh:mm:ss tt") : "N/A")</td>
                                <td>@(item.CheckOut.HasValue ? item.CheckOut.Value.ToString("dd/M/yyyy hh:mm:ss tt") : "-")</td>

                                <td>@(item.ContractStatus == true? Html.Raw("<span class='text-success label label-success'>Signed</span>") : Html.Raw("<span class='text-success label label-danger'>Pending</span>"))<!--</td>-->
                                <td>@(item.ContractValidity == "Valid" ? Html.Raw("<span class='text-success label label-success'>Valid</span>") : Html.Raw("<span class='text-success label label-danger'>Expired</span>"))<!--</td>-->

                            </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>

    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#ContractTable').DataTable({
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "scrollCollapse": true,
                "scrollY": '70vh',
                "scrollX": "auto",
                "iDisplayLength": 100,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5'
                ],
            });
        });
        function GetContractDetail() {
            var IsSignedFilter = $('#status').val();

            window.location.href = GetFormatedUrl("/Reporting/ContractsExpiringIn30Days?IsSignedFilter=" + IsSignedFilter);

        };
      
    </script>
}