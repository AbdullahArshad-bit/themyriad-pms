@model dynamic
@{
    ViewBag.Header = "Accounting Vouchers Report";
    ViewBag.HeaderDescription = "Accounting Vouchers Report";
    ViewBag.Title = "Accounting Vouchers Report | PMS";
}
@section styles{
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
    <style>
        .right {
            text-align: right;
        }
    </style>
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="">
            <div class="row">
                <div class="col-md-2">
                    <label>From Date</label>
                    <input name="daterange" type="text" autocomplete="off" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input name="daterange" type="text" autocomplete="off" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" />
                </div>
                <div class="col-md-3">
                    <label>Report Type</label>
                    <select id="ReportType" class="form-control mt-2">
                        <option value="All" @(ViewBag.ReprtTypr == "All" ? "selected" : "")>All</option>
                        <option value="Receipt" @(ViewBag.ReportType == "Receipt" ? "selected" : "")>Receipt</option>
                        <option value="Sales" @(ViewBag.ReportType == "Sales" ? "selected" : "")>Sales</option>
                        <option value="Reversal" @(ViewBag.ReportType == "Reversal" ? "selected" : "")>Reversal</option>
                        <option value="Security Deposit" @(ViewBag.ReportType == "Security Deposit" ? "selected" : "")>Security Deposit</option>
                        <option value="Reverse Payments" @(ViewBag.ReportType == "Reverse Payments" ? "selected" : "")>Reverse Payments</option>

                    </select>
                </div>
                <div class="col-md-3">
                    <label>&nbsp;</label><br />
                    <button type="button" onclick="AccountingVoucherReport();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span> Search </span></button>
                    <button type="button" onclick="GetExcel();" class="btn btn-success btn-bordered waves-effect w-md button-effect" style="margin-left: 5px;"><i class="fa fa-download"></i> <span> Export Report </span></button>

                </div>
                <div class="col-md-2">
                    <label>&nbsp;</label><br />
                </div>
            </div>
            <br />
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div class="box-body">
            <div style="overflow: auto; width:100%; white-space:nowrap;">
                <table class="table table-bordered table-striped data-table" id="AccountingVoucherTable">
                    <thead>
                        <tr>
                            <th>Voucher Date</th>
                            <th>Voucher Type Name</th>
                            <th>Myriad ID</th>
                            <th>Voucher Number</th>
                            <th>Ledger Name</th>
                            <th>Ledger Amount</th>
                            <th>Ledger Amount Dr/Cr</th>
                            <th>Voucher Narration</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th class="right"></th>
                            <th></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js"></script>
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {
            var table = $('#AccountingVoucherTable').DataTable({
                processing: false,
                serverSide: true,
                filter: true,
                paging: true,
                searching: true,
                lengthChange: true,
                scrollCollapse: true,
                scrollY: '70vh',
                scrollX: true,
                scroller: true,
                ordering: true,
                info: true,
                iDisplayLength: 100,
                autoWidth: true,
                responsive: true,
                language: {
                    emptyTable: "No record found."
                },
                "ajax": {
                    "url": "@Url.Action("loadAccountingVouchersReportbyAjax", "Reporting")",
                    "type": "POST",
                    "data": function (d) {
                        d.FromDate = $('#FromDate').val();
                        d.ToDate = $('#ToDate').val();
                        d.ReportType = $('#ReportType').val();
                        d.query = d.query;
                        d.SelectedColumns = [];
                        var columnIndex = d.order[0].column;
                        if (columnIndex === 0) {
                            d.orderBy = d.order[0].column;
                            d.orderDir = d.order[0].dir;
                        }
                        else {
                            var columnName = d.columns[columnIndex].data;
                            d.orderBy = columnName;
                            d.orderDir = d.order[0].dir;
                        }
                    },
                    beforeSend: function () {
                        ShowLoader();
                    },
                    complete: function () {
                        HideLoader();
                    },
                    "error": function (xhr, error, thrown) {
                        console.log("AJAX error: ", xhr.status, xhr.responseText, error, thrown);
                        HideLoader();
                        alert("An error occurred while loading data. Check the console for details.");
                    }
                },

                "columns": [
                    {
                        "data": "VoucherDate",
                        "render": function (data) {
                            if (!data) return '';

                            if (typeof data === 'string' && data.indexOf('/Date(') === 0) {
                                var timestamp = parseInt(data.replace(/\/Date\((-?\d+)\)\//, '$1'));
                                var date = new Date(timestamp);
                                return date.toLocaleDateString('en-GB');
                            }

                            var date = new Date(data);
                            return !isNaN(date.getTime()) ?
                                date.toLocaleDateString('en-GB') : '';
                        }
                    },
                    { "data": "VoucherTypeName" },
                    { "data": "MyriadID" },
                    { "data": "VoucherNumber" },
                    { "data": "LedgerName" },
                    {
                        "data": "LedgerAmount",
                        "render": function (data) { return data < 0 ? '(' + Math.abs(data) + ')' : data || 0; },
                        "className": "right"
                    },
                    { "data": "LedgerAmountDrCr" },
                    { "data": "VoucherNarration" }
                ],

                "footerCallback": function (row, data, start, end, display) {
                    //var api = this.api();
                    //var ledgerAmountTotal = api.column(4, { page: 'current' }).data().reduce(function (a, b) {
                    //    return a + parseFloat(b || 0);
                    //}, 0);
                    //$(api.column(4).footer()).html(ledgerAmountTotal.toFixed(2));
                },
            });

            $('.from_date').datepicker({
                weekStart: 1,
                startDate: '',
                format: "dd/M/yyyy",
                autoclose: true
            });


            $('.to_date').datepicker({
                weekStart: 1,
                startDate: '',
                format: "dd/M/yyyy",
                autoclose: true
            });

            window.AccountingVoucherReport = function () {
                table.ajax.reload();
            };

            window.GetExcel = function () {
                var SD = $('.from_date').val();
                var ED = $('.to_date').val();
                var reportType = $('#ReportType').val();
                window.location.href = GetFormatedUrl("/Reporting/ExportAccountingVouchersReport?fromDate=" + SD + "&toDate=" + ED + "&reportType=" + reportType);
            };
        });
    </script>
}