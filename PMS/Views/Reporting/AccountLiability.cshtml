@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.AccountLiabilityVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "General Account Report";
    ViewBag.HeaderDescription = "General Account Report";
    ViewBag.Title = "General Account Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="">
                    <div class="col-md-3">
                        <label>Persons</label>
                        @Html.DropDownList("StudentId", null, "-- All Persons --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Accounts</label>
                            @Html.DropDownList("AccountId", null, "-- All Accounts --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                        </div>
                    </div>

                    <div class="col-md-1">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetAccountDetail();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                    </div>
                </div>
                <br />

            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="LiabilityTable" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Account</th>
                            <th>Total Price</th>
                            <th>Net Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.LocationName</td>
                                <td>@item.MyriadID</td>
                                <td>@item.FullName</td>
                                <td>@item.ChartOfAccountsName</td>
                                <td>@item.InvoiceDetailPrice</td>
                                <td>@item.InvoiceDetailTotalAmount</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>

    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#LiabilityTable').DataTable({
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "scrollCollapse": true,
                "scrollY": '70vh',
                "scrollX": "auto",
                "iDisplayLength": 100,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                    '<button type="button" onclick="Print()" class="dt-button buttons-excel buttons-html5"><i class="fa fa-download"></i></button>'

                ],
            });
        });
        function GetAccountDetail() {
            var StudentId = $('#StudentId').val();
            var AccountId = $('#AccountId').val();

            window.location.href = GetFormatedUrl("/Reporting/AccountLiability?StudentId=" + StudentId + "&AccountId=" + AccountId);

        };
        function Print() {
            var StudentId = $('#StudentId').val();
            var AccountId = $('#AccountId').val();
            window.open("/Reporting/GetAccountLiabilityPDFReport?StudentId=" + StudentId + "&AccountId=" + AccountId, '_blank');
        }
    </script>
}