@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ManagerDailyVM>

@{
    ViewBag.Header = "Manager - Daily Report";
    ViewBag.HeaderDescription = "Manager - Daily Report";
    ViewBag.Title = "Manager - Daily Report | PMS";
}


@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}

<style>
    div.container {
        max-width: 1200px;
    }

    .right {
        text-align: right;
    }

    table.dataTable tfoot th {
        text-align: right;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            <div class="">
                <div class="col-md-2">
                    <label>From Date</label>
                    <input name="daterange" id="FilterDate" class="form-control filter_date" value="@ViewBag.FilterDate" placeholder="From Date" />
                </div>

                <div class="col-md-1">
                    <label> &nbsp; </label>
                    <br />
                    <button type="button" onclick="DailyManagerDetail();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="DailyManagertbl" class="table table-bordered table-striped display now" style="width:100%">
                    
                    <thead>
                        <tr>
                            <th>Total Bed Space</th>
                            <th>Bed Occupied</th>
                            <th>Available Bed</th>
                            <th>In-House Adults/Residents</th>
                            <th>In-House Children/Guests</th>
                            <th>Total In-House Persons</th>
                            <th>% Rooms Occupied</th>
                            <th>Arrival Beds</th>
                            <th>Arrival Persons</th>
                            <th>Departure Bed Space</th>
                            <th>Departure Persons</th>
                            <th>No Show Bed Spaces</th>
                            <th>Reservations Made Today</th>
                            <th>Beds Revenue</th>
                            <th>Other Revenue</th>
                            <th>Total Revenue</th>
                            <th>Payment</th>
                            <th>Arrival Beds for Tomorrow</th>
                            <th>Departure Rooms for Tomorrow</th>

                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TotalBedSpace</td>
                                <td>@item.BedOccupied</td>
                                <td>@item.AvailableBed</td>
                                <td>@item.InHouseAdultsResidents</td>
                                <td>@item.InHouseChildrenGuests</td>
                                <td>@item.TotalInHousePersons</td>
                                <td>@item.RoomsOccupied</td>
                                <td>@item.ArrivalBeds</td>
                                <td>@item.ArrivalPersons</td>
                                <td>@item.DepartureBedSpace</td>
                                <td>@item.DeparturePersons</td>
                                <td>@item.NoShowBedSpace</td>
                                <td>@item.ReservationsMadeToday</td>
                                <td class="right">@item.BedsRevenue</td>
                                <td class="right">@item.OtherRevenue</td>
                                <td class="right">@(item.BedsRevenue + item.OtherRevenue)</td>
                                <td class="right">@item.Payment</td>
                                <td>@item.ArrivalBedsTomorrow</td>
                                <td>@item.DepartureRoomsTomorrow</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#DailyManagertbl').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'copyHtml5',
                    'excelHtml5',

                    //'<button type="button" onclick="PDFPrint()" class="dt-button buttons-excel buttons-html5"><i class="fa fa-download"></i></button>'
                ],
            });
        });

        $('.filter_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })

        function DailyManagerDetail() {
            var SD = $('.filter_date').val();

            window.location.href = GetFormatedUrl("/Reporting/ManagerDailyReport?FilterDate=" + SD);

        };
        function PDFPrint() {
            var SD = $('.filter_date').val();
            window.open("/Reporting/ManagerDailyPDFReport?FilterDate=" + SD, '_blank');
        }
    </script>
}