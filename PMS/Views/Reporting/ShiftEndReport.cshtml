@model IEnumerable<PMS.DTO.ViewModels.ReportingViewModels.ShiftEndReportVM>

@{
    ViewBag.Header = "End Of Shift Report";
    ViewBag.HeaderDescription = "End Of Shift Report";
    ViewBag.Title = "End Of Shift Report | PMS";
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    div.container {
        max-width: 1200px;
    }

    .right {
        text-align: right;
    }

    table.dataTable tfoot th {
        text-align: right;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }



        </div>
        <div class="">
            <div class="">
                <div class="col-md-2">
                    <label>From Date</label>
                    <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" autocomplete="off" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" autocomplete="off" />
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label>Payment</label>
                        @Html.DropDownList("PaymentId", null, "-- All Payments --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                    </div>
                </div>

                <div class="col-md-3" id="UserDiv">
                    <label>User</label>
                    @Html.DropDownList("userid", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2", @required = "required" })
                </div>

                <div class="col-md-1">
                    <label> &nbsp; </label>
                    <br />
                    <button type="button" onclick="GetShiftEndReport();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
                </div>
            </div>
            <br />

        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="col-md-12">

                <table id="payment-table" class="table table-bordered table-striped display now" style="width:100%">

                    <thead>

                        <tr>
                            <th>Location</th>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Transaction Code</th>
                            <th>Remarks</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Status</th>
                            <th>TransactionDate</th>
                            <th>CreatedBy</th>
                            <th>Approved By</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.LocationName</td>
                                <td>@item.MyriadID</td>
                                <td>@item.FullName</td>
                                <td>@item.TransactionCode</td>
                                <td>@item.Remarks</td>
                                <td class="right">@item.Amount</td>
                                <td>@item.PaymentMethod</td>
                                <td>
                                    @if (item.Status == true)
                                    {
                                        <span class="text-success label label-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger label label-primary">Pending</span>
                                    }
                                </td>
                                <td>@item.TransactionDate</td>
                                <td>@item.CreatedBy</td>
                                <td>@item.ApprovedBy</td>


                            </tr>
                        }

                    </tbody>

                    <tfoot style="width: 100%">
                        <tr>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th>@ViewBag.TotalAmount</th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>

                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>

    </div>
</div>

@section scripts{


    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    @*<script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>*@

    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>

        $(document).ready(function () {
            $('#payment-table').DataTable({
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                //"pageLength": -1,
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "scrollCollapse": true,
                "scrollY": '70vh',
                "scrollX": "auto",
                "iDisplayLength": 100,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                buttons: [
                    'excelHtml5'


                ],
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                columnDefs: [
                    { type: 'date-euro', targets: 4 }
                ]
            });
            $('.dataTables_length').addClass('bs-select');
        });


    </script>


    <script type="text/javascript">


        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                //startDate.setDate(startDate.getDate(new Date(selected.date.valueOf())));
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });




        function GetShiftEndReport() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var PaymentId = $('#PaymentId').val();
            var userid = $('#userid').val();

            window.location.href = GetFormatedUrl("/Reporting/ShiftEndReport?FromDate=" + SD + "&ToDate=" + ED + "&PaymentId=" + PaymentId + "&userid=" + userid);

        };
        function Print() {
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var PaymentId = $('#PaymentId').val();
            var userid = $('#userid').val();
            var Type = $('#type').val();
            window.open("/Reporting/GetPaymentsDetailPDFReport?FromDate=" + SD + "&ToDate=" + ED + "&PaymentId=" + PaymentId + "&StudentId=" + StudentId, + "&userid=" + userid + "&type=" + Type, '_blank');
        }


    </script>

}