@using PMS.Common.Classes

@{
    ViewBag.Header = "Chart Of Accounts";
    ViewBag.HeaderDescription = "Chart of Accounts List";
    ViewBag.Title = "COA | PMS";

    var Accounts = ViewBag.ChartOfAccounts as List<PMS.DTO.ViewModels.COAViewModels.COAVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12" style="margin-bottom:30px; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_acc_COA))
                    {
                        <a href="@Url.Action("CreateOrUpdateCOA", "Accounting")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Account</a>
                    }
                </div>
            </div>
            <div style="overflow: auto; width:100%;white-space:nowrap;">
                <table class="table table-bordered table-striped data-table">
                    <thead>
                        <tr>
                            <th>Location</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Alias</th>
                            <th>Type</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Accounts)
                        {
                            <tr>
                                <td>@item.LocationName</td>
                                <td>@item.Code</td>
                                <td>@item.Name</td>
                                <td>@item.Alias</td>
                                <td>@item.AccountType</td> <!-- Adjust if necessary -->
                                <td>
                                    @if (item.Status == true)
                                    {
                                        <span class='label label-success'>Yes</span>
                                    }
                                    else
                                    {
                                        <span class='label label-danger'>No</span>
                                    }
                                </td>
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.add_acc_COA))
                                    {
                                        <a title="Edit" href="@Url.Action("CreateOrUpdateCOA", "Accounting", new { id = item.Id })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_acc_COA))
                                    {
                                        <a title="Delete" href="#" data-href="@Url.Action("DeleteChatOfAccount", "Accounting", new { id = item.Id })" data-toggle="modal" data-target="#confirm-delete"><i class="fa fa-remove"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_div" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true"></div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        });
    </script>
}
