@model List<PMS.DTO.ViewModels.TicketGroupVm>
@{
    ViewBag.Header = "Ticket Group";
    ViewBag.HeaderDescription = "All Groups";
    ViewBag.Title = "All Ticket Group | PMS";
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<div class="card">

    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>

    <div class="box box-danger">
        <div>

            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
        </div>
        <br />

        <div class="col-md-3">
            <div class="form-group">
                @Html.Label("GroupId", "Group")
                @Html.DropDownList("GroupId", null, "--- Select Group ---", htmlAttributes: new { @class = "form-control", @rows = 5 })

            </div>
        </div>
        <div class="col-md-1">
            <label> &nbsp; </label>
            <br />
            <button type="button" onclick="GetTicketGroup();" class="btn btn-themyriad btn-bordered waves-effect w-md"><i class="fa fa-search"></i> <span>Search</span></button>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="box-body">

                    <table id="table" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var i = 0;}
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="form-group">
                                            <div class="checkbox">
                                                <label>
                                                    <input type="checkbox" name="name" class="checkbox user" value="@item.UserId" data-id="@item.UserId" id="user-@i" @(item.GroupUserID == item.UserId ? "checked" : "")>
                                                    @item.Name
                                                </label>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@item.RoleName</td>
                                    <td>
                                        <div class="form-group">
                                            <div class="radio">
                                                @foreach (var item2 in item.TicketGroupRole)
                                                {
                                                    string checkeds = "";

                                                    if (item2.Id == item.GroupRoleId)
                                                    {
                                                        checkeds = "checked";
                                                    }

                                                    <label>
                                                        <input type="radio" name="type-@i" value="@item2.Id" data-id="@item2.Id" class="RoleType" @checkeds>
                                                        @item2.Name
                                                    </label>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                { i++; }
                            }
                        </tbody>
                    </table>
                    <div class="box-footer" style="display:none;" id="submitButton">
                        <button class="btn btn-themyriad savebtn" type="button" onclick="Submit()">Save</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    @*<script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
        <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
        <script type="text/javascript" src="//cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>*@

    <script>

        $(document).ready(function () {
            var table = $('#table').DataTable({
                "paging": false,
                "searching": false

            });
            var tableData = table.rows().data();
            if (tableData.length > 0) {
                $('#submitButton').show();
            } else {
                $('#submitButton').hide();
            }
        });
        function GetTicketGroup() {
            var GroupId = $('#GroupId').val();

            window.location.href = GetFormatedUrl("/TicketGroup/Add?GroupId=" + GroupId);
            if (GroupId > 0) {
                $('#submitButton').show();
            }
            else {
                $('#submitButton').hide();
            }
        };
        function Submit() {
            var list = [];
            var groupId = $("#GroupId").val();
            $("#table tbody ").find(".user:checkbox:checked").closest("tr").each(function () {
                var userId = $(this).find(".user").attr("data-id");
                var roleId = $(this).find(".RoleType:radio:checked").attr("data-id")
                var userGroup = {
                    UserId: userId,
                    GroupRoleId: roleId,
                    GroupId: groupId
                };
                list.push(userGroup);
            });
            if (list.length > 0) {
                $.ajax({
                    url: "/TicketGroup/Add",
                    method: "Post",
                    data: JSON.stringify(list),
                    contentType: "application/json; charset=utf-8",
                    success: function (response) {

                        location.href = "/TicketGroup/Add?GroupId=" + groupId

                    }

                });
            }
        }
    </script>
}