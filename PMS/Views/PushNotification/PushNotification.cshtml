@model PMS.DTO.ViewModels.PushNotificationPageViewModel

@{
    ViewBag.Header = "Push Notification";
    ViewBag.HeaderDescription = "Send a notification to subscribed devices";
    ViewBag.Title = "Push Notification | PMS";
}

@section styles{
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
}

<div class="box box-danger">

    @using (Html.BeginForm("PushNotification", "PushNotification", FormMethod.Post, new { id = "push_notification_form" }))
    {
        @Html.AntiForgeryToken()

        <div class="box-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input type="text" id="title" name="title" class="form-control" placeholder="Enter notification title" required />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label for="body">Message</label>
                        <textarea id="body" name="body" class="form-control" rows="4" placeholder="Enter notification message" required></textarea>
                    </div>
                </div>
            </div>

            <div class="box-footer">
                <button type="submit" id="btn-send-notification" class="btn btn-themyriad waves-effect button-effect">
                    <i class="fa fa-bell"></i> Send Notification
                </button>
            </div>
        </div>
    }
</div>

<div class="box box-danger">
    <div class="box-header with-border">
        <h3 class="box-title">Previously Sent Notifications</h3>
    </div>
    <div class="box-body table-responsive">
        <table id="push-notification-logs-table" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Message</th>
                    <th>Sent By</th>
                    <th>Sent By Email</th>
                    <th>Sent On</th>
                    <th>Delivered</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Logs != null && Model.Logs.Count > 0)
                {
                    foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td>@log.Title</td>
                            <td>@log.MessageBody</td>
                            <td>@(string.IsNullOrEmpty(log.SentByUserName) ? "-" : log.SentByUserName)</td>
                            <td>@(string.IsNullOrEmpty(log.SentByEmail) ? "-" : log.SentByEmail)</td>
                            <td>@log.SentOn.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>@(log.DeliveredDeviceCount.HasValue ? log.DeliveredDeviceCount.ToString() : "-")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">No notification logs found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>

    <script>
        $(document).ready(function () {
            $('#push-notification-logs-table').DataTable({
                order: [[4, 'desc']],
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 10
            });

            $('#push_notification_form').on('submit', function () {
                $('#btn-send-notification').prop('disabled', true);
                if (typeof ShowLoader === 'function') {
                    ShowLoader();
                } else {
                    $('.Customoverlay, .Customloader').show();
                }
            });
        });
    </script>

    @if (ViewBag.StatusMessage != null)
    {
        <script type="text/javascript">
            $(function () {
                Toast.show('@ViewBag.StatusMessage', 'success', 5000);
            });
        </script>
    }
}
