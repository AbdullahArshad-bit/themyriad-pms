@using PMS.Common.Classes;
@{
    ViewBag.Header = "Refund Payments";
    ViewBag.HeaderDescription = "All Refund Payments";
    ViewBag.Title = "Refund Payments | PMS";
}
@{
    var editAction = User.IsInRole(AppUserRoles.Edit_acc_PaymentTransection);
    var approveAction = User.IsInRole(AppUserRoles.Approve_acc_PaymentTransection);
    var editRefundAction = User.IsInRole(AppUserRoles.Edit_Refund_Payment);
    var paymentDetAction = User.IsInRole(AppUserRoles.view_acc_PaymentTransectionDetail);
    var paymentVoucherAction = User.IsInRole(AppUserRoles.View_Payment_Voucher_Detail);
    var dubaiLocationId = (int)Enumeration.LocationEnum.Dubai;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/css/bootstrap-multiselect.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}
<style>
    .right {
        text-align: right;
    }

    .action-for-Payment {
        font-size: 20px !important;
    }
</style>
<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">�</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">�</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="">
                <div class="">
                    <div class="col-md-3">
                        <label>From Date</label>
                        <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" autocomplete="off" />
                    </div>
                    <div class="col-md-3">
                        <label>To Date</label>
                        <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" autocomplete="off" />
                    </div>
                    <div class="col-md-3">
                        <label>Students</label>
                        @Html.DropDownList("StudentId", null, "-- All Users --", htmlAttributes: new { @class = "form-control select2" })
                    </div>
                    <div class="col-md-3">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetRefundPayments();" class="btn btn-themyriad btn-bordered waves-effect w-md "><i class="fa fa-search"></i> <span>Search</span></button>
                        <button type="button" onclick="GetExcel()" class="btn btn-success btn-bordered waves-effect w-md button-effect" style="margin-left: 5px;"> <i class="fa fa-download"> </i> <span> Export Report </span> </button>

                    </div>
                 
                </div>
                <br />
            </div>
        </div>

        <div class="col-md-12">
            <hr />
        </div>

        <div class="row">
            <div class="row" style="margin-bottom:30px">

                <div class="col-md-3">
                    <label>Search By Column:</label>
                    <select class="form-control" id="column-filter">
                        <option value="">All Columns</option>
                        <option value="Location">Location</option>
                        <option value="TransactionCode">Transaction Code</option>
                        <option value="InvoiceCode">Invoice Code</option>
                        <option value="InvoiceDate">Invoice Date</option>
                        <option value="MyriadID">MyriadID</option>
                        <option value="FullName">FullName</option>
                        <option value="PaymentName">Payment Method</option>
                        <option value="PaymentReferenceNumber">Payment Reference</option>
                        <option value="CreatedBy">Created By</option>
                        <option value="ApprovedBy">Approved By</option>

                    </select>
                </div>

                <div class="col-md-3" style="width: 200px;">
                    <label>Column Visibilty:</label>
                    <select multiple class="form-control" id="columnvisibilty-filter">
                        <option value="Location">Location</option>
                        <option value="TransactionCode">Transaction Code</option>
                        <option value="InvoiceCode">Invoice Code</option>
                        <option value="InvoiceDate">Invoice Date</option>
                        <option value="MyriadID">MyriadID</option>
                        <option value="FullName">FullName</option>
                        <option value="PaymentDate">Payment Date</option>
                        <option value="Remarks">Remarks</option>
                        <option value="DebitAmount">Amount</option>
                        <option value="PaymentName">Payment Method</option>
                        <option value="PaymentReferenceNumber">Payment Reference</option>
                        <option value="IsApproved">Status</option>
                        <option value="CreatedBy">Created By</option>
                        <option value="ApprovedBy">Approved By</option>

                    </select>
                </div>
            </div>

            <div class="col-md-12">
                <table id="RefundPayments" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Location</th>
                            <th>Transaction Code</th>
                            <th>Invoice Code</th>
                            <th>Invoice Date</th>
                            <th>MyriadID</th>
                            <th>FullName</th>
                            <th>Payment Date</th>
                            <th>Remarks</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Payment Reference</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Approved By</th>
                        </tr>
                    </thead>

                    <tbody>
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/js/bootstrap-multiselect.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script>
        var dataTable;

        $(document).ready(function () {
            $('#columnvisibilty-filter').multiselect({
                nonSelectedText: 'Select columns to hide',
                maxHeight: 100,
                onChange: function (element, checked) {
                    // Call GetBookings function when value is selected or deselected
                    GetRefundPayments()
                },
            });
            GetRefundPayments();
        });

         function PaymentAction() {
            var actions = new Array();
             if ('@editRefundAction' == 'True') actions.push("editRefund-action");
            if ('@approveAction' == 'True') actions.push("approve-action");
            if ('@paymentDetAction' == 'True') actions.push("detail-action");
             if ('@paymentVoucherAction' == 'True') actions.push("paymentVoucher-action");
            return actions;
        }

        function GetRefundPayments() {
            loadRefundPaymentsTable();
        }

        function loadRefundPaymentsTable() {
            ShowLoader();

            if (dataTable) {
                dataTable.destroy();
            }
            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            var StudentId = $('#StudentId').val();
            var urlParams = new URLSearchParams(window.location.search);
            var query = urlParams.get('queryby');
            var actions = PaymentAction();
            var selectedColumns = $('#columnvisibilty-filter').val();
            var columns = [];
            if (selectedColumns) {
                selectedColumns.forEach(function (columnName) {
                    var columnDef = {
                        "data": columnName
                    };
                    columns.push(columnDef);
                });
            }
            dataTable = $('#RefundPayments').DataTable({
                processing: false,
                serverSide: true,
                filter: true,
                paging: true,
                searching: true,
                lengthChange: true,
                scrollCollapse: true,
                scrollY: '70vh',
                scrollX: true,
                scroller: true,
                ordering: true,
                info: true,
                iDisplayLength: 100,
                autoWidth: true,
                responsive: true,
                columns: columns,
                language: {
                    emptyTable: "No record found.",
                },
                "ajax": {
                    "url": "/Payments/loadRefundPaymentByAjax",
                    "type": "POST",
                    "data": function (d) {

                        d.FromDate = SD;
                        d.ToDate = ED;
                        d.StudentId = StudentId;
                        d.query = query;
                        d.SelectedColumns = selectedColumns;
                        var selectedColumn = $('#column-filter').val();
                        if (selectedColumn) {
                            d.search = {
                                value: $('#RefundPayments_filter input').val(),
                                column: selectedColumn
                            };
                        }
                        else
                        {
                            d.search
                        }
                        var columnIndex = d.order[0].column;

                        if (columnIndex === 0) {
                            d.orderBy = d.order[0].column;
                            d.orderDir = d.order[0].dir;
                        } else {
                            var columnName = d.columns[columnIndex].data;
                            d.orderBy = columnName;
                            d.orderDir = d.order[0].dir;
                        }
                    },

                    "datatype": "json",
                    beforeSend: function () {
                        ShowLoader(); // Show loader before AJAX request
                    },
                    complete: function () {
                        HideLoader(); // Hide loader after AJAX request
                    },
                    error: function (xhr, error, thrown) {
                        console.error('AJAX error:', error, thrown);
                        HideLoader();
                    }
                },
                columns: [
                    {
                        "data": "Id",
                        render: function (data, type, full, meta) {
                            var availableActions = '';
                            var isDubai = full.LocationId == @dubaiLocationId; // Muscat LocationId

                            if (full.IsApproved == true && full.CreditNoteId == null && isDubai && full.IsReversedPayment !== true) {
                                if (actions.includes("editRefund-action"))
                                    availableActions += `<a class = "editRefund EditHideAfterApproval menu-icons" style="text-align:inherit" title="Edit Payment" href="/Payments/Edit?id=${full.Id}">
          <i style="cursor:pointer" class="fa fa-edit action-for-Payment"></i></a>`
                            }

                            if (full.VoucherId != 0) {
                                if (actions.includes("paymentVoucher-action"))
                                availableActions += `<a class="voucher-action menu-icons" style="text-align:inherit" title="Voucher Details" href="/Voucher/PaymentVoucher?id=${full.VoucherId}">
<i class="fa fa-ticket action-for-Voucher"></i></a>`
                            }

                            if (actions.includes("detail-action"))
                                availableActions += `<a class = "detail-action menu-icons" style="text-align:inherit" title="Details" href="/Payments/Details?id=${full.Id}">
                                <i class="fa fa-file-text-o action-for-Payment"></i></a>`

                            return availableActions;
                        },

                    },
                    { "data": "Location", visible: !selectedColumns.includes("Location") },
                    { "data": "TransactionCode", visible: !selectedColumns.includes("TransactionCode") },
                    { "data": "InvoiceCode", visible: !selectedColumns.includes("InvoiceCode") },
                    {
                        "data": "InvoiceDate",
                        visible: !selectedColumns.includes("InvoiceDate"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.InvoiceDate) + '</span>'
                        },
                    },
                    { "data": "MyriadID", visible: !selectedColumns.includes("MyriadID") },
                    { "data": "FullName", visible: !selectedColumns.includes("FullName") },
                    {
                        "data": "PaymentDate",
                        visible: !selectedColumns.includes("PaymentDate"),
                        render: function (data, type, full, meta) {
                            return '<span>' + dateformate(full.PaymentDate) + '</span>'
                        },
                    },
                    { "data": "Remarks", visible: !selectedColumns.includes("Remarks") },
                    {
                        "data": "DebitAmount",
                        visible: !selectedColumns.includes("DebitAmount"),
                        "className": "text-right",
                        render: function (data, type, full, meta) {
                            var currency = full.Currency ? full.Currency + ' ' : '';
                            if (full.DebitAmount < 0) {
                                return '<span>' + '(' + currency + Math.abs(parseFloat(full.DebitAmount).toFixed(2)) + ')' + '</span>'
                            }
                            else {
                                return '<span>' + currency + parseFloat(full.DebitAmount).toFixed(2) + '</span>'
                            }
                        },
                    },
                    { "data": "PaymentName", visible: !selectedColumns.includes("PaymentName") },
                    { "data": "PaymentReferenceNumber", visible: !selectedColumns.includes("PaymentReferenceNumber") },
                    {
                        "data": "IsApproved",
                        visible: !selectedColumns.includes("IsApproved"),
                        render: function (data, type, full, meta) {

                            if (full.IsReversedPayment === true) {
                                return `<span class="text-danger label label-danger">Reversed</span>`;
                            }
                            else if (full.IsApproved == true) {
                                return `<span class="text-success label label-success">Approved</span>`
                            }
                            else {
                                return `<span class="text-danger label label-primary ToBeApproved-${full.Id}">Pending</span>`
                            }
                        },
                    },
                    { "data": "CreatedBy", visible: !selectedColumns.includes("CreatedBy") },
                    { "data": "ApprovedBy", visible: !selectedColumns.includes("ApprovedBy") },
                ],

            });
        };

        function dateformate(date) {
            if (date == '' || date == null) {
                return '';
            } else {
                let d = new Date(parseInt(date.substr(6))); //parse json datetime to datetime
                let _month = parseInt(d.getMonth()) + 1;
                let _date = d.getDate() + "/" + _month + "/" + d.getFullYear();

                return _date;
            }
        }
        var Id = 0;
        function ApproveConform(Code) {
            Id = Code;
            $('#ApproveConformation').modal('show');
        }

        function ApproveInvoice() {
            $('#ApproveConformation').modal('hide');
            $.ajax({
                type: "Get",
                url: GetFormatedUrl('/Payments/ApprovePayment/') + Id,
                async: true,
                success: function (data) {
                    var data = data.status;
                    if (data == true) {
                        $('.ToBeApproved-' + Id).closest('tr').find('.EditHideAfterApproval').addClass('hide');
                        $('.ToBeApproved-' + Id).closest('tr').find('.ApproveHideAfterApproval').addClass('hide');
                        $('.ToBeApproved-' + Id).closest('td').html('<span class="text-success label label-success">Approved</span>');
                    }
                },
                error: function (data) {
                }
            });
        };

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.from_date').datepicker({
            weekStart: 1,
            startDate: '',
            format: "dd/M/yyyy",
            orientation: "bottom left",

            autoclose: true
        })
            .on('changeDate', function (selected) {
                startDate = new Date(selected.date.valueOf());
                $('.to_date').datepicker('setStartDate', startDate);
            });
        $('.to_date')
            .datepicker({
                weekStart: 1,
                startDate: new Date($('.from_date').val()),
                endDate: ToEndDate,
                format: "dd/M/yyyy",
                orientation: "bottom left",
                autoclose: true,

            })
            .on('changeDate', function (selected) {
                FromEndDate = new Date(selected.date.valueOf());
                FromEndDate.setDate(FromEndDate.getDate(new Date(selected.date.valueOf())));
                $('.from_date').datepicker('setEndDate', FromEndDate);
            });

        function GetExcel() {

            var SD = $('.from_date').val();
            var ED = $('.to_date').val();
            window.location.href = GetFormatedUrl("/Payments/ExportRefundPaymentReport?FromDate=" + SD + "&ToDate=" + ED);

        }
    </script>

}