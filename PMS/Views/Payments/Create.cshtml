@model PMS.EF.StudentLedger

@{
    ViewBag.Header = "Payment";
    ViewBag.HeaderDescription = "Add Payment";
    ViewBag.Title = "Create | PMS";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section styles{
    @Styles.Render("~/Content/datepicker/css")
    <style>
        .creditNote {
            font-size: 12px;
            font-family: 'FontAwesome';
        }

        .crd-btn {
            font-size: 16px;
        }
    </style>
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.Partial("_CreateOrUpdate")
}

@section scripts
{
    @Scripts.Render("~/bundles/jqueryval")
    @Scripts.Render("~/bundles/datepicker/Js")

    // Replace the entire script block at the bottom of Create.cshtml with this:
    <script type="text/javascript">
        $(function () {
            var startDate = new Date();

            $('#datepicker').datepicker({
                autoclose: true,
                format: "dd/M/yyyy",
                startDate: startDate // Set the start date to the current date
            }).datepicker('setDate', startDate);
            //new End

            // Modified button click handlers to prevent double submission
            $('.SubmitWithApprove').on('click', function (e) {
                // Prevent default button behavior
                e.preventDefault();

                console.log('Save & Approve clicked');

                // Check if form is valid before disabling buttons
                var $form = $(this).closest('form');
                if (!$form[0].checkValidity()) {
                    // Trigger the browser's built-in validation UI
                    $form[0].reportValidity();
                    return;
                }

                // Disable both buttons immediately
                $('.SubmitWithApprove').prop('disabled', true);
                $('.SubmitWithOutApprove').prop('disabled', true);
                ShowLoader();

                // Change button text to show loading
                $(this).html('<i class="fa fa-spinner fa-spin"></i> Processing...');

                // Set form values and submit
                $('#IsApproved').val(true);
                $('#LocationId').prop('disabled', false);

                // Submit the form
                $form.submit();
            });

            $('.SubmitWithOutApprove').on('click', function (e) {
                // Prevent default button behavior
                e.preventDefault();

                console.log('Save clicked');

                // Check if form is valid before disabling buttons
                var $form = $(this).closest('form');
                if (!$form[0].checkValidity()) {
                    // Trigger the browser's built-in validation UI
                    $form[0].reportValidity();
                    return;
                }

                // Disable both buttons immediately
                $('.SubmitWithApprove').prop('disabled', true);
                $('.SubmitWithOutApprove').prop('disabled', true);
                ShowLoader();

                // Change button text to show loading
                $(this).html('<i class="fa fa-spinner fa-spin"></i> Processing...');

                // Set form values
                $('#IsApproved').val(false);
                $('#LocationId').prop('disabled', false);

                // Submit the form
                $form.submit();
            });

            $('#LocationId').on('change', function () {
                var Code = $('#Code').val()
                var LocationId = $(this).val()
                var url = GetFormatedUrl("/Payments/GetLocationBYId")
                $.ajax({
                    type: "Get",
                    url: url,
                    data: {
                        Id: LocationId
                    },
                    success: function (data) {
                        var data = data;
                        $('#Code').val(data.Code);
                        $('#StudentId').html('');
                        var html = "<option value=''>-- Resident ID --</option>";
                        $.each(data.Students, function (key, value) {
                            html = html + "<option Value='" + value.PersonID + "'>" + value.FullName + "</option>"
                        })
                        $('#StudentId').html(html);
                    }
                });
            });

            $('#StudentId').on('change', function () {

                var studentid = $(this).val()
                var LocationId = $('#LocationId').val()
                var url = GetFormatedUrl("/Invoicings/GetInvoicesByPersonId")
                $.ajax({
                    type: "Get",
                    url: url,
                    data: {
                        PersonId: studentid
                    },
                    success: function (data) {
                        $('#InvoiceId').html('');

                        var html = "<option value=''>-- Invoice --</option>";
                        $.each(data.data, function (key, value) {
                            html = html + "<option data-attr='" + value.Amount + "' Value='" + value.Id + "'>" + value.Value + "</option>"
                        })
                        $('#InvoiceId').html(html);
                        GetStudentCreditNote(studentid);
                        //GetOutStandingBalance(studentid);

                        // Only call GetOutStandingBalance if not Dubai (LocationId != 17)
                        if (LocationId != '17') {
                            GetOutStandingBalance(studentid);
                        }
                    }
                });
            });

            $('#InvoiceId').on('change', function () {

                $("#CreditAmount").val('');
                $("#CreditAmount").attr('disabled', false);
                var invoiceid = $('#InvoiceId').val();
                var url = GetFormatedUrl("/Payment/checkpayables");
                $.ajax({
                    type: "Get",
                    url: url,
                    data: {
                        InvoiceId: invoiceid
                    },
                    success: function (data) {
                        $('.CreditAmountLabel').text('Amount Received (' + "Total Payable: " + data.Amount + ")");
                        $("#InvoiceId").select2().find(":selected").attr("data-attr", data.Amount);
                        //alert(data.Amount);
                    }
                });
            });

            function GetStudentCreditNote(id) {
                $.ajax({
                    url: "/CreditNote/GetAllStudentCreditNote/" + id,
                    method: "Get",
                    success: function (data) {
                        var response = data.data;
                        $('.crd-dv').html('');
                        $('.crd-dv').hide();
                        if (response != null && response.length > 0) {

                            $.each(response, function (index, value) {

                                var message = value.Type === "Advance Payment"
                                    ? `This Customer Has an Advance Payment! Do You Want To Adjust Advance Payment (<b style="color:#c00606;">${value.Code}</b>) Of Amount`
                                    : `This Customer Has A Credit Note! Do You Want To Adjust Credit Note (<b style="color:#c00606;">${value.Code}</b>) Of Amount`;


                                var html = ` <div class="col-md-12" style="padding-top:8px;">
                                    <a href="#" class="crd-btn" onclick="AdjustCreditNote(${value.Id})">
                                    <i class="fa fa-plus-circle"></i></a>
                                    &nbsp;
                                    <span class="creditNote">
                                         ${message}
                                        <span id="crdNoteAmount-${value.Id}">
                                        <b style="color:#c00606;">${value.Amount} ${value.CurrencyName}</b>
                                        </span> ?
                                    </span>
                                    <input type="text" id="creditNoteId-${value.Id}" value="" hidden />
                                    </div>`;
                                $('.crd-dv').append(html);
                            });
                            $('.crd-dv').show();
                        }
                        var pymenttypeId = $("#CreditNotePaymentTypeId").val();
                        if (pymenttypeId != 0 || pymenttypeId != "") {
                            $("#PaymentTypeId option[value='" + pymenttypeId + "']").remove();
                            $("#CreditNotePaymentTypeId").val("");
                        }
                        $('#PaymentTypeId2').attr('disabled', true);
                        $('#CreditNoteId').val('');
                        $('#CreditAmount').attr('readonly', false);
                        $('#CreditAmount').val('');

                        $("#PaymentTypeId").select2({ disabled: '' });

                    }
                });
            }
            function GetOutStandingBalance(id) {

                $.ajax({
                    url: "/Payments/GetOutStandingBalance/" + id,
                    method: "Get",
                    success: function (data) {

                        var response = data.data;
                        var currency = data.currency; // Get currency name from response
                        $('.out-dv').html('');
                        $('.out-dv').hide();
                        if (response < 0) {
                            response = response * (-1);
                        }
                        if (response > 0) {


                            var html = ` <div class="col-md-12" style="padding-top:8px;">
                    <a href="#" class="crd-btn" onclick="AdjustOutStandingBalance()"><i class="fa fa-plus-circle"></i></a>
                    &nbsp;
                    <span class="creditNote">
                        This Customer Has An Outstanding Balance Of Amount <span><b style="color:#c00606;">${response} ${currency}</b></span>
                    </span>

                    </div>`;
                            $('.out-dv').append(html);

                            $('.out-dv').show();
                        }
                    }

                });
            }

            function CheckAmount() {
                var Amount = $('#CreditAmount').val();
                var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");

                if (Number(Amount) > Number(InvAmount)) {
                    $('#InvAmountValidation').removeAttr('hidden');
                    $('#CreditAmount').val("");
                }
                else {
                    $('#InvAmountValidation').attr("hidden", true);
                }
            }

            function AdjustCreditNote(id) {
                var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");
                if (InvAmount == "" || InvAmount == undefined) {
                    Toast.show("Please Select An Invoice", 'error');
                    return
                }
                $.ajax({
                    url: "/CreditNote/GetForPaymentById/" + id,
                    method: "Get",
                    success: function (data) {
                        var response = data.data;
                        if (response != null) {
                            var crdAmount = response.Amount;
                            var PaymentTypeId = response.PaymentTypeId;


                            if (Number(InvAmount) >= Number(crdAmount)) {
                                $("#CreditAmount").val(crdAmount);

                            } else {
                                $("#CreditAmount").val(InvAmount);
                            }
                            $("#CreditNoteId").val(response.Id);
                            $("#CreditAmount").attr("readonly", true);
                            $("#PaymentTypeId").select2({ data: [{ id: PaymentTypeId, text: 'Credit Note' }] });
                            $("#PaymentTypeId").val(PaymentTypeId);
                            $("#PaymentTypeId2").val(PaymentTypeId);
                            $("#CreditNotePaymentTypeId").val(PaymentTypeId);
                            $('#PaymentTypeId2').attr('disabled', false);
                            $("#PaymentTypeId").select2({ 'disabled': 'readonly' });
                        }
                    }
                });

            }

            function AdjustOutStandingBalance() {
                var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");
                if (InvAmount == "" || InvAmount == undefined) {
                    Toast.show("Please Select An Invoice", 'error');
                    return
                }
                var id = $('#StudentId').val();
                $.ajax({
                    url: "/Payments/GetForPaymentById/" + id,
                    method: "Get",
                    success: function (data) {
                        var response = data.data;
                        var response1 = data.data1;
                        if (response != null && response1 != null) {
                            var crdAmount = response;
                            var PaymentTypeId = response1;


                            if (Number(InvAmount) >= Number(crdAmount)) {
                                $("#CreditAmount").val(crdAmount);

                            } else {
                                $("#CreditAmount").val(InvAmount);
                            }
                            //$("#CreditNoteId").val(response.Id);
                            $("#CreditAmount").attr("readonly", true);
                            $("#PaymentTypeId").select2({ data: [{ id: PaymentTypeId, text: 'Adjusted From Outstanding Balance' }] });
                            $("#PaymentTypeId").val(PaymentTypeId);
                            $("#PaymentTypeId2").val(PaymentTypeId);
                            //$("#CreditNotePaymentTypeId").val(PaymentTypeId);
                            $('#PaymentTypeId2').attr('disabled', false);
                            $("#PaymentTypeId").select2({ 'disabled': 'readonly' });
                            $('.SubmitWithOutApprove').hide();
                        }
                    }
                });

            }

            function setInitialLocation() {

                var initialLocation = localStorage.getItem("selectedLocation");

                if (initialLocation) {

                    $('#LocationId').val(initialLocation);
                    $("#LocationId").prop('disabled', true);

                    $('#LocationId').change();
                }
            }

            $(document).ready(function () {
                setInitialLocation();
            });
        });

        // Make these functions globally accessible
        window.CheckAmount = function () {
            var Amount = $('#CreditAmount').val();
            var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");
            var errorMsg = $('#DebitAmountValidation');

            if (parseFloat(Amount) > parseFloat(InvAmount)) {
                $('#InvAmountValidation').removeAttr('hidden');
                $('#CreditAmount').val("");
            }
            else {
                $('#InvAmountValidation').attr("hidden", true);
            }
            if (Amount < 0 || isNaN(Amount)) {
                // Clear the invalid input
                $('#CreditAmount').val('');

                if (errorMsg.length === 0) {
                    // Create error message if it doesn't exist
                    $('#CreditAmount').after('<span class="text-danger" id="DebitAmountValidation" style="color: #c20e1a;">Amount must be greater than 0</span>');
                } else {
                    errorMsg.show();
                }
                return false;
            } else {
                // Hide error message if amount is valid
                if (errorMsg.length > 0) {
                    errorMsg.hide();
                }
                return true;
            }
        }

        window.AdjustCreditNote = function (id) {
            var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");
            if (InvAmount == "" || InvAmount == undefined) {
                Toast.show("Please Select An Invoice", 'error');
                return
            }
            $.ajax({
                url: "/CreditNote/GetForPaymentById/" + id,
                method: "Get",
                success: function (data) {
                    var response = data.data;
                    if (response != null) {
                        var crdAmount = response.Amount;
                        var PaymentTypeId = response.PaymentTypeId;


                        if (Number(InvAmount) >= Number(crdAmount)) {
                            $("#CreditAmount").val(crdAmount);

                        } else {
                            $("#CreditAmount").val(InvAmount);
                        }
                        $("#CreditNoteId").val(response.Id);
                        $("#CreditAmount").attr("readonly", true);
                        $("#PaymentTypeId").select2({ data: [{ id: PaymentTypeId, text: 'Credit Note' }] });
                        $("#PaymentTypeId").val(PaymentTypeId);
                        $("#PaymentTypeId2").val(PaymentTypeId);
                        $("#CreditNotePaymentTypeId").val(PaymentTypeId);
                        $('#PaymentTypeId2').attr('disabled', false);
                        $("#PaymentTypeId").select2({ 'disabled': 'readonly' });
                    }
                }
            });
        };

        window.AdjustOutStandingBalance = function () {
            var InvAmount = $("#InvoiceId").select2().find(":selected").attr("data-attr");
            if (InvAmount == "" || InvAmount == undefined) {
                Toast.show("Please Select An Invoice", 'error');
                return
            }
            var id = $('#StudentId').val();
            $.ajax({
                url: "/Payments/GetForPaymentById/" + id,
                method: "Get",
                success: function (data) {
                    var response = data.data;
                    var response1 = data.data1;
                    if (response != null && response1 != null) {
                        var crdAmount = response;
                        var PaymentTypeId = response1;


                        if (Number(InvAmount) >= Number(crdAmount)) {
                            $("#CreditAmount").val(crdAmount);

                        } else {
                            $("#CreditAmount").val(InvAmount);
                        }
                        //$("#CreditNoteId").val(response.Id);
                        $("#CreditAmount").attr("readonly", true);
                        $("#PaymentTypeId").select2({ data: [{ id: PaymentTypeId, text: 'Adjusted From Outstanding Balance' }] });
                        $("#PaymentTypeId").val(PaymentTypeId);
                        $("#PaymentTypeId2").val(PaymentTypeId);
                        //$("#CreditNotePaymentTypeId").val(PaymentTypeId);
                        $('#PaymentTypeId2').attr('disabled', false);
                        $("#PaymentTypeId").select2({ 'disabled': 'readonly' });
                        $('.SubmitWithOutApprove').hide();
                    }
                }
            });
        };
    </script>

}
