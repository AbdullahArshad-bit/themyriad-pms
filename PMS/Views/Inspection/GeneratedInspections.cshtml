@model List<PMS.DTO.ViewModels.InspectionViewModels.GenetatedInspectionsVM>
@using PMS.Common.Classes

@{
    ViewBag.Header = "Generated Inspections";
    ViewBag.HeaderDescription = "All Generated Inspections";
    ViewBag.Title = "Generated Inspections | PMS";

    //var placements = ViewBag.Placements as List<PMS.DTO.ViewModels.BedSpacePlacementViewModels.PlacementsListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
    <style>
        .highlight {
            border-color: #c20e1a !important;
        }
    </style>
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div style="overflow: auto; width:100%;white-space:nowrap;">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Bedspace</th>
                            <th>Bedspace ID</th>
                            <th>CreatedDate</th>
                            <th>CreatedBy</th>
                            <th>UpdatedDate</th>
                            <th>UpdatedBy</th>
                            <th>Remarks</th>
                            <th>Staff Status</th>
                            <th>Student Status</th>
                            <th>Maintenance Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.InspectionName</td>
                                <td>@item.InspectionType</td>
                                <td>@item.BedSpaceName</td>
                                <td>@item.BedSpaceID</td>
                                <td>@(item.CreatedDate==null?"":((DateTime)item.CreatedDate).ToString("dd/MM/yyy"))</td>
                                <td>@item.CreatedBy</td>
                                <td>@(item.UpdatedDate == null?"":((DateTime)item.UpdatedDate).ToString("dd/MM/yyy"))</td>
                                <td>@item.UpdatedBy</td>
                                <td>@item.Remarks</td>
                                @if (item.Staff_Status != "Pending")
                                {
                                    <td><span class='label label-success'>@item.Staff_Status</span></td>

                                }
                                else
                                {
                                    <td><span class='label label-danger'>@item.Staff_Status</span></td>

                                }
                                @if (item.Student_Status != "Pending")
                                {
                                    <td><span class='label label-success'>@item.Student_Status</span></td>

                                }
                                else
                                {
                                    <td><span class='label label-danger'>@item.Student_Status</span></td>

                                }
                                @if (item.Maintenance_Status != "Pending")
                                {
                                    <td><span class='label label-success'>@item.Maintenance_Status</span></td>

                                }
                                else
                                {
                                    <td><span class='label label-danger'>@item.Maintenance_Status</span></td>

                                }




                                <td>

                                    <a title="Edit" id="GeneratedInspectionForm" datashow-id="@item.InspectionID" @("onclick=OpenConfirmInspectionModal(" + @item.ID + ") style='color:green;display:inline-block'") href="#"><i class="fa fa-edit"></i></a>

                                    @if (User.IsInRole(AppUserRoles.delete_users) && item.Staff_Status != "Approved" && item.Staff_Status != "Statrted" &&
                                        item.Student_Status != "Approved" && item.Student_Status != "Statrted" && item.Maintenance_Status != "Approved" && item.Maintenance_Status != "Started")
                                    {
                                        <a title="Delete" href="#" @("onclick=OpenConfirmDeletenModal(" + @item.ID + ") ") @*data-href="@Url.Action("DeleteGenerateInspection", "Inspection", new { id = item.ID })" data-toggle="modal" data-target="#confirm-delete"*@><i class="fa fa-remove"></i></a>
                                    }
                                    <a title="View" id="GeneratedInspectionView" target="_blank" href="@Url.Action("GeneratedInspectionView", "Inspection", new { id = item.ID })"><i class="fa fa-eye" aria-hidden="true"></i></a>

                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>

                    </tfoot>
                </table>

            </div>

        </div>
    </div>
</div>
<div class="modal" id="GeneratedInspectionConfirm">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Edit Generated Inspection</h4>
            </div>
            <div class="modal-body">

                <div class="row col-sm-12">
                    <label>Change Maintenance Status</label>
                </div>
                <div class="col-md-12">
                    @Html.DropDownList("Status", null, "Select...       ", htmlAttributes: new { @class = "Dropdown form-control ", @required = "required", style = "min-width:125px" })

                </div>


                <div class="row col-sm-12">
                    <label>Change Staff Status</label>
                </div>
                <div class="col-md-12">
                    @Html.DropDownList("StaffStatus", null, "Select...       ", htmlAttributes: new { @class = "Dropdown form-control ", @required = "required", style = "min-width:125px" })

                </div>


                <div class="row col-sm-12">
                    <label>Change Student Status</label>
                </div>
                <div class="col-md-12">
                    @Html.DropDownList("StudentStatus", null, "Select...       ", htmlAttributes: new { @class = "Dropdown form-control", @required = "required", style = "min-width:125px" })

                </div>
                <div class="col-md-12">
                    <label for="Remarks">Any Addition Notes:</label>
                </div>
                <div class="col-md-12">
                    <textarea id="Remarks" name="Remarks" placeholder="Enter Your Remarks" rows="4" cols="80" style="min-height:125px"></textarea>
                </div>




            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <a class="btn btn-themyriad btn-ok" onclick="EditInspection()">Run Operation</a>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

<div class="modal" id="InspectionConfirm">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Inspection Result</h4>
            </div>
            <div class="modal-body">
                <div class="row" id="Field_Body">

                </div>
                <div class="row" style="border-bottom: 1px solid #e5e5e5; padding-bottom: 13px;"></div>
                <div class="row" id="Field_Body1" style="height: 228px; overflow: auto; padding-top: 18px; ">
                    <div class="hidden">
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <a class="btn btn-themyriad btn-ok SaveInspectionReport" onclick="SaveInspectionReport()">Save</a>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>


<div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>You are about to delete this record. This process is irreversible.</p>
                <p> Are you sure?</p>
                <p class="debug-url"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button onclick="DeleteGenerateInspection()" class="btn btn-themyriad btn-ok">Delete</button>
            </div>
        </div>
    </div>

</div>




@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>
    <script src="~/Assets/js/GenerateInspection.js" type="text/javascript"></script>


    <script>


    </script>
}
