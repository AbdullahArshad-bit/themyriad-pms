@model List<PMS.DTO.ViewModels.InspectionViewModels.InspectionFieldsVM>

@using PMS.Common.Classes

@{
    /**/

    ViewBag.Header = "Inspection Fields";
    ViewBag.HeaderDescription = "All Inspection Fields";
    ViewBag.Title = "Inspection Fields | PMS";

    var inspectionFields = ViewBag.InspectionFields as List<PMS.DTO.ViewModels.InspectionViewModels.InspectionFieldsVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }


            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_InspectionFields))
                    {
                        <a href="@Url.Action("AddInspectionField", "Inspection")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add Inspection Field</a>
                    }</div>
            </div>

            <div style="overflow: auto; width:100%;white-space:nowrap;">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Model Name</th>
                            <th>Short Label</th>
                            <th>Rating List</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in inspectionFields)
                        {
                            <tr>
                                <td>@item.ModelName</td>
                                <td>@item.ShortLabel</td>
                                <td>@item.ratingList</td>
                                @if (item.IsActive == true)
                                {
                                    <td><span class='label label-success'>Yes</span></td>

                                }
                                else
                                {
                                    <td><span class='label label-danger'>No</span></td>
                                }
                            <td class="menu-icons" style="text-align:inherit">
                                @if (User.IsInRole(AppUserRoles.add_InspectionFields))
                                {
                                    <a title="Edit" href="@Url.Action("AddInspectionField", "Inspection", new { @id = item.INspectionFieldID })"><i class="fa fa-edit"></i></a>
                                }
                                @if (User.IsInRole(AppUserRoles.delete_InspectionFields))
                                {
                                    <a title="Delete" href="#" @("onclick=OpenConfirmDeletenModal(" + @item.INspectionFieldID + ") ")><i class="fa fa-remove"></i></a>
                                }
                            </td>
                            </tr>
                        }

                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Model Name</th>
                            <th>Short Label</th>
                            <th>Rating List</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">


    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>You are about to delete this record. This process is irreversible.</p>
                <p> Are you sure?</p>
                <p class="debug-url"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button onclick="DeleteInspectionField()" class="btn btn-themyriad btn-ok">Delete</button>
            </div>
        </div>
    </div>



</div>
@section scripts{

    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({});
        })
        var id = "";
        function OpenConfirmDeletenModal(ID) {

            id = ID;

            $('#confirm-delete').modal('show');

        }

        function DeleteInspectionField() {

            $.ajax({

                url: GetFormatedUrl("/Inspection/DeleteInspectionField?id=" + id),
                type: "GET",

                dataType: "json",
                contentType: "application/json;charset=UTF-8",

                success: function (data) {
                    if (data.Success != 'true' && data.Code == 404) {

                        return;
                    }
                    if (data.success != 'false') {
                        window.location.href = GetFormatedUrl("/Inspection/InspectionField");

                    }
                }
            })


        }

    </script>
}
