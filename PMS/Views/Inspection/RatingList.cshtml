@using PMS.Common.Classes

@{
    ViewBag.Header = "Rating List";
    ViewBag.HeaderDescription = "All Rating List";
    ViewBag.Title = "Rating List | PMS";

    var ratings = ViewBag.Ratings as List<PMS.DTO.ViewModels.InspectionViewModels.RatingListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">
                    @if (User.IsInRole(AppUserRoles.add_InspectionRating))
                    {
                        <a href="@Url.Action("AddRatingList", "Inspection")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New Rating List</a>
                    }
                </div>
            </div>
            <div style="overflow: auto; width:100%;white-space:nowrap;">
                <table class="table table-bordered table-striped data-table">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Name</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ratings)
                        {
                            <tr>
                                <td class="menu-icons" style="text-align:inherit">
                                    <a title="View Ratings" href="javascript:GetRatings(@item.InspectionRatingListID)"><i class="fa fa-search"></i> View Ratings</a>
                                </td>
                                <td>@item.Name</td>
                                @if (item.IsActive == true)
                                {
                                    <td><span class='label label-success'>Yes</span></td>

                                }
                                else
                                {
                                    <td><span class='label label-danger'>No</span></td>

                                }
                                <td class="menu-icons" style="text-align:inherit">
                                    @if (User.IsInRole(AppUserRoles.add_InspectionRating))
                                    {
                                        <a title="Edit" href="@Url.Action("AddRatingList", "Inspection", new { id = item.InspectionRatingListID })"><i class="fa fa-edit"></i></a>
                                    }
                                    @if (User.IsInRole(AppUserRoles.delete_InspectionRating))
                                    {
                                        <a title="Delete" href="#" @("onclick=OpenConfirmDeleteModal(" + @item.InspectionRatingListID + ") ")><i class="fa fa-remove"></i></a>

                                    }

                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th>Name</th>
                            <th>Active</th>
                            <th>Action</th>
                        </tr>
                    </tfoot>
                </table>

            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">


    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>You are about to delete this record. This process is irreversible.</p>
                <p> Are you sure?</p>
                <p class="debug-url"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button onclick="DeleteInspection()" class="btn btn-themyriad btn-ok">Delete</button>
            </div>
        </div>
    </div>



</div>
<div class="modal fade" id="modal_div" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">

</div>

@section scripts{

    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({});
        })

        function GetRatings(n) {
            $.ajax({
                url: "/Inspection/GetRatings",
                method: "Get",
                dataType: "html",
                contentType: 'application/json; charset=utf-8',
                data: { id: n },
                beforeSend: function () {
                    $('#loader').show();
                },
                complete: function () {
                    $('#loader').fadeOut('slow');
                },
                success: function (data) {
                    $("#modal_div").html(data);
                    $('#modal_div').modal('show');

                    //$('#table').DataTable({});
                },
                error: function (xhr) {
                    showMessage(xhr.status + " - " + xhr.statusText);

                }
            });
        }

        var id = "";
        function OpenConfirmDeleteModal(ID) {

            id = ID;

            $('#confirm-delete').modal('show');

        }

        function DeleteInspection() {

            $.ajax({

                url: GetFormatedUrl("/Inspection/DeleteRatingList?id=" + id),
                type: "GET",

                dataType: "json",
                contentType: "application/json;charset=UTF-8",

                success: function (data) {
                    if (data.Success != 'true' && data.Code == 404) {

                        return;
                    }
                    if (data.success != 'false') {
                        window.location.href = GetFormatedUrl("/Inspection/RatingList");

                    }
                }
            })


        }
    </script>
}
