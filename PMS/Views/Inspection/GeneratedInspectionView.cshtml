@model PMS.DTO.ViewModels.InspectionViewModels.InspectionViewVM
@using PMS.Common.Classes

@{
    ViewBag.Header = "Inspection View";
    ViewBag.HeaderDescription = "Inspection View";
    ViewBag.Title = "Inspection View | PMS";

    //var placements = ViewBag.Placements as List<PMS.DTO.ViewModels.BedSpacePlacementViewModels.PlacementsListVM>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <style>
        hr {
            height: 47px !important;
        }

        textarea {
            margin: 0px;
            height: 32px;
            width: 1253px !important;
        }
    </style>
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="padding: initial !important;">

                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Inspection:-</label>
                    </div>
                    <div class="col-sm-6">
                        <label>@Model.InspectionName</label>
                    </div>


                </div>
                <div class="col-sm-3">

                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Created Date:-</label>
                    </div>
                    <div class="col-sm-6">
                        <label>@Model.CreatedDate</label>

                    </div>



                </div>

                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Bed Space:-</label>

                    </div>
                    <div class="col-sm-6">
                        <label>@Model.BedSpace</label>

                    </div>
                </div>

                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Valid for days:-</label>

                    </div>
                    <div class="col-sm-6">
                        <label>@Model.EffectiveDays</label>

                    </div>
                </div>
            </div>
            <hr>
            <div class="col-sm-12" style="padding: initial !important;">
                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Student status:-</label>

                    </div>
                    <div class="col-sm-6">
                        <label>@Model.StudentStatus</label>

                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Staff Status:-</label>

                    </div>
                    <div class="col-sm-6">
                        <label>@Model.StaffStatus</label>

                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="col-sm-6">
                        <label style="color:#c20e1a">Maintenance Status:-</label>

                    </div>
                    <div class="col-sm-6">
                        <label>@Model.MaintannaceStatus</label>

                    </div>
                </div>


            </div>

            <div class="col-sm-12" style="padding-left: inherit !important;">
                <div class="col-sm-12">
                    <label style="color:#c20e1a">Maintenance Notes:-</label>

                </div>
                <div class="col-sm-12">
                    <textarea readonly>@Model.MaintananceRemarks</textarea>

                </div>

            </div>

            <div style="overflow: auto; width:100%;white-space:nowrap;">

                <table class="table table-bordered table-striped data-table">

                    <thead>

                        <tr>
                            <th>Inspection Field</th>
                            <th>Rating Value </th>
                            <th>Note</th>
                            <th>Recommend Charge Percentage</th>
                            <th>Image</th>



                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.IFL)
                        {
                            <tr>
                                <td>@item.FieldName</td>
                                <td>@item.SelectedRating</td>
                                <td>@item.Note</td>
                                <td>@item.RecomendedCharge</td>
                                @if (item.ImageAttached != null)
                                {
                                    <td><img src="@item.ImageAttached" alt="InspectionImage" width="200" height="100"></td>
                                }
                                else
                                {
                                    <td>Not Exists</td>
                                }

                            </tr>
                        }
                    </tbody>
               
                </table>

            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">


    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>You are about to delete this record. This process is irreversible.</p>
                <p> Are you sure?</p>
                <p class="debug-url"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button onclick="DeleteInspection()" class="btn btn-themyriad btn-ok">Delete</button>
            </div>
        </div>
    </div>



</div>
@section scripts{

    <script src="~/Assets/bower_components/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="~/Assets/bower_components/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="//cdn.datatables.net/plug-ins/1.10.11/sorting/date-eu.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({});
        })


        var id = "";
        function OpenConfirmDeleteModal(ID) {

            id = ID;

            $('#confirm-delete').modal('show');

        }

        function DeleteInspection() {

            $.ajax({

                url: GetFormatedUrl("/Inspection/DeleteInspection?id=" + id),
                type: "GET",

                dataType: "json",
                contentType: "application/json;charset=UTF-8",

                success: function (data) {
                    if (data.Success != 'true' && data.Code == 404) {

                        return;
                    }
                    if (data.success != 'false') {
                        window.location.href = GetFormatedUrl("/Inspection/Inspection");

                    }
                }
            })


        }

    </script>
}
