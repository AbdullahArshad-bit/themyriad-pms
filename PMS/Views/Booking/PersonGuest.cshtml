@model List<PMS.DTO.ViewModels.BedSpacePlacementViewModels.GuestCountListVM>

@using PMS.Common.Classes

@{
    ViewBag.Header = "Person Guests";
    ViewBag.HeaderDescription = "All Person Guests";
    ViewBag.Title = "Person Guests | PMS";

}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
}
<style>
    .right {
        text-align: right;
    }

    .openCheckOutGuestModal {
        cursor: pointer; /* Apply the pointer cursor style */
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }@if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="input-group-btn">

                    @if (User.IsInRole(AppUserRoles.add_acc_Services))
                    {
                        <a href="@Url.Action("AddGuestCount", "Booking")" class="btn btn-themyriad"><i class="fa fa-plus" style="padding-right: 5px;"></i> Add New GuestCount   </a>
                    }

                </div>
            </div>

            <form method="post" action="@Url.Action("CheckOutPersonGuest", "Booking")">

                <div class="modal fade" id="CheckOutGuestModal" tabindex="-1" role="dialog" aria-labelledby="CheckOutGuestModalLabel" aria-hidden="true">
                    <div class="modal-dialog">

                        <div class="modal-content">
                            <input type="hidden" id="personGuestIDInput" name="ID" value="" />

                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                                <h4 class="modal-title" id="CheckOutGuestModalLabel">Check Out Guest</h4>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure to check out the guest?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>

                                <button type="submit" class="btn btn-themyriad btn-ok" id="confirmYes">Yes</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="overflow: auto; width:100%;white-space:nowrap;">
                    <table class="table table-bordered table-striped data-table">

                        <thead>
                            <tr>
                                <th>Location</th>
                                <th>Title</th>
                                <th>MyriadID</th>
                                <th>Full Name</th>
                                <th>Bed Room</th>
                                <th>Guest Count</th>
                                <th>ID Number</th>
                                <th>Guest Name</th>
                                <th>Visitor Card Number</th>

                                <th>Description</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.LocationName</td>
                                    <td>@item.Title</td>
                                    <td>@item.Code</td>
                                    <td>@item.FullName</td>
                                    <td>@item.BedRoom</td>
                                    <td>@item.GuestCount</td>
                                    <td>@item.IDNumber</td>
                                    <td>@item.GuestName</td>
                                    <td>@item.VisitorCardNumber</td>
                                    <td>@item.Description</td>
                                    <td>
                                        @if (item.GuestCount > 0)
                                        {
                                            <a title="Check out guest" class="openCheckOutGuestModal" data-personGuestID="@item.PersonGuestID"><i class="fa fa-users"></i></a>
                                        }

                                        else
                                        {
                                            <span></span>
                                        }

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_div" tabindex="-1" role="dialog" aria-labelledby="CheckOutGuestModalLabel" aria-hidden="true">

</div>

@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>

    <script>
        $(function () {
            $('.data-table').DataTable({
                "scrollY": "70vh",
                "scrollCollapse": true,
                "scrollX": "auto",
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5',
                ],
            });
        })

        $('.openCheckOutGuestModal').click(function () {
            var personGuestID = $(this).attr('data-personGuestID');
            $('#personGuestIDInput').val(personGuestID);
            $('#CheckOutGuestModal').modal('show');
        });



    </script>
}
