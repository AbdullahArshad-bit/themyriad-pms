@model PMS.EF.Invoicing
@using PMS.Common.Classes;
@using PMS.DTO.ViewModels;
@using PMS.DTO.ViewModels.SetupViewModels

@{
    ViewBag.Header = "Invoicing";
    ViewBag.HeaderDescription = "Print Invoice";
    ViewBag.Title = "Print Invoice | PMS";

    var statementUrl = Url.Action("PartnerLedger", "payments", new { personId = Model.StudentId });
}
@{
    var Details = (List<InvoicingDetailVM>)ViewBag.InvoicingDetail;
    var locationSetting = (LocationSettingsVM)ViewBag.LocationSetting;
    var receipt = ViewBag.ReceiptDetail as List<PMS.DTO.ViewModels.PaymentViewModels.PaymentVM>;
    @Html.HiddenFor(x => x.InvoiceTypeId)

    var pendingBalance = ViewBag.PendingBalance ?? 0;
    var totalBalanceOfResident = ViewBag.TotalBalanceOfResident ?? 0;

}
<div class="box-header with-border no-print">
    <div class="input-group-btn">
        <a href="@Url.Action("Index", "Invoicings")" class="btn btn-themyriad"><i class="fa fa-arrow-left" style="padding-right: 5px;"></i>Back to Invoices</a>
    </div>
</div>

<section class="invoice" id="Pdf2">
    <!-- title row -->
    <div class="row">
        <div class="col-xs-12">
            <h2 class="page-header">
                @*<span class="logo-lg"><img src="@Url.Content("~/Assets/Images/logo.png")" alt="logo"></span>*@
                <span class="logo-lg"><img src="https://themyriad.com/Assets/images/logo.png" alt="logo"></span>
            </h2>
        </div>
        <!-- /.col -->
    </div>
    <!-- info row -->
    <div class="row invoice-info">
        <div class="col-sm-4 invoice-col">
            <b>Invoice#: @Model.Code </b><br>
            <b>Location: </b> @Model.Location.LocationName<br />
            <b>Myriad ID:</b> <a href="#" onclick="window.open('@statementUrl');">@Model.Person.Code:  @Model.Person.FullName </a><br>
            <b>Phone Number: </b> @Model.Person.Phone<br>
            <b>Invoice Date:</b>  @Model.InvoiceDate.ToString("dd/MM/yyyy")<br>
            <b>Currency: </b> @Model.Location.Currencies.Select(x => x.Name).FirstOrDefault()<br>
            <b>Status:</b> @{
                if (Model.IsApproved)
                {
                    <span class="label label-success">Approved</span>
                }
                else
                {
                    <span class="label label-primary">Pending</span>

                }

            } <br>
            <b>Created By: </b>@Model.UserMaster.FullName<br>
            <b>Approved By: </b>@(Model.UserMaster1==null? "":Model.UserMaster1.FullName)<br>
            @*<b>Account:</b> @Model.NetAmount
                <br />*@
        </div>
        @if (Model.Refunded == true && Model.IsPaid != null)
        {
            <div class="col-md-4" style="text-align: center">
                <h1><span style="color: #c20e1a; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">REFUNDED</span></h1><br>
            </div>
        }
        else if (Model.Refunded == true && Model.IsPaid == null)
        {
            <div class="col-md-4" style="text-align: center">
                <h1><span style="color: #c20e1a; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">Reversed</span></h1><br>
            </div>
        }

        else if (Model.Refunded == true && Model.IsPaid == null && Model.ParentInvoiceId != null)
        {
            <div class="col-md-4" style="text-align: center">
                <h1><span style="color: #c20e1a; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">Reversed</span></h1><br>
            </div>
        }
        else if (Model.IsPaid == true)
        {
            <div class="col-md-4" style="text-align: center">
                <h1><span style="color: #00a65a; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">PAID</span></h1><br>
            </div>
        }
        @*else if (pendingBalance > 0 && totalBalanceOfResident > 0)
            {
                <div class="col-md-4" style="text-align: center">
                    <h1><span style="color: #c20e1a; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">Reversed-Credit Note</span></h1><br>
                </div>
            }*@
        else if (Model.IsPaid == null)
        {
            <div class="col-md-4" style="text-align: center">
                <h1><span style="color: #DAA520; font-size: 38px; font-family: Lucida Console, Courier New,monospace ">UNPAID</span></h1><br>
            </div>
        }

        else
        {

        }
        <div class="col-md-4">

        </div>
        <div class="col-md-4" style="text-align: right">
            <span style="color: #c20e1a;">@locationSetting.CompanyName</span><br>
            @if (Model.LocationId == ((int)Enumeration.LocationEnum.Muscat))
            {
                <b>VATIN: </b><span style="color: #c20e1a;">@locationSetting.VATNo</span>
            }
            else if (Model.LocationId == ((int)Enumeration.LocationEnum.Dubai))
            {
                <b>TRN: </b><span style="color: #c20e1a;">@locationSetting.VATNo</span>
            }
        </div>

        <!-- /.col -->
    </div>
    <!-- /.row -->
    <!-- Table row -->
    <div class="row">
        <div class="table-responsive">
            <table class="table table-striped" id="InvoiceTypeId" typeof="hidden">
                <thead>
                    <tr>
                        <th>Sr#</th>
                        <th>Service</th>
                        <th>Description</th>
                        <th class="datetd">FromDate</th>
                        <th class="datetd">toDate</th>
                        <th>Amount</th>
                        <th class="col-md-3">Tax</th>
                        <th>Discount%</th>
                        <th>Net Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int count = 1; }
                    @foreach (var item in Details)
                    {

                        <tr>
                            <td>@count</td>
                            <td>@item.ServiceName</td>
                            <td>@item.Description</td>
                            <td class="datetd">@item.FromDateString</td>
                            <td class="datetd">@item.ToDateString</td>

                            <td>@item.Price</td>
                            <td>
                                <select name=det[@count][TaxesIds] autocomplete="off" class="form-control select2 taxes" id="TaxIds" multiple="multiple" data-Taxids="@item.TaxesIds" disabled></select>
                            </td>
                            <td>@item.DiscountPercentage</td>
                            <td>@item.TotalAmount</td>
                        </tr>
                        count++;
                    }

                </tbody>
            </table>
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->

    <div class="row">
        <!-- accepted payments column -->
        <div class="col-xs-8">
            <p class="lead" style="font-size: 15px; font-weight: 500;">Remarks:</p>
            <p class="text-muted well well-sm no-shadow" style="margin-top: 10px;">
                @Model.Remarks
            </p>
        </div>
        <!-- /.col -->
        <div class="col-xs-4">
            <div class="table-responsive">
                <table class="table" id="mytable">
                    <tbody>
                        <tr>
                            <th style="width:50%">Subtotal:</th>
                            <td>@Model.TotalPrice</td>
                        </tr>
                        <tr>
                            <th>Tax Amount:</th>
                            <td>@Model.TaxAmount</td>
                        </tr>
                        <tr>
                            <th>Discount Amount:</th>
                            <td>@Model.TotalDiscountAmount</td>
                        </tr>


                        @if (Model.InvoiceTaxDetails != null)
                        {
                            foreach (var item in Model.InvoiceTaxDetails.ToList())
                            {
                                <tr>
                                    <th>@item.TaxName</th>
                                    <td>@item.TaxAmount</td>
                                </tr>
                            }
                        }
                        <tr>
                            <th>Net Total:</th>
                            <td>@Model.NetAmount</td>
                        </tr>
                        @foreach (var item in receipt)
                        {
                            <tr>
                                <th><a href="@Url.Action(" Details","Payments", new { id=item.Id })">@item.TransactionCode</a></th>
                                @*<th>@item.TransactionCode</th>*@
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <td style="margin-left:80px;">(@item.Amount)</td>
                            </tr>

                        }
                        <tr>
                            <th>Remaining</th>
                            <td>@ViewBag.total</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
    <!-- this row will not appear when printing -->
    <div class="row no-print">
        <div class="col-xs-12">
            <a href="#" onclick="window.print();" id="btnPrint" class="btn btn-default"><i class="fa fa-print"></i> Print</a>
            <a href="#" onclick="Print()" class="btn btn-primary"><i class="fa fa-download"></i> Download Report</a>

            @if (Model.Location.LocationName == "Dubai")
            {
                <a href="#" onclick="GetHtml('#Pdf2')" id="printBtn" class="btn btn-default"><i class="fa fa-envelope"></i> Email Invoice</a>
            }

            <a href="#" onclick="SendInvoicePushNotification()" id="pushNotifyBtn" class="btn btn-warning">
                <i class="fa fa-bell"></i> Push Notification
            </a>

            @if (Model.IsApproved != true)
            {
                if (User.IsInRole(AppUserRoles.Approve_acc_Invoice))
                {
                    <button type="button" id="Approve" class="btn btn-success pull-right">
                        <i class="fa fa-thumbs-up"></i> Approve
                    </button>
                }
            }
        </div>
    </div>
</section>
@section scripts
{
    <script src="~/Scripts/jquery-3.3.1.min.js"></script>
    <script src="~/Scripts/jquery-3.3.1.js"></script>
    <script src="/PMS/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <!-- Select2 -->
    <script src="~/Assets/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script src="~/Scripts/Common.js"></script>
    <script>
        $(document).ready(function () {
            var printable = GetQueryStringValue("prnt");
            if (printable == 1) {
                $('#btnPrint').click();
            }
        });
    $('#Approve').on('click', function () {
        $.ajax({
            type: "Get",
            url: GetFormatedUrl('/Invoicings/ApproveInvoice/') + '@Model.Id',
            async: true,
            success: function (data) {
                var data = data.status;
                if (data == true) {
                    window.location.reload();
                    $('#Approve').addClass('hide');
                }
            },
            error: function (data) {
                $('#Piechartdiv').text('Some error occured !', 'error')
            }
        });
    });
        function Print() {
            window.open('/Reporting/GenerateInvoiceDetailReport?Id='+@Model.Id,'_blank');
        }
    GetTaxesEdit();
    $('.taxes').each(function (i, e) {
        $(this).select2().val($(this).attr('data-taxids').split(',')).trigger("change");
    })


    function GetTaxesEdit() {
        var url = GetFormatedUrl("/Invoicings/GetTaxes")
        $.ajax({
            type: "Get",
            url: url,
            async: false,
            success: function (data) {
                var data = data.data;
                $(".taxes").html('');
                var html = "";
                $.each(data, function (key, value) {
                    html = html + "<option Value='" + value.Value + "'>" + value.Text + "</option>"
                })
                $(".taxes").html(html);

            }
        });
        }

        function SendInvoicePushNotification() {
            $('.Customoverlay, .Customloader').show();

            $.ajax({
                type: "Post",
                url: GetFormatedUrl('/Invoicings/SendInvoicePushNotification'),
                data: { id: @Model.Id },
                success: function (data) {
                    $('.Customoverlay, .Customloader').hide();
                    if (data.success) {
                        swal("Push notification sent!", data.message || "", "success");
                    } else {
                        swal("Unable to send push notification", data.message || "", "error");
                    }
                },
                error: function () {
                    $('.Customoverlay, .Customloader').hide();
                    swal("Some error occurred!", "", "error");
                }
            });
        }

        function GetHtml(selector) {
            var ht = '';
            $('.Customoverlay, .Customloader').show();

            $.ajax({
                type: "Get",
                url: GetFormatedUrl('/Invoicings/InvoiceHtml/') + '@Model.Id',
                dataType: 'html',
                async: false,
                success: function (response)
                {
                    ht = jQuery(response).find(selector).html();
                }
            });

            $.ajax({
            type: "Post",
                url: GetFormatedUrl('/Invoicings/SendInvoiceByEmail'),
                async: true,
                data: {
                subject: 'The Myriad ' + '@Model.Location.LocationName ' + 'Invoice - ' + '@Model.Code',
                body: ht,
                isBodyHtml: true,
                to: '@Model.Person.Email',
                locationId: @Model.LocationId

            },
                success: function (data) {
                   $('.Customoverlay, .Customloader').hide();

                swal("Email Sent Successfully!", "", "success");
            },
                error: function (data) {
                    $('.Customoverlay, .Customloader').hide();

                $('#Piechartdiv').text('Some error occured !', 'error')
            }
        });

        }

        function getElementChildrenAndStyles(selector) {
            var test = $(selector).clone();
            var html = test[0].outerHTML

            selector = selector.split(",").map(function (subselector) {
                return subselector + "," + subselector + " *";
            }).join(",");
            elts = $(selector);

            var rulesUsed = [];
            // main part: walking through all declared style rules
            // and checking, whether it is applied to some element
            Stylesheets = document.styleSheets;
            var sheets = [];
            $(Stylesheets).each(function (i, e) {
                if (e.href != null && !e.href.includes('font')) {
                    sheets.push(e);
                }
            })
            for (var c = 0; c < sheets.length; c++) {
                var url = sheets[c].href;
                    var rules = sheets[c].rules || sheets[c].cssRules;
                    for (var r = 0; r < rules.length; r++) {
                        var selectorText = rules[r].selectorText;
                        var matchedElts = $(selectorText);
                        for (var i = 0; i < elts.length; i++) {
                            if (matchedElts.index(elts[i]) != -1) {
                                rulesUsed.push(rules[r]);
                                break;
                            }
                        }
                    }

            }
            var style = rulesUsed.map(function (cssRule) {
                if (cssRule.style) {
                    var cssText = cssRule.style.cssText.toLowerCase();
                } else {
                    var cssText = cssRule.cssText;
                }
                // some beautifying of css
                return cssText.replace(/(\{|;)\s+/g, "\$1\n  ").replace(/\A\s+}/, "}");
                //                 set indent for css here ^
            }).join("\n");
            var htt = ''
            $(sheets).each(function (i, e) {
               htt = htt + '<link rel="stylesheet" href="' + e.href + '">'

            })
            var css = '<style> table, th, td {border: 1px solid black;} </style>'
            return htt + css + html;
            //return "<style>\n" + style + "\n</style>\n\n" + html;
        }
        $(document).ready(function () {

          var typeId = $("#InvoiceTypeId").val();
          if (typeId == 1)
          $('.datetd').show(); //regular invoice
          else
          $('.datetd').hide(); //deposit invoice

          $('.date').val('');
          });


    </script>

    <style>
        .selection--multiple {
            border: none !important;
            background-color: transparent !important;
        }
    </style>
}
