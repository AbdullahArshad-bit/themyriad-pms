@using PMS.Common.Classes
@{
    ViewBag.Header = "Invoices";
    ViewBag.HeaderDescription = "All Invoices";
    ViewBag.Title = "Invoices | PMS";
}
@{
    var editAction = User.IsInRole(AppUserRoles.add_acc_Invoice);
    var approveAction = User.IsInRole(AppUserRoles.Approve_acc_Invoice);
    var editAterApproveAction = User.IsInRole(AppUserRoles.Edit_AfterApprove_acc_Invoice);
    var invDetAction = User.IsInRole(AppUserRoles.view_acc_InvoiceDetail);
    var reverseInvoiceAction = User.IsInRole(AppUserRoles.Reverse_Invoice);
    var invoiceVoucherAction = User.IsInRole(AppUserRoles.View_Invoicing_Voucher_Detail);
    var paymentLinkAction = User.IsInRole(AppUserRoles.View_Payment_Link);
    var dubaiLocationId = (int)Enumeration.LocationEnum.Dubai;
    var muscatLocationId = (int)Enumeration.LocationEnum.Muscat;
    var rentalInvoiceTypeId = (int)Enumeration.InvoiceTypes.Rental;
    var depositInvoiceTypeId = (int)Enumeration.InvoiceTypes.Deposit;
    var miscellaneousInvoiceTypeId = (int)Enumeration.InvoiceTypes.Miscellaneous;
}
@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/css/bootstrap-multiselect.css">

}
<style>
    .right {
        text-align: right;
    }

    left {
        text-align: left;
    }

    .action-for-Invoice {
        font-size: 20px !important;
    }

    @@media (min-width: 768px) {
        .modal-dialog-xl {
            width: 65% !important;
        }
    }

    .reverseModal .modal-content {
        width: auto;
    }

    .reverseModal .modal-body {
        position: relative;
    }

    .reverse-calc-overlay {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1050;
        background: rgba(255, 255, 255, 0.75);
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .reverse-calc-overlay.active {
        display: flex;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }
            <div class="col-sm-12 " style="margin-bottom:30px ; padding:0px;">
                <div class="btn-group">
                    @if (User.IsInRole(AppUserRoles.add_acc_Invoice))
                    {
                        <a href="@Url.Action("Create", "Invoicings")" class="btn btn-themyriad btn-search button-effect">
                            <i class="fa fa-plus" style="padding-right: 5px;"></i>
                            Add New Invoice
                        </a>
                    }
                </div>
            </div>
            <div class="">
                <div class="">
                    <div class="col-md-3">
                        <label>From Date</label>
                        <input name="daterange" id="FromDate" class="form-control from_date" value="@ViewBag.FromDate" placeholder="From Date" autocomplete="off" />
                    </div>
                    <div class="col-md-3">
                        <label>To Date</label>
                        <input name="daterange" id="ToDate" class="form-control to_date" value="@ViewBag.ToDate" placeholder="To Date" autocomplete="off" />
                    </div>
                    <div class="col-md-3">
                        <label>Invoice Type</label>
                        @Html.DropDownList("InvoiceTypeId", null, "--- All ---", htmlAttributes: new { @class = "form-control " })
                    </div>
                    <div class="col-md-3">
                        <label> &nbsp; </label>
                        <br />
                        <button type="button" onclick="GetInvoices();" class="btn btn-themyriad btn-bordered waves-effect w-md button-effect"><i class="fa fa-search"></i> <span>Search</span></button>
                        <button type="button" onclick="GetExcel()" class="btn btn-success btn-bordered waves-effect w-md button-effect" style="margin-left: 5px;"> <i class="fa fa-download"> </i> <span> Export Report </span> </button>

                    </div>
                </div>
                <br />
            </div>
        </div>
        <div class="col-md-12">
            <hr />
        </div>
        <div style="overflow: auto; width:100%">
            <div class="row" style="margin-bottom:30px">
                <div class="col-md-3">
                    <label>Search By Column:</label>
                    <select class="form-control" id="column-filter">
                        <option value="">All Columns</option>
                        <option value="Location">Location</option>
                        <option value="Code">Invoice Id</option>
                        <option value="MyriadID">MyriadID</option>
                        <option value="FullName">FullName</option>
                        <option value="Remarks">Remarks</option>
                        <option value="ServiceName">Service Name</option>
                        <option value="NetAmount">Net Amount</option>
                        <option value="Status">Status</option>
                        <option value="CreatedBy">Created By</option>
                        <option value="ApprovedBy">Approved By</option>
                    </select>
                </div>
                <div class="col-md-3" style="width: 200px;">
                    <label>Column Visibilty:</label>
                    <select multiple class="form-control" id="columnvisibilty-filter">
                        <option value="Location">Location</option>
                        <option value="Code">Invoice Id</option>
                        <option value="MyriadID">MyriadID</option>
                        <option value="FullName">FullName</option>
                        <option value="InvoiceDate">Invoice Date</option>
                        <option value="FromDate">From Date</option>
                        <option value="ToDate">To Date</option>
                        @*<option value="DueDate">Due Date</option>*@
                        <option value="Remarks">Remarks</option>
                        <option value="ServiceName">Service Name</option>
                        <option value="NetAmount">Net Amount</option>
                        <option value="PendingBalance">Pending Balance</option>
                        <option value="TotalBalanceOfResident">Total Balance</option>
                        <option value="Status">Status</option>
                        <option value="IsPaid">Paid/Unpaid</option>
                        <option value="CreatedBy">Created By</option>
                        <option value="ApprovedBy">Approved By</option>
                        <option value="CreatedDate">Created Date</option>
                    </select>
                </div>
            </div>

            <div class="col-md-12">
                <table id="tblGrid" class="table table-bordered table-striped data-table">

                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Location</th>
                            <th>Invoice Id</th>
                            <th>MyiadID</th>
                            <th>FullName</th>
                            <th>Invoice Date</th>
                            <th>FromDate</th>
                            <th>ToDate</th>
                            @*<th>Due Date</th>*@
                            <th>Remarks</th>
                            <th>Service Name</th>
                            <th>Net Amount</th>
                            <th>Pending Balance</th>
                            <th>Total Balance</th>
                            <th>Status</th>
                            <th>Paid/Unpaid</th>
                            <th>Created By</th>
                            <th>Approved By</th>
                            <th>Created Date</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal" id="ApproveConformation">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Are you sure you want to Approve?</h4>
            </div>
            <div class="modal-body">
                <p>If you Approve this invoice will no longer be editable, Please review and confirm.</p>
            </div>
            <div class="modal-footer">
                <div class="col-md-3"></div>
                <div class="col-md-4"></div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                </div>
                <div class="col-md-2">
                    <button type="button" onclick="ApproveInvoice();" class="btn btn-primary">Approve</button>
                </div>

            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

<div class="modal" id="ConfirmPaymentLink">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Are you sure you want to Generate Link?</h4>

            </div>
            <div class="modal-body" id="paymentConfirmBody">

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                <button type="button" onclick="GenratePaymentLink();" class="btn btn-danger">Generate</button>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

<div class="modal" id="PaymentLinkModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title">Payment Link</h4>
            </div>
            <div class="modal-body">
                <div class="">
                    <div class="input-group">
                        <textarea type="text" id="paymentlink" class="form-control" readonly></textarea>
                        <span class="input-group-addon" style="cursor:pointer;" onclick="Copy()"><i class="fa fa-clipboard" style="font-size: 24px;"></i></span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="col-md-4"></div>
                <div class="col-md-5"></div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>

<div class="modal reverseModal" id="ReverseInvoiceBtnConfirm">
    <form method="post" action="@Url.Action("ReverseInvoice", "Invoicings")">
        <div class="modal-dialog modal-dialog-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                    <h4 class="modal-title">Reverse Invoice</h4>
                </div>

                <div class="modal-body" style="max-height: 700px;">
                    <div class="reverse-calc-overlay">
                        <span><i class="fa fa-spinner fa-spin"></i> Calculating amounts...</span>
                    </div>
                    <p>If you Reverse this invoice will no longer be editable, Please review and confirm.</p>
                    <input type="hidden" name="id" id="ReveserInvoiceHiddenId" />
                    <input type="hidden" name="Subtotal" id="SubtotalAmountHiddenId" />
                    <input type="hidden" name="Taxtotal" id="TaxtotalAmountHiddenId" />
                    <input type="hidden" name="Discounttotal" id="DiscounttotalAmountHiddenId" />
                    <input type="hidden" name="NetTotal" id="NetTotalAmountHiddenId" />
                    <input type="hidden" name="StudentId" id="StudentId" />
                    <input type="hidden" name="InvoiceTypeId" id="InvoiceTypeId" />
                    <input type="hidden" name="OccupancyId" id="OccupancyId" />
                    <input type="hidden" name="PriceConfig" id="PriceConfig" />
                    <input type="hidden" name="FrequencyId" id="FrequencyId" />

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="reverseInvoiceTable">
                            <thead>
                                <tr>
                                    <th>Service</th>
                                    <th>Description</th>
                                    <th>From Date</th>
                                    <th>To Date</th>
                                    <th>Amount</th>
                                    <th>Tax</th>
                                    <th>Discount%</th>
                                    <th>Net Amount</th>
                                </tr>
                            </thead>
                            <tbody id="reverseInvoiceTableBody"></tbody>
                        </table>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6"></div>
                        <div class="col-md-6">
                            <table class="table">
                                <tbody class="text-bold">
                                    <tr>
                                        <th style="width:50%">Subtotal:</th>
                                        <td id="subTotalAmount">0.00</td>
                                    </tr>
                                    <tr>
                                        <th style="width:50%">Tax Amount:</th>
                                        <td id="taxAmount">0.00</td>
                                    </tr>
                                    <tr>
                                        <th style="width:50%">Discount Amount:</th>
                                        <td id="discountAmount">0.00</td>
                                    </tr>
                                    <tr>
                                        <th>Net Amount:</th>
                                        <td id="NetTotalAmount">0.00</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="reverseInvoiceRemarks">Enter remarks</label>
                        <textarea id="reverseInvoiceRemarks" class="form-control" name="Remarks" required placeholder="Remarks" style="min-height:70px"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-themyriad btn-ok" type="submit"> Reverse</button>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal" id="ReverseInvoiceBtnConfirmForMuscat">
    <form method="post" action="@Url.Action("ReverseInvoice", "Invoicings")">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                    <h4 class="modal-title">Reverse Invoice</h4>
                </div>
                <div class="modal-body">
                    <p>If you Reverse this invoice will no longer be editable, Please review and confirm.</p>
                    <input type="hidden" name="Id" id="ReveserInvoiceForMuscatHiddenId" />
                    <input type="hidden" name="LocationId" id="ReveserInvoiceForMuscatLocationHiddenId" />
                    <input type="hidden" name="InvoiceTypeId" id="ReveserInvoiceForMuscatInvoiceTypeHiddenId" />

                    <div class="form-group">
                        <label for="reverseInvoiceRemarksForMuscat">Enter remarks</label>
                        <textarea id="reverseInvoiceRemarksForMuscat" class="form-control" name="Remarks" required placeholder="Remarks" style="min-height:70px"></textarea>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-themyriad-black" data-dismiss="modal">Cancel</button>
                        <button class="btn btn-themyriad btn-ok" type="submit"> Reverse</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>



@section scripts{
    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/js/bootstrap-multiselect.min.js"></script>

    <!-- bootstrap datepicker -->
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <script>
        window.invoicingIndexConfig = {
            editAction: @(editAction ? "true" : "false"),
            approveAction: @(approveAction ? "true" : "false"),
            editAfterApproveAction: @(editAterApproveAction ? "true" : "false"),
            invDetAction: @(invDetAction ? "true" : "false"),
            reverseInvoiceAction: @(reverseInvoiceAction ? "true" : "false"),
            invoiceVoucherAction: @(invoiceVoucherAction ? "true" : "false"),
            paymentLinkAction: @(paymentLinkAction ? "true" : "false"),
            dubaiLocationId: @dubaiLocationId,
            muscatLocationId: @muscatLocationId,
            rentalInvoiceTypeId: @rentalInvoiceTypeId,
            depositInvoiceTypeId: @depositInvoiceTypeId,
            miscellaneousInvoiceTypeId: @miscellaneousInvoiceTypeId
        };
    </script>
    <script src="~/Content/Js/Invoicing/IndexPage.js"></script>
}
