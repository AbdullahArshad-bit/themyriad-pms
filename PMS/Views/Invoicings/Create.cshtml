@model PMS.EF.Invoicing

@{
    ViewBag.Header = "Invoicing";
    ViewBag.HeaderDescription = "Add New Invoice";
    ViewBag.Title = "Create Invoice | PMS";
}


@section styles{
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">

}


@Html.Partial("_CreateOrUpdate")



@section scripts
{
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Assets/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>

    <script type="text/javascript">
        $(function () {
            function addDays(date, days) {
                var result = new Date(date);
                result.setDate(result.getDate() + days);
                return result;
            }

            var startDate = new Date();

            // Initialize Invoice Date
            $('#datepicker').datepicker({
                autoclose: true,
                format: "dd/M/yyyy",
                startDate: startDate
            }).datepicker('setDate', startDate);

            // Initialize Due Date (starts from invoice date)
            var initialDueDate = addDays(startDate, 7);
            $('#dueDatePicker').datepicker({
                autoclose: true,
                format: "dd/M/yyyy",
                startDate: startDate
            }).datepicker('setDate', initialDueDate);

            // When Invoice Date changes
            $('#datepicker').on('changeDate', function (e) {
                var selectedDate = e.date;
                var newDueDate = addDays(selectedDate, 7);

                // Update Due Date picker settings
                $('#dueDatePicker').datepicker('setStartDate', selectedDate);
                $('#dueDatePicker').datepicker('setDate', newDueDate);
            });
        });


        function bindServiceDates() {
            $('.date').datepicker({
                autoclose: true,
                format: "dd/M/yyyy",
                placeholder: 'dd/mm/yyyy'

            })
        }
    </script>

    <script>
        $('#InvoiceTypeId').on('change', function () {
            
         
            //var Code = $('#Code').val()
            var LocationId = $('#LocationId').val()
            var InvoiceTypeId = $(this).val()
            if (LocationId == null || LocationId == '' || LocationId == undefined) {
                showMessage('Please Select Location id!');
                $(this).val('')
                return;
            }
            var url = GetFormatedUrl("/Invoicings/GetLocationBYId")
            $.ajax({
                type: "Get",
                url: url,
                data: {
                    Id: LocationId,
                    InvoiceTypeId: InvoiceTypeId
                },
                success: function (data) {
                    var data = data;
                    $('#Code').val(data.Code);
                    $('#StudentId').html('');
                    var html = "<option value=''>--- Select Resident Id ---</option>";
                    $.each(data.Students, function (key, value) {
                        html = html + "<option Value='" + value.PersonID + "'>" + value.FullName + "</option>"
                    })
                    $('#StudentId').html(html);
                }
            });

        });

        // Calling the Location Function
        $(document).ready(function () {
            
            setInitialLocation();
        });
    </script>
}

