@using PMS.DTO.ViewModels.DashboardViewModel
@using PMS.Common.Classes

@{
    ViewBag.Header = "Up Coming Invoices";
    ViewBag.HeaderDescription = "Up Coming Invoices";
    ViewBag.Title = "Up Coming Invoices | PMS";
    var unpaidinvoice = ViewBag.unpaidinvoice as List<unpaidInvoice>;
}

@section styles{
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/bootstrap-datepicker/dist/css/bootstrap-datepicker.min.css">
    <link rel="stylesheet" href="~/Assets/bower_components/datatables.net-bs/css/dataTables.bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.0/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.0.0/css/buttons.dataTables.min.css">

}
<style>
    .right {
        text-align: right;
    }

    left {
        text-align: left;
    }

    .action-for-Invoice {
        font-size: 20px !important;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title"></h3>
    </div>
    <div class="box box-danger">
        <div class="box-header">
            <h3 class="box-title"></h3>
        </div>
        <div class="box-body">
            @if (ViewBag.error != null)
            {
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                    @ViewBag.error
                </div>
            }
            @if (ViewBag.success != null)
            {
                <div class="alert alert-success alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    <h4><i class="icon fa fa-check"></i> Alert!</h4>
                    @ViewBag.success
                </div>
            }

            <div style="overflow: auto; width:100%">
                <div class="col-md-12">
                    <table id="UnpaidInvoice" class="table table-bordered table-striped display now" style="width:100%">

                        <thead>

                            <tr>
                                <th>Myriad ID</th>
                                <th>FullName</th>
                                <th>InvoiceDate</th>
                                <th>CheckOut</th>
                                <th>TillDate</th>
                                <th>PaidStatus</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in unpaidinvoice)
                            {
                                <tr>
                                    <td><a href="#Fee">@item.Personcode</a></td>
                                    <td>@item.FullName</td>
                                    <td>@item.InvoiceDate.Value.ToString("dd/MM/yyy")</td>
                                    <td>@item.CheckOut.Value.ToString("dd/MM/yyy")</td>
                                    <td>

                                        <span class="label label-danger">@item.TillDate.Value.ToString("dd/MM/yyyy")</span>
                                    </td>

                                    @if (item.PaidStatus == "Paid")
                                    {
                                        <td><span class="label label-success">@item.PaidStatus</span></td>
                                    }

                                    else
                                    {
                                        <td><span class="label label-danger">@item.PaidStatus</span></td>

                                    }

                                    @if (User.IsInRole(AppUserRoles.add_acc_Invoice))
                                    {
                                        <td> <a title="Create Invoice" href="@Url.Action("FeeAssessment", "Invoicings", new { StudentId = item.StudentId })" class=""><i class="fa fa-share"></i></a></td>
                                    }

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{

    <script src="https://cdn.datatables.net/1.11.0/js/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js" type="text/javascript"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/plug-ins/1.11.3/sorting/date-euro.js"></script>

    <script>

        $(document).ready(function () {
            $('#UnpaidInvoice').DataTable({
                //"scrollY": "70vh",
                //"scrollCollapse": true,
                //"scrollX": "auto",
                "paging": true,
                "searching": true,
                "lengthChange": true,
                "ordering": true,
                "scrollCollapse": true,
                "scrollY": '70vh',
                "scrollX": "auto",
                "iDisplayLength": 100,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                dom: 'Blfrtip',
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                buttons: [
                    'excelHtml5'

                ],
            });
        });

    </script>


}
