
@{
    //TheMyriad.DTO.Admin.User user = new TheMyriad.DTO.Admin.User();
    //if (HttpContext.Current.Session["User"] != null)
    //{
    //    user = HttpContext.Current.Session["User"] as TheMyriad.DTO.Admin.User;
    //}
}
@{
    var currentUrl = Request.Url;
    bool isUAT = currentUrl != null &&
                 currentUrl.Host.ToLower().Contains("themyriad.com") &&
                 currentUrl.Port == 8020;
}
<style>
    #select-location {
        display: flex;
        gap: 5px;
        margin: 10px 10px 0 0;
    }

    .navbar-lable {
        margin: 5px 15px 0 0;
    }

    #locations {
        width: 175px !important;
    }

    @@media screen and (max-width: 426px) {
        #select-location {
            display: block;
            margin: 0 10px 10px 0;
        }

        .navbar-lable {
            margin: 5px 5px 0 10px;
        }
    }

    @@media screen and (min-width: 1024px) {
        .test-env-container {
            position: absolute;
            top: 50%;
            left: 4%;
            width: auto;
            overflow: hidden;
            transform: translateY(-50%);
            white-space: nowrap;
            pointer-events: none;
            padding: 10px;
            background-color: #c20e1a;
        }
        /* Scrolling animation for the tagline */
        .test-env {
            display: inline-block;
            font-weight: bold;
            font-size: 16px;
            color: white;
            text-transform: uppercase;
            animation: marquee 10s linear infinite;
        }
    }

    @@media screen and (max-width: 1023px) {
        .test-env-container {
            display: none;
        }
    }
</style>
<body class="page1">
    <header class="main-header">

        <!-- Logo -->
        <a href="@Url.Action("Index", "Home")" class="logo">
            <!-- mini logo for sidebar mini 50x50 pixels -->
            <span class="logo-mini btn-themyriad"><b>PMS</b></span>
            <!-- logo for regular state and mobile devices -->
            <span class="logo-lg"><img src="https://www.themyriad.com/Assets/images/logo.png" alt="logo"></span>
        </a>

        <!-- Header Navbar -->
        <nav class="navbar navbar-static-top" role="navigation">
            @if (isUAT)
            {
                <div class="test-env-container">
                    <span class="test-env">TEST ENVIRONMENT</span>
                </div>
            }
            <!-- Sidebar toggle button-->
            <a href="#" class="sidebar-toggle" data-toggle="push-menu" role="button">
                <span class="sr-only">Toggle navigation</span>
            </a>

            <!-- Navbar Right Menu -->
            <div class="navbar-custom-menu">
                <ul class="nav navbar-nav">
                    <li>
                        <div class="navbar-nav" id="select-location">
                            <div class="nav-item navbar-lable "><b>Selected Location</b></div>

                            <div class="lab location-Div navbar-nav ml-auto" style="width:175px !important" id="location-Div">
                                <select name="" id="locations" class="locations select2 form-control nav-item" onchange="post()">
                                </select>
                            </div>
                        </div>
                    </li>

                    <!-- Bell Notification -->
                    <li class="dropdown notifications-menu">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown" onclick="UpdateNotification()">
                            <i class="fa fa-bell-o counter" style="color: #161515; font-size: 20px; "></i>
                            <span class="label label-warning noti_count" style=" background-color: #d10e0e !important;"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li class="header total_noti" style="text-align: center; color: #c20e1a"></li>
                            <li>
                                <!-- inner menu: contains the actual data -->
                                <ul class="menu" id="noti_descriptions">
                                </ul>
                            </li>

                            <li class="footer"><a href="@Url.Action("Index","Notification")">View all</a></li>
                        </ul>
                    </li>

                    <!-- User Account Menu -->
                    <li class="dropdown user user-menu">

                        <!-- Menu Toggle Button -->
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">

                            <!-- The user image in the navbar-->
                            <img src="~/Assets/dist/img/profile.png" class="user-image" alt="User Image">

                            <!-- hidden-xs hides the username on small devices so only the image appears. -->
                            <span class="hidden-xs">@PMS.Common.Globals.User.Name</span>
                        </a>
                        <ul class="dropdown-menu">

                            <!-- The user image in the menu -->
                            <li class="user-header">
                                <img src="~/Assets/dist/img/profile.png" class="img-circle" alt="User Image">
                                <p>
                                    @PMS.Common.Globals.User.Name
                                    <small>Member since @PMS.Common.Globals.User.CreatedDate.ToString("MMM yyyy")</small>
                                </p>
                            </li>

                            <!-- Menu Footer-->
                            <li class="user-footer">
                                <div class="pull-left">
                                    <a href="@Url.Action("ChangePassword","Account")" class="btn btn-default btn-flat">Change Password</a>
                                </div>

                                @using (Html.BeginForm("LogOut", "Account", new { area = "" }, FormMethod.Post, new { id = "logoutForm", @class = "pull-right" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <a href="javascript:document.getElementById('logoutForm').submit()" class="btn btn-themyriad btn-flat">Sign out</a>
                                }

                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
</body>