    <script>

    function showMessage(msg) {
            $('.message_modal_text').text(msg);
            $('#message_modal').modal('show');
        }

    $(document).ready(function () {

            var sessionValue = @Html.Raw(Json.Encode(Session["locationcount"]));

            if (sessionValue == null) {
                var value = localStorage.getItem('SelItem');
                // Try auto-selecting last location on server before showing modal
                $.ajax({
                    type: 'GET',
                    url: GetFormatedUrl('/Setup/GetLastLocation'),
                    success: function (resp) {
                        var loc = resp && resp.data ? resp.data : null;
                        if (loc) {
                            // Persist and set session via server strictly to one location
                            localStorage.setItem('selectedLocation', loc);
                            localStorage.setItem('SelItem', loc);
                            $.ajax({ type: 'GET', url: GetFormatedUrl('/Account/FilterData?locationid=' + loc + '&returnURL=' + window.location.href) });
                        } else if (value == null) {
                            $('.locdiv, .locdiv1').css('filter', 'blur(5px)');
                            $('#modal-location').modal('show');
                            $("#location-Div").addClass('highlight');
                        }
                    },
                    error: function () {
                        if (value == null) {
                            $('.locdiv, .locdiv1').css('filter', 'blur(5px)');
                            $('#modal-location').modal('show');
                            $("#location-Div").addClass('highlight');
                        }
                    }
                });
            }

