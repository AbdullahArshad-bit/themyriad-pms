        function post() {

            var selectedlocation = $("#locations").val();
            localStorage.setItem("selectedLocation", selectedlocation);
             var selItem = localStorage.getItem("SelItem");
               sessionStorage.setItem("mySessionValue", true);
            window.location.href = GetFormatedUrl("/Account/UpdateData?locationid=" + selectedlocation + "&returnURL=" + window.location.href);
    }

        var startDate = new Date();
        var FromEndDate = new Date();
        var ToEndDate = new Date();
        ToEndDate.setDate(ToEndDate.getDate() + 365);

        $('.From_Date').datepicker({
            weekStart: 1,
            format: " dd/M/yyyy",
            autoclose: true,
            startDate: startDate
        }).on('changeDate', function (selected) {
            startDate = new Date(selected.date.valueOf());
            $('.To_Date').datepicker('setStartDate', startDate);
            $('.To_Date').datepicker('setEndDate', new Date(startDate.getFullYear() + 1, startDate.getMonth(), startDate.getDate()));

            $('.From_Date').datepicker('hide');
        });

        $('.To_Date').datepicker({
            weekStart: 1,
            format: " dd/M/yyyy",
            autoclose: true
        });
