        });
        $('#message_modal').on('show.bs.hide', function (e) {
            $('.message_modal_text').text('');
        });
        //GetNotifications();
    });

    function readImageURL(input, img, inputImg) {
        $(img).attr('src', '');
        if (input.files && input.files[0]) {
            var size = input.files[0].size / 1024 / 1024;
            if (size > 1) {
                $('#fileSizeMessage').modal('show');
                $(inputImg).val(null);
                return;
            }
            var reader = new FileReader();
            reader.onload = function (e) {
                $(img).attr('src', e.target.result);
            }
            reader.readAsDataURL(input.files[0]);
        }
        };

    function GetNotifications() {
        var url = GetFormatedUrl("/Notification/GetNotifications")
        $.ajax({
            type: "Get",
            url: url,
            success: function (data) {
                var data = data.notifications;
                var noti_count = "";
                var total_noti = 0;
                var html = "";
                if (data != null) {
                    $.each(data, function (index, value) {
                        total_noti = data.length;
                        if (value.Counts == 0)
                            noti_count = '';
                        else
                            noti_count = value.Counts;

                        html += ` <li>
                                                <a href="${value.RedirectURL}">
                                                    <h4 style="font-weight: bold"> ${value.Subject}</h4>
                                                 <div>  <p>${value.Description}</p></div>
                                                </a>
                                            </li>`;
                    });
                    $('#noti_descriptions').html(html);
                    $('.total_noti').html(`You have ${total_noti} notifications`);
                    $('.noti_count').html(noti_count);
                }
            }
        });
        }

    function UpdateNotification() {
        var url = GetFormatedUrl("/Notification/UpdateNotification")
        $.ajax({
            type: "Get",
            url: url,
            success: function (data) {
                GetNotifications();
            }
        })
        }

        function GetLocations() {
        var url = GetFormatedUrl("/Setup/GetAssignedLocations")
        $.ajax({
            type: "Get",
            url: url,
            success: function (data) {
                var data = data.data;
                $(".locations").html('');
                var html = "";
                if (data != null) {
                    $.each(data, function (index, value) {
                        html = html + "<option Value='" + value.Value + "'>" + value.Text + "</option>"

                    });
                    $(".locations").html(html);
                    var selItem = localStorage.getItem("SelItem");

                    $("#locations").val(selItem);
                    var sessionValue = @Html.Raw(Json.Encode(Session["locationcount"]));

                    if (sessionValue != null) {
                        var sessionValue1 = sessionValue[0];
                        var val = String(sessionValue1);
                        $("#locations").val(val);
                    }
                    if (!sessionStorage.getItem("filterDataExecuted")) {
                        sessionStorage.setItem("filterDataExecuted", "true");
                        LastUsedLocation();
                    }
                }
            }
        });
        }

    $("#locations").change(function () {
        localStorage.setItem("SelItem", $(this).val());
        $('.locdiv, .locdiv1').css('filter', 'none');
    });

 // Gets Location Stored in Local Storage
