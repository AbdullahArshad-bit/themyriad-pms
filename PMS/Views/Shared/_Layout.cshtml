    <script>
        (function () {
            // Idle timeout values derived from web.config forms auth timeout (minutes)
            // For 1440 mins (1 day): show warning at 23h59m40s with 20s countdown

            var idleLimitMs = 1440 * 60 * 1000; // 1440 minutes = 1 day
            var warningOffsetMs = 20000; // 20 seconds warning
            var warningAtMs = idleLimitMs - warningOffsetMs; // Show warning 20s before timeout

            var idleTimer = null;
            var countdownTimer = null;
            var remaining = 20;

            function resetIdleTimer() {
                clearTimers();
                // Start timer to show warning at 40s
                idleTimer = setTimeout(showWarning, warningAtMs);
            }

            function clearTimers() {
                if (idleTimer) { clearTimeout(idleTimer); idleTimer = null; }
                if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; }
            }

            function showWarning() {
                remaining = 20;
                $('#idle-countdown').text(remaining);
                $('#idle-timeout-modal').modal('show');
                // Start countdown to auto-logout
                countdownTimer = setInterval(function () {
                    remaining -= 1;
                    if (remaining <= 0) {
                        clearInterval(countdownTimer);
                        countdownTimer = null;
                        performLogout();
                    } else {
                        $('#idle-countdown').text(remaining);
                    }
                }, 1000);
            }

            function performLogout() {
                try {
                    // Attach current URL so server can preserve ReturnUrl on forced logout
                    var currentUrl = window.location.pathname + window.location.search + window.location.hash;
                    document.getElementById('idleReturnUrl').value = currentUrl;
                    // Submit secured POST to logout (no ReturnUrl if current is logout)
                    if (currentUrl.toLowerCase().indexOf('/account/logout') === 0) {
                        document.getElementById('idleReturnUrl').value = '';
                    }
                    document.getElementById('idleLogoutForm').submit();
                } catch (e) {
                    // Fallback
                    window.location.href = '@Url.Content("~/Account/Login")';
                }
            }

            function keepAlive() {
                try {
                    $.ajax({
                        type: 'GET',
                        url: GetFormatedUrl('/Setup/GetLastLocation'),
                        cache: false
                    });
                } catch (e) { }
            }

            // Buttons: Continue and Logout
            $('#idle-stay-btn').on('click', function () {
                if ($('#idle-timeout-modal').hasClass('in')) {
                    $('#idle-timeout-modal').modal('hide');
                }
                // Refresh server session/auth cookie on explicit continue
                keepAlive();
                resetIdleTimer();
            });

            $('#idle-logout-btn').on('click', function () {
                performLogout();
            });

            // Only explicit interactions dismiss the modal and reset the timer
            var activityEvents = 'mousedown keydown keyup click touchstart';
            $(document).on(activityEvents, function (e) {
                var $t = $(e.target);
                // If interaction happens inside the idle modal (e.g., clicking buttons),
                // don't treat it as generic activity. Let the button handlers run.
                if ($t.closest('#idle-timeout-modal').length) {
                    return;
                }
                if ($('#idle-timeout-modal').hasClass('in')) {
                    $('#idle-timeout-modal').modal('hide');
                    // If user interacted while warning was visible, ping server to renew session
                    keepAlive();
                }
                resetIdleTimer();
            });

            // Kick off
            $(function () { resetIdleTimer(); });
        })();
    </script>
    <script type="text/javascript">

        // To make Pace works on Ajax calls
        $(document).ajaxStart(function () {
            Pace.restart()
        })
    </script>
