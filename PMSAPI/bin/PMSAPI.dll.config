<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301879
  -->
<configuration>
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <!-- Same PMS database used by the other projects. Update the data source / catalog per environment. -->
    <add name="PMSEntities" connectionString="metadata=res://*/PMS.csdl|res://*/PMS.ssdl|res://*/PMS.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=localhost;initial catalog=PMS;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient" />
  </connectionStrings>
  <appSettings>
    <!-- JWT settings for integration client authentication. Keep Jwt:Issuer in sync with the hosted URL. -->
    <add key="Jwt:key" value="db3OIsj+BXE9NZDy0t8W3TcNekrF+2d/1sFnWG4HnV8TZY30iTOdtVWJG8abWvB1GlOgJuQZdcF2Luqm/hccMw==" />
    <add key="Jwt:Issuer" value="https://localhost:44360" />
    <!-- Access token lifetime in minutes for integration clients. -->
    <add key="Jwt:ExpireMinutes" value="60" />
    <!-- Client credentials are stored in ClientIntegration (Client_ID / Client_Secret). See PMSAPI/Sql/IntegrationWebhooks.sql. -->
    <add key="OnlineBookingUserEmail" value="admin@themyriad.com" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>
  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="default.aspx" />
      </files>
    </defaultDocument>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>
  <runtime>
